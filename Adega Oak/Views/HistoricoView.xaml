<UserControl x:Class="Adega_Oak.Views.HistoricoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource MaterialDesignPaper}">
    
    <Grid Margin="24" >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource MaterialDesignCardBackground}"
                CornerRadius="8"
                Effect="{DynamicResource MaterialDesignElevationShadow2}"
                Margin="0,10,0,24">
            <Grid Margin="24,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Historico de Movimentacoes"
                               Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                               Foreground="{DynamicResource MaterialDesignBody}"/>

                    <StackPanel Orientation="Vertical" Margin="0,12,0,0">
                        <TextBlock Text="Filtrar por:" 
                                 Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                 Margin="0,0,0,8"/>
                        
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                            <StackPanel Orientation="Vertical" Margin="0,0,20,0">
                                <TextBlock Text="Tipo de Venda" 
                                         FontSize="12" 
                                         Foreground="{DynamicResource MaterialDesignBodyLight}"
                                         Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding TiposVendaFiltro}"
                                         SelectedItem="{Binding TipoVendaFiltro}"
                                         Width="120"
                                         Style="{StaticResource MaterialDesignFilledComboBox}"
                                         Foreground="{DynamicResource MaterialDesignBody}"/>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" Margin="0,0,20,0">
                                <TextBlock Text="Tipo de Movimentacao" 
                                         FontSize="12" 
                                         Foreground="{DynamicResource MaterialDesignBodyLight}"
                                         Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding TiposMovimentacaoFiltro}"
                                         SelectedItem="{Binding TipoMovimentacaoFiltro}"
                                         Width="120"
                                         Style="{StaticResource MaterialDesignFilledComboBox}"
                                         Foreground="{DynamicResource MaterialDesignBody}"/>
                            </StackPanel>

                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="Responsavel" 
                                         FontSize="12" 
                                         Foreground="{DynamicResource MaterialDesignBodyLight}"
                                         Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding ResponsavelFiltroOpcoes}"
                                         SelectedItem="{Binding ResponsavelFiltro}"
                                         Width="150"
                                         Style="{StaticResource MaterialDesignFilledComboBox}"
                                         Foreground="{DynamicResource MaterialDesignBody}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>

                <Button Grid.Column="1"
                    Command="{Binding GerarRelatorioDiarioCommand}"
                    Content="Gerar Relatorio"
                    Margin="15,0,0,0"
                    Padding="10,5"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DataGrid Grid.Row="0"
                      ItemsSource="{Binding Historico}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Margin="10"
                      Effect="{DynamicResource MaterialDesignElevationShadow2}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Data" 
                                        Binding="{Binding Data, StringFormat=dd/MM/yyyy HH:mm}" Width="Auto"/>
                    <DataGridTextColumn Header="Tipo" 
                                        Binding="{Binding Tipo}" Width="Auto"/>
                    <DataGridTextColumn Header="Tipo de Venda" 
                                        Binding="{Binding TipoVenda}" Width="Auto"
                                        Visibility="Visible"/>
                    <DataGridTextColumn Header="Produto" 
                                        Binding="{Binding ProdutoDescricao}" Width="Auto"/>
                    <DataGridTextColumn Header="Quantidade" 
                                        Binding="{Binding Quantidade}" Width="Auto"/>
                    <DataGridTextColumn Header="Responsavel" 
                                        Binding="{Binding Responsavel}" Width="Auto"/>
                    <DataGridTextColumn Header="Tipo Saida" 
                                        Binding="{Binding TipoSaida}" Width="Auto"/>
                    <DataGridTextColumn Header="Valor Total" 
                                        Binding="{Binding ValorTotal, StringFormat=C2}" Width="Auto"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="1"
                    Background="{DynamicResource MaterialDesignCardBackground}"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="0,1,0,0"
                    Padding="20,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Totais:" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0">
                        <TextBlock Text="Entradas: " FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalEntradas, StringFormat=C2}" 
                                  FontWeight="Bold" 
                                  Foreground="Green"
                                  VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="20,0">
                        <TextBlock Text="Saidas: " FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalSaidas, StringFormat=C2}" 
                                  FontWeight="Bold" 
                                  Foreground="Red"
                                  VerticalAlignment="Center"/>
                    </StackPanel>

                    <Separator Grid.Column="3" Width="1" Margin="20,0" Background="{DynamicResource MaterialDesignDivider}"/>

                    <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="20,0">
                        <TextBlock Text="Total Geral: " FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalGeral, StringFormat=C2}" 
                                  FontWeight="Bold" 
                                  FontSize="14"
                                  VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="1" 
                Visibility="{Binding RelatorioDiario, Converter={StaticResource NullToVisibilityConverter}}"
                Background="#80000000"
                VerticalAlignment="Stretch"
                HorizontalAlignment="Stretch">
            <Border Background="{DynamicResource MaterialDesignCardBackground}" 
                    BorderBrush="Gray" 
                    BorderThickness="1" 
                    CornerRadius="5"
                    Padding="20"
                    MaxWidth="800"
                    MaxHeight="600">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Text="{Binding RelatorioDiario.Data, StringFormat='Relatorio do dia {0:dd/MM/yyyy}'}"
                                  FontSize="18"
                                  FontWeight="Bold"
                                  Margin="0,0,0,10"/>
                        
                        <Button Grid.Column="1"
                                Command="{Binding FecharRelatorioCommand}"
                                Content="X"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="5"
                                Margin="10,0,0,0"/>
                    </Grid>

                    <StackPanel Grid.Row="1">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <DatePicker SelectedDate="{Binding DataSelecionada}" Width="120"/>
                            <Button Command="{Binding GerarRelatorioDiarioCommand}" 
                                    Content="Gerar Relatorio do Dia" 
                                    Margin="10,0,0,0"/>
                        </StackPanel>
                        
                        <TextBlock Text="Movimentacoes de Saida" 
                                   FontWeight="Bold" 
                                   FontSize="16" 
                                   Margin="0,0,0,10"/>
                        
                        <DataGrid ItemsSource="{Binding RelatorioDiario.Movimentacoes}" 
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="True"
                                  MaxHeight="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Hora" 
                                                  Binding="{Binding Data, StringFormat=HH:mm}" Width="Auto"/>
                                <DataGridTextColumn Header="Produto" 
                                                  Binding="{Binding ProdutoDescricao}" Width="Auto"/>
                                <DataGridTextColumn Header="Quantidade" 
                                                  Binding="{Binding Quantidade}" Width="Auto"/>
                                <DataGridTextColumn Header="Tipo Saida" 
                                                  Binding="{Binding TipoSaida}" Width="Auto"/>
                                <DataGridTextColumn Header="Valor Unit." Width="Auto" Binding="{Binding ValorUnitario, StringFormat=C2}">
                                    <DataGridTextColumn.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Tipo}" Value="Entrada">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.CellStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Valor Total" Width="Auto" Binding="{Binding ValorTotal, StringFormat=C2}">
                                    <DataGridTextColumn.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Tipo}" Value="Entrada">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.CellStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <TextBlock Text="Total de Saidas: " FontWeight="Bold"/>
                            <TextBlock Text="{Binding RelatorioDiario.TotalSaidas, StringFormat=C2}" FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <TextBlock Text="Varejo: " FontWeight="Bold" Foreground="Green" Margin="20,0,5,0"/>
                            <TextBlock Text="{Binding TotalVarejoDia, StringFormat=C2}" FontWeight="Bold" Foreground="Green"/>
                            
                            <TextBlock Text="Atacado: " FontWeight="Bold" Foreground="Orange" Margin="20,0,5,0"/>
                            <TextBlock Text="{Binding TotalAtacadoDia, StringFormat=C2}" FontWeight="Bold" Foreground="Orange"/>
                        </StackPanel>
                    </StackPanel>

                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
