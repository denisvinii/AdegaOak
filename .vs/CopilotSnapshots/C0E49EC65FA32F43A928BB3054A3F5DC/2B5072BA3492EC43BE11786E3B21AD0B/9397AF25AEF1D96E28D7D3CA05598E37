    private void CriarTabelasSQLiteSeNecessario(SqliteConnection? conn = null)
    {
        bool shouldDisposeConnection = conn == null;
        conn ??= new SqliteConnection($"Data Source={_sqliteDbPath}");
        if (conn.State != ConnectionState.Open)
            conn.Open();

        using var cmd = conn.CreateCommand();

        // Tabela de produtos
        cmd.CommandText = @"
            CREATE TABLE IF NOT EXISTS estoque (
                productid INTEGER PRIMARY KEY,
                bebida TEXT NOT NULL,
                tamanho TEXT NOT NULL,
                material TEXT NOT NULL,
                valor DECIMAL NOT NULL DEFAULT 0,
                valor_venda DECIMAL NOT NULL DEFAULT 0,
                quantidade_caixa INTEGER DEFAULT 1,
                valor_caixa DECIMAL NOT NULL DEFAULT 0,
                valor_atacado_caixa DECIMAL NOT NULL DEFAULT 0,
                estoque_minimo INTEGER DEFAULT 0,
                quantidade_minima_atacado INTEGER DEFAULT 20
            )";
        cmd.ExecuteNonQuery();

        // Tabela de movimentações
        cmd.CommandText = @"
            CREATE TABLE IF NOT EXISTS movimentacoes (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                data TEXT NOT NULL,
                tipo TEXT NOT NULL,
                tipo_venda TEXT DEFAULT 'Varejo',
                productid INTEGER NOT NULL,
                produto TEXT NOT NULL,
                quantidade INTEGER NOT NULL,
                responsavel TEXT NOT NULL,
                saida TEXT,
                valor_unitario DECIMAL NOT NULL DEFAULT 0,
                FOREIGN KEY (productid) REFERENCES estoque(productid)
            )";
        cmd.ExecuteNonQuery();

        // Tabela de configuração de quantidade mínima de atacado
        cmd.CommandText = @"
            CREATE TABLE IF NOT EXISTS configuracao_atacado (
                productid INTEGER PRIMARY KEY,
                quantidade_minima_atacado INTEGER DEFAULT 20,
                ativo BOOLEAN DEFAULT 1,
                FOREIGN KEY (productid) REFERENCES estoque(productid)
            )";
        cmd.ExecuteNonQuery();

        // Tabela de funcionários
        cmd.CommandText = @"
            CREATE TABLE IF NOT EXISTS funcionarios (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                username TEXT NOT NULL UNIQUE
            )";
        cmd.ExecuteNonQuery();

        // Tabela de controle de sincronização
        cmd.CommandText = @"
            CREATE TABLE IF NOT EXISTS sync_control (
                ultima_sync TEXT,
                status TEXT
            )";
        cmd.ExecuteNonQuery();

        // Tabela de despesas
        cmd.CommandText = @"
            CREATE TABLE IF NOT EXISTS despesas (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                descricao TEXT NOT NULL,
                valor REAL NOT NULL,
                data DATETIME NOT NULL,
                tipo INTEGER NOT NULL,
                pago BOOLEAN DEFAULT 0,
                data_pagamento DATETIME,
                notas TEXT,
                criado_em DATETIME DEFAULT CURRENT_TIMESTAMP
            )";
        cmd.ExecuteNonQuery();

        // Tabela de Copoes
        cmd.CommandText = @"
            CREATE TABLE IF NOT EXISTS copoes (
                copao_id INTEGER PRIMARY KEY AUTOINCREMENT,
                nome TEXT NOT NULL UNIQUE,
                descricao TEXT,
                preco_venda DECIMAL(10,2) NOT NULL,
                ativo BOOLEAN DEFAULT 1,
                data_criacao DATETIME DEFAULT CURRENT_TIMESTAMP
            )";
        cmd.ExecuteNonQuery();

        // Tabela de Composicao de Copoes
        cmd.CommandText = @"
            CREATE TABLE IF NOT EXISTS copao_composicao (
                composicao_id INTEGER PRIMARY KEY AUTOINCREMENT,
                copao_id INTEGER NOT NULL,
                product_id INTEGER NOT NULL,
                quantidade DECIMAL(10,4) NOT NULL,
                unidade TEXT NOT NULL,
                debita_estoque BOOLEAN DEFAULT 0,
                FOREIGN KEY (copao_id) REFERENCES copoes(copao_id) ON DELETE CASCADE,
                FOREIGN KEY (product_id) REFERENCES estoque(productid) ON DELETE RESTRICT
            )";
        cmd.ExecuteNonQuery();

        // Tabela de Vendas de Copoes
        cmd.CommandText = @"
            CREATE TABLE IF NOT EXISTS copao_vendas (
                venda_id INTEGER PRIMARY KEY AUTOINCREMENT,
                copao_id INTEGER NOT NULL,
                quantidade INTEGER NOT NULL,
                preco_unitario DECIMAL(10,2) NOT NULL,
                preco_total DECIMAL(10,2) NOT NULL,
                data_venda DATETIME DEFAULT CURRENT_TIMESTAMP,
                responsavel TEXT,
                observacoes TEXT,
                FOREIGN KEY (copao_id) REFERENCES copoes(copao_id)
            )";
        cmd.ExecuteNonQuery();

        // Criar indices para Copoes
        cmd.CommandText = @"
            CREATE INDEX IF NOT EXISTS idx_copao_composicao_copao 
            ON copao_composicao(copao_id)";
        cmd.ExecuteNonQuery();

        cmd.CommandText = @"
            CREATE INDEX IF NOT EXISTS idx_copao_composicao_product 
            ON copao_composicao(product_id)";
        cmd.ExecuteNonQuery();

        cmd.CommandText = @"
            CREATE INDEX IF NOT EXISTS idx_copao_vendas_copao 
            ON copao_vendas(copao_id)";
        cmd.ExecuteNonQuery();

        cmd.CommandText = @"
            CREATE INDEX IF NOT EXISTS idx_copao_vendas_data 
            ON copao_vendas(data_venda)";
        cmd.ExecuteNonQuery();

        // Garante que existe pelo menos um usuário admin
        using (var checkCmd = conn.CreateCommand())
        {
            checkCmd.CommandText = "SELECT COUNT(*) FROM funcionarios WHERE username = 'admin'";
            var adminCount = Convert.ToInt32(checkCmd.ExecuteScalar());
            if (adminCount == 0)
            {
                using var insertCmd = conn.CreateCommand();
                insertCmd.CommandText = "INSERT INTO funcionarios (username) VALUES ('admin')";
                insertCmd.ExecuteNonQuery();
            }
        }

        if (shouldDisposeConnection)
            conn.Dispose();
    }

