    /// <summary>
    /// Faz backup incremental das tabelas da nuvem para o banco local.
    /// </summary>
    public void BackupBancoNuvemParaLocal()
    {
        if (!IsOnline())
            return;

        using var pgConn = new NpgsqlConnection(_dbCloudConnectionString);
        using var sqliteConn = new SqliteConnection($"Data Source={_sqliteDbPath}");
        pgConn.Open();
        sqliteConn.Open();

        CriarTabelasSQLiteSeNecessario();

        // Backup da tabela estoque (aqui pode limpar pois é dado de referência)
        using (var pgCmd = pgConn.CreateCommand())
        {
            // Alterado para incluir as colunas de atacado e minimo
            pgCmd.CommandText = "SELECT productid, bebida, tamanho, material, estoque_minimo, valor, valor_venda, quantidade_caixa, valor_caixa, valor_atacado_caixa, quantidade_minima_atacado FROM estoque";
            using var reader = pgCmd.ExecuteReader();
            using var tx = sqliteConn.BeginTransaction();

            using (var delCmd = sqliteConn.CreateCommand())
            {
                delCmd.CommandText = "DELETE FROM estoque";
                delCmd.ExecuteNonQuery();
            }

            while (reader.Read())
            {
                using var insertCmd = sqliteConn.CreateCommand();
                // Atualizado para incluir as colunas valor_venda, quantidade_caixa, valor_caixa, valor_atacado_caixa e quantidade_minima_atacado
                insertCmd.CommandText = "INSERT INTO estoque (productid, bebida, tamanho, material, estoque_minimo, valor, valor_venda, quantidade_caixa, valor_caixa, valor_atacado_caixa, quantidade_minima_atacado) VALUES (@id, @bebida, @tamanho, @material, @minimo, @valor, @valor_venda, @qtd_caixa, @valor_caixa, @valor_atacado_caixa, @quantidade_minima_atacado)";
                insertCmd.Parameters.AddWithValue("@id", reader.GetInt32(0));
                insertCmd.Parameters.AddWithValue("@bebida", reader.GetString(1));
                insertCmd.Parameters.AddWithValue("@tamanho", reader.GetString(2));
                insertCmd.Parameters.AddWithValue("@material", reader.GetString(3));
                insertCmd.Parameters.AddWithValue("@minimo", reader.IsDBNull(4) ? 0 : reader.GetInt32(4));
                insertCmd.Parameters.AddWithValue("@valor", reader.IsDBNull(5) ? 0 : reader.GetDecimal(5));
                insertCmd.Parameters.AddWithValue("@valor_venda", reader.IsDBNull(6) ? 0 : reader.GetDecimal(6));
                insertCmd.Parameters.AddWithValue("@qtd_caixa", reader.IsDBNull(7) ? 1 : reader.GetInt32(7));
                insertCmd.Parameters.AddWithValue("@valor_caixa", reader.IsDBNull(8) ? 0 : reader.GetDecimal(8));
                insertCmd.Parameters.AddWithValue("@valor_atacado_caixa", reader.IsDBNull(9) ? 0 : reader.GetDecimal(9));
                insertCmd.Parameters.AddWithValue("@quantidade_minima_atacado", reader.FieldCount > 10 && !reader.IsDBNull(10) ? reader.GetInt32(10) : 20);
                insertCmd.ExecuteNonQuery();
            }
            tx.Commit();
        }

        // Backup da tabela funcionarios (aqui pode limpar pois é dado de referência)
        using (var pgCmd = pgConn.CreateCommand())
        {
            pgCmd.CommandText = "SELECT id, username FROM funcionarios";
            using var reader = pgCmd.ExecuteReader();
            using var tx = sqliteConn.BeginTransaction();

            using (var delCmd = sqliteConn.CreateCommand())
            {
                delCmd.CommandText = "DELETE FROM funcionarios";
                delCmd.ExecuteNonQuery();
            }

            while (reader.Read())
            {
                using var insertCmd = sqliteConn.CreateCommand();
                insertCmd.CommandText = "INSERT INTO funcionarios (id, username) VALUES (@id, @username)";
                insertCmd.Parameters.AddWithValue("@id", reader.GetInt32(0));
                insertCmd.Parameters.AddWithValue("@username", reader.GetString(1));
                insertCmd.ExecuteNonQuery();
            }
            tx.Commit();
        }

        // Backup da tabela movimentacoes
        using (var countCmd = sqliteConn.CreateCommand())
        {
            countCmd.CommandText = "SELECT COUNT(*) FROM movimentacoes";
            var count = Convert.ToInt32(countCmd.ExecuteScalar());

            if (count == 0)
            {
                // Faz backup completo inicial
                using var pgCmd = pgConn.CreateCommand();
                pgCmd.CommandText = "SELECT data, tipo, tipo_venda, productid, produto, quantidade, responsavel, saida, valor_unitario FROM movimentacoes ORDER BY data DESC";
                using var reader = pgCmd.ExecuteReader();
                using var tx = sqliteConn.BeginTransaction();

                try
                {
                    while (reader.Read())
                    {
                        using var insertCmd = sqliteConn.CreateCommand();
                        insertCmd.CommandText = @"
                            INSERT OR IGNORE INTO movimentacoes 
                            (data, tipo, tipo_venda, productid, produto, quantidade, responsavel, saida, valor_unitario) 
                            VALUES (@data, @tipo, @tipo_venda, @productid, @produto, @quantidade, @responsavel, @saida, @valor_unitario)";

                        insertCmd.Parameters.AddWithValue("@data", reader.GetDateTime(0).ToString("yyyy-MM-dd HH:mm:ss"));
                        insertCmd.Parameters.AddWithValue("@tipo", reader.GetString(1));
                        insertCmd.Parameters.AddWithValue("@tipo_venda", reader.IsDBNull(2) ? "Varejo" : reader.GetString(2));
                        insertCmd.Parameters.AddWithValue("@productid", reader.GetInt32(3));
                        insertCmd.Parameters.AddWithValue("@produto", reader.GetString(4));
                        insertCmd.Parameters.AddWithValue("@quantidade", reader.GetInt32(5));
                        insertCmd.Parameters.AddWithValue("@responsavel", reader.GetString(6));
                        insertCmd.Parameters.AddWithValue("@saida", reader.IsDBNull(7) ? DBNull.Value : reader.GetString(7));
                        insertCmd.Parameters.AddWithValue("@valor_unitario", reader.IsDBNull(8) ? 0 : reader.GetDecimal(8));
                        insertCmd.ExecuteNonQuery();
                    }
                    tx.Commit();
                }
                catch
                {
                    tx.Rollback();
                    throw;
                }
            }
            else
            {
                // Faz backup incremental apenas das novas movimentações
                using var pgCmd = pgConn.CreateCommand();
                pgCmd.CommandText = @"
                    SELECT m.data, m.tipo, m.tipo_venda, m.productid, m.produto, m.quantidade, m.responsavel, m.saida, m.valor_unitario 
                    FROM movimentacoes m 
                    WHERE NOT EXISTS (
                        SELECT 1 FROM movimentacoes l
                        WHERE l.data = m.data AND l.productid = m.productid
                    )
                    ORDER BY m.data DESC";

                using var reader = pgCmd.ExecuteReader();
                using var tx = sqliteConn.BeginTransaction();

                try
                {
                    while (reader.Read())
                    {
                        using var insertCmd = sqliteConn.CreateCommand();
                        insertCmd.CommandText = @"
                            INSERT OR IGNORE INTO movimentacoes 
                            (data, tipo, tipo_venda, productid, produto, quantidade, responsavel, saida, valor_unitario) 
                            VALUES (@data, @tipo, @tipo_venda, @productid, @produto, @quantidade, @responsavel, @saida, @valor_unitario)";

                        insertCmd.Parameters.AddWithValue("@data", reader.GetDateTime(0).ToString("yyyy-MM-dd HH:mm:ss"));
                        insertCmd.Parameters.AddWithValue("@tipo", reader.GetString(1));
                        insertCmd.Parameters.AddWithValue("@tipo_venda", reader.IsDBNull(2) ? "Varejo" : reader.GetString(2));
                        insertCmd.Parameters.AddWithValue("@productid", reader.GetInt32(3));
                        insertCmd.Parameters.AddWithValue("@produto", reader.GetString(4));
                        insertCmd.Parameters.AddWithValue("@quantidade", reader.GetInt32(5));
                        insertCmd.Parameters.AddWithValue("@responsavel", reader.GetString(6));
                        insertCmd.Parameters.AddWithValue("@saida", reader.IsDBNull(7) ? DBNull.Value : reader.GetString(7));
                        insertCmd.Parameters.AddWithValue("@valor_unitario", reader.IsDBNull(8) ? 0 : reader.GetDecimal(8));
                        insertCmd.ExecuteNonQuery();
                    }
                    tx.Commit();
                }
                catch
                {
                    tx.Rollback();
                    throw;
                }
            }
        }
    }

    /// <summary>
    /// Sincroniza movimentações locais para a nuvem (envia apenas as que não existem na nuvem).
    /// </summary>
    public void SincronizarDadosParaNuvem()
    {
        if (!IsOnline())
            return;

        using var pgConn = new NpgsqlConnection(_dbCloudConnectionString);
        using var sqliteConn = new SqliteConnection($"Data Source={_sqliteDbPath}");
        pgConn.Open();
        sqliteConn.Open();

        // 1. Buscar movimentações já existentes na nuvem (usando data+productid+tipo_venda+quantidade+valor_unitario como chave)
        var movimentacoesNaNuvem = new Dictionary<string, (DateTime data, int productid, string? tipo_venda, int quantidade, decimal valor_unitario)>();
        using (var pgCmd = pgConn.CreateCommand())
        {
            pgCmd.CommandText = "SELECT data, productid, COALESCE(tipo_venda, 'Varejo'), quantidade, COALESCE(valor_unitario, 0) FROM movimentacoes";
            using var reader = pgCmd.ExecuteReader();
            while (reader.Read())
            {
                string dataStr = reader.GetDateTime(0).ToString("yyyy-MM-dd HH:mm:ss");
                int productid = reader.GetInt32(1);
                string tipoVenda = reader.IsDBNull(2) ? "Varejo" : reader.GetString(2);
                int quantidade = reader.GetInt32(3);
                decimal valorUnit = reader.IsDBNull(4) ? 0 : reader.GetDecimal(4);
                string chave = $"{dataStr}|{productid}|{tipoVenda}|{quantidade}|{valorUnit}";
                movimentacoesNaNuvem[chave] = (reader.GetDateTime(0), productid, tipoVenda, quantidade, valorUnit);
            }
        }

        // 2. Buscar movimentações locais (usando mesma chave composta)
        var movimentacoesLocais = new Dictionary<string, (string data, string tipo, string? tipo_venda, int productid, string produto, int quantidade, string responsavel, object? saida, decimal? valor_unitario)>();
        using (var sqliteCmd = sqliteConn.CreateCommand())
        {
            // Inclui tipo_venda e valor_unitario no select local
            sqliteCmd.CommandText = "SELECT data, tipo, tipo_venda, productid, produto, quantidade, responsavel, saida, valor_unitario FROM movimentacoes";
            using var reader = sqliteCmd.ExecuteReader();
            while (reader.Read())
            {
                string data = reader.GetString(0);
                int productid = reader.GetInt32(3);
                string tipoVendaLocal = reader.IsDBNull(2) ? "Varejo" : reader.GetString(2);
                int quantidadeLocal = reader.GetInt32(5);
                decimal valorUnitLocal = reader.IsDBNull(8) ? 0 : reader.GetDecimal(8);
                string chave = $"{data}|{productid}|{tipoVendaLocal}|{quantidadeLocal}|{valorUnitLocal}";
                movimentacoesLocais[chave] = (
                    data,
                    reader.GetString(1),
                    tipoVendaLocal,
                    productid,
                    reader.GetString(4),
                    quantidadeLocal,
                    reader.GetString(6),
                    reader.IsDBNull(7) ? null : reader.GetString(7),
                    reader.IsDBNull(8) ? (decimal?)null : reader.GetDecimal(8)
                );
            }
        }

        // 3. Incluir na nuvem as movimentações que existem localmente e não estão na nuvem
        foreach (var kvp in movimentacoesLocais)
        {
            if (!movimentacoesNaNuvem.ContainsKey(kvp.Key))
            {
                var mov = kvp.Value;
                using var insertCmd = pgConn.CreateCommand();
                insertCmd.CommandText = "INSERT INTO movimentacoes (data, tipo, tipo_venda, productid, produto, quantidade, responsavel, saida, valor_unitario) VALUES (@data, @tipo, @tipo_venda, @productid, @produto, @quantidade, @responsavel, @saida, @valor_unitario)";
                insertCmd.Parameters.AddWithValue("@data", DateTime.Parse(mov.data));
                insertCmd.Parameters.AddWithValue("@tipo", mov.tipo);
                insertCmd.Parameters.AddWithValue("@tipo_venda", mov.tipo_venda ?? "Varejo");
                insertCmd.Parameters.AddWithValue("@productid", mov.productid);
                insertCmd.Parameters.AddWithValue("@produto", mov.produto);
                insertCmd.Parameters.AddWithValue("@quantidade", mov.quantidade);
                insertCmd.Parameters.AddWithValue("@responsavel", mov.responsavel);
                insertCmd.Parameters.AddWithValue("@saida", mov.saida ?? DBNull.Value);
                insertCmd.Parameters.AddWithValue("@valor_unitario", mov.valor_unitario ?? 0);
                insertCmd.ExecuteNonQuery();
            }
        }

    }

    /// <summary>
    /// Fluxo recomendado: sincroniza dados locais para a nuvem, atualiza dados de referência e movimentações da nuvem.
    /// </summary>
    public void SincronizarEAtualizarBackupLocal()
    {
        if (!IsOnline())
            return;

        try
        {
            System.Diagnostics.Debug.WriteLine("Iniciando sincronização...");

            // 1. Garante que as tabelas existem
            CriarTabelasSQLiteSeNecessario();

            // 2. Primeiro atualiza dados de referência (estoque e funcionários)
            AtualizarDadosReferencia();
            System.Diagnostics.Debug.WriteLine("Dados de referência atualizados");

            // 3. Sincroniza todas as movimentações
            SincronizarMovimentacoesNuvem();
            System.Diagnostics.Debug.WriteLine("Movimentações sincronizadas");

            // 4. Atualiza controle
            AtualizarSyncControl("Sincronização concluída com sucesso");
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Erro na sincronização: {ex.Message}");
            AtualizarSyncControl($"Erro na sincronização: {ex.Message}");
            throw;
        }
    }
