                );";

            // Verifica se a coluna valor_venda existe e adiciona se necessário
            cmd.CommandText = @"
                DO $$
                BEGIN
                    IF NOT EXISTS (
                        SELECT 1 
                        FROM information_schema.columns 
                        WHERE table_name = 'estoque' AND column_name = 'valor_venda'
                    ) THEN
                        ALTER TABLE estoque ADD COLUMN valor_venda DECIMAL DEFAULT 0;
                    END IF;
                    
                    IF NOT EXISTS (
