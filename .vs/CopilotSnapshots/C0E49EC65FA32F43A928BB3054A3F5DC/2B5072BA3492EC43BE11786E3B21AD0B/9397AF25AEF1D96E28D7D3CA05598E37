    #region Helpers
    private void AtualizarDadosReferencia()
    {
        using var pgConn = new NpgsqlConnection(_dbCloudConnectionString);
        using var sqliteConn = new SqliteConnection($"Data Source={_sqliteDbPath}");
        pgConn.Open();
        sqliteConn.Open();

        // Atualiza estoque
        using (var tx = sqliteConn.BeginTransaction())
        {
            try
            {
                // 1. Criar tabela temporária para os dados atuais da nuvem
                using (var createTempCmd = sqliteConn.CreateCommand())
                {
                    createTempCmd.CommandText = @"
                        CREATE TEMP TABLE IF NOT EXISTS estoque_temp (
                            productid INTEGER PRIMARY KEY,
                            bebida TEXT,
                            tamanho TEXT,
                            material TEXT,
                            estoque_minimo INTEGER,
                            valor DECIMAL(10,2),
                            valor_venda DECIMAL(10,2),
                            quantidade_caixa INTEGER DEFAULT 1,
                            valor_caixa DECIMAL(10,2) DEFAULT 0,
                            valor_atacado_caixa DECIMAL(10,2) DEFAULT 0,
                            quantidade_minima_atacado INTEGER DEFAULT 1
                        )";
                    createTempCmd.ExecuteNonQuery();
                }

                // 2. Limpar tabela temporária
                using (var clearTempCmd = sqliteConn.CreateCommand())
                {
                    clearTempCmd.CommandText = "DELETE FROM estoque_temp";
                    clearTempCmd.ExecuteNonQuery();
                }

                // 3. Carregar dados da nuvem na tabela temporária
                using (var pgCmd = pgConn.CreateCommand())
                {
                    pgCmd.CommandText = @"
                        SELECT productid, bebida, tamanho, material, 
                               estoque_minimo, valor, valor_venda, quantidade_caixa, valor_caixa, valor_atacado_caixa
                        FROM estoque";
                    using var reader = pgCmd.ExecuteReader();

                    while (reader.Read())
                    {
                        using var insertTempCmd = sqliteConn.CreateCommand();
                        insertTempCmd.CommandText = @"
                            INSERT INTO estoque_temp (
                                productid, bebida, tamanho, material, 
                                estoque_minimo, valor, valor_venda, quantidade_caixa, valor_caixa, valor_atacado_caixa
                            ) VALUES (
                                @id, @bebida, @tamanho, @material, 
                                @minimo, @valor, @valor_venda, @quantidade_caixa, @valor_caixa, @valor_atacado_caixa
                            )";

                        insertTempCmd.Parameters.AddWithValue("@id", reader.GetInt32(0));
                        insertTempCmd.Parameters.AddWithValue("@bebida", reader.GetString(1));
                        insertTempCmd.Parameters.AddWithValue("@tamanho", reader.GetString(2));
                        insertTempCmd.Parameters.AddWithValue("@material", reader.GetString(3));
                        insertTempCmd.Parameters.AddWithValue("@minimo", reader.IsDBNull(4) ? 0 : reader.GetInt32(4));
                        insertTempCmd.Parameters.AddWithValue("@valor", reader.IsDBNull(5) ? 0 : reader.GetDecimal(5));
                        insertTempCmd.Parameters.AddWithValue("@valor_venda", reader.IsDBNull(6) ? 0 : reader.GetDecimal(6));
                        insertTempCmd.Parameters.AddWithValue("@quantidade_caixa", reader.IsDBNull(7) ? 1 : reader.GetInt32(7));
                        insertTempCmd.Parameters.AddWithValue("@valor_caixa", reader.IsDBNull(8) ? 0 : reader.GetDecimal(8));
                        insertTempCmd.Parameters.AddWithValue("@valor_atacado_caixa", reader.IsDBNull(9) ? 0 : reader.GetDecimal(9));
                        // quantidade_minima_atacado may not exist in older schemas; guard by FieldCount
                        insertTempCmd.Parameters.AddWithValue("@quantidade_minima_atacado", reader.FieldCount > 10 && !reader.IsDBNull(10) ? reader.GetInt32(10) : 20);
                        insertTempCmd.ExecuteNonQuery();
                    }
                }

                // 4. Atualizar tabela principal
                using (var mergeCmd = sqliteConn.CreateCommand())
                {
                    // Build column list dynamically based on target table columns to avoid mismatches
                    var targetCols = new List<string>();
                    using (var colsCmd = sqliteConn.CreateCommand())
                    {
                        colsCmd.CommandText = "PRAGMA table_info(estoque);";
                        using var colsReader = colsCmd.ExecuteReader();
                        while (colsReader.Read())
                        {
                            targetCols.Add(colsReader.GetString(1));
                        }
                    }

                    // Columns present in the temporary table (as created above)
                    var tempCols = new[]
                    {
                        "productid","bebida","tamanho","material",
                        "estoque_minimo","valor","valor_venda","quantidade_caixa",
                        "valor_caixa","valor_atacado_caixa","quantidade_minima_atacado"
                    };

                    var insertCols = tempCols.Where(c => targetCols.Contains(c)).ToArray();
                    var colList = string.Join(", ", insertCols);
                    var selectList = string.Join(", ", insertCols.Select(c => c));

                    if (insertCols.Length == 0)
                    {
                        // Fallback: try to do simple replace
                        mergeCmd.CommandText = @"
                            INSERT OR REPLACE INTO estoque 
                            SELECT * FROM estoque_temp";
                    }
                    else
                    {
                        mergeCmd.CommandText = $@"
                            INSERT OR REPLACE INTO estoque ({colList})
                            SELECT {selectList} FROM estoque_temp";
                    }

                    mergeCmd.ExecuteNonQuery();
                }

                // 5. Remover registros que não existem mais na nuvem
                using (var cleanupCmd = sqliteConn.CreateCommand())
                {
                    cleanupCmd.CommandText = @"
                        DELETE FROM estoque 
                        WHERE productid NOT IN (SELECT productid FROM estoque_temp)
                            AND EXISTS (SELECT 1 FROM estoque)
                            AND EXISTS (SELECT 1 FROM estoque_temp)";
                    cleanupCmd.ExecuteNonQuery();
                }

                tx.Commit();
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Erro ao atualizar dados de referência: {ex.Message}");
                tx.Rollback();
                throw;
            }
            finally
            {
                // 6. Limpar tabela temporária
                using var dropTempCmd = sqliteConn.CreateCommand();
                dropTempCmd.CommandText = "DROP TABLE IF EXISTS estoque_temp";
                dropTempCmd.ExecuteNonQuery();
            }
        }

        // Continua com a atualização dos funcionários...
        using (var tx = sqliteConn.BeginTransaction())
        {
            try
            {
                using (var pgCmd = pgConn.CreateCommand())
                {
                    pgCmd.CommandText = "SELECT id, username FROM funcionarios";
                    using var reader = pgCmd.ExecuteReader();

                    while (reader.Read())
                    {
                        using var insertCmd = sqliteConn.CreateCommand();
                        insertCmd.CommandText = @"
                            INSERT INTO funcionarios (id, username) 
                            VALUES (@id, @username)
                            ON CONFLICT(id) DO UPDATE SET
                                username = @username";

                        insertCmd.Parameters.AddWithValue("@id", reader.GetInt32(0));
                        insertCmd.Parameters.AddWithValue("@username", reader.GetString(1));
                        insertCmd.ExecuteNonQuery();
                    }
                }

                tx.Commit();
            }
            catch
            {
                tx.Rollback();
                throw;
            }
        }
    }

    private void SincronizarMovimentacoesNuvem()
    {
        using var pgConn = new NpgsqlConnection(_dbCloudConnectionString);
        using var sqliteConn = new SqliteConnection($"Data Source={_sqliteDbPath}");
        pgConn.Open();
        sqliteConn.Open();

        using var tx = sqliteConn.BeginTransaction();
        try
        {
            // Primeiro limpa todas as movimentações locais
            using (var delCmd = sqliteConn.CreateCommand())
            {
                delCmd.CommandText = "DELETE FROM movimentacoes";
                delCmd.ExecuteNonQuery();
            }

            // Busca todas as movimentações do PostgreSQL
            using var pgCmd = pgConn.CreateCommand();
            pgCmd.CommandText = @"
                SELECT data, tipo, tipo_venda, productid, produto, quantidade, responsavel, saida, valor_unitario 
                FROM movimentacoes 
                ORDER BY data DESC";

            using var reader = pgCmd.ExecuteReader();
            while (reader.Read())
            {
                using var insertCmd = sqliteConn.CreateCommand();
                insertCmd.CommandText = @"
                    INSERT OR IGNORE INTO movimentacoes 
                    (data, tipo, tipo_venda, productid, produto, quantidade, responsavel, saida, valor_unitario) 
                    VALUES (@data, @tipo, @tipo_venda, @productid, @produto, @quantidade, @responsavel, @saida, @valor_unitario)";

                // Converte o timestamp para o formato de texto usado no SQLite
                string dataFormatada = reader.GetDateTime(0).ToString("yyyy-MM-dd HH:mm:ss");
                insertCmd.Parameters.AddWithValue("@data", dataFormatada);
                insertCmd.Parameters.AddWithValue("@tipo", reader.GetString(1));
                insertCmd.Parameters.AddWithValue("@tipo_venda", reader.IsDBNull(2) ? "Varejo" : reader.GetString(2));
                insertCmd.Parameters.AddWithValue("@productid", reader.GetInt32(3));
                insertCmd.Parameters.AddWithValue("@produto", reader.GetString(4));
                insertCmd.Parameters.AddWithValue("@quantidade", reader.GetInt32(5));
                insertCmd.Parameters.AddWithValue("@responsavel", reader.GetString(6));
                insertCmd.Parameters.AddWithValue("@saida", reader.IsDBNull(7) ? DBNull.Value : reader.GetString(7));
                insertCmd.Parameters.AddWithValue("@valor_unitario", reader.IsDBNull(8) ? 0 : reader.GetDecimal(8));
                insertCmd.ExecuteNonQuery();
            }

            tx.Commit();
            System.Diagnostics.Debug.WriteLine("Sincronização de movimentações concluída com sucesso");
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Erro ao sincronizar movimentações: {ex.Message}");
            tx.Rollback();
            throw;
        }
    }

