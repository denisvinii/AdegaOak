public class ProdutoSelecionadoItem : ObservableObject
{
    public MainRepository.Produto Produto { get; set; } = null!;
    public string Descricao { get; set; } = "";

    private int quantidade;
    public int Quantidade
    {
        get => quantidade;
        set
        {
            if (SetProperty(ref quantidade, value))
                OnPropertyChanged(nameof(ValorTotal));
        }
    }

    public string TipoMovimentacao { get; set; } = "";
    public string? TipoSaida { get; set; }
    public string? UnidadeSelecionada { get; set; } // "Unidade" ou "Caixa"

    private decimal valorUnitario;
    public decimal ValorUnitario
    {
        get => valorUnitario;
        set
        {
            if (SetProperty(ref valorUnitario, value))
                OnPropertyChanged(nameof(ValorTotal));
        }
    }

    // Propriedades adicionais para referência
    public int QuantidadeCaixas { get; set; } = 0; // Quantidade de caixas selecionadas (para referência)
    public decimal ValorCaixa { get; set; } = 0; // Valor total da caixa (para referência)
    public string? TipoVenda { get; set; } = "Varejo"; // "Varejo" ou "Atacado"

    public int QuantidadeMinimaAtacado { get; set; } = 20; // mínimo em unidades

    // ValorTotal sempre é calculado como: Quantidade × ValorUnitario
    public decimal ValorTotal
    {
        get
        {
            // Quando a unidade selecionada for 'Caixa', usar o valor exato de ValorCaixa multiplicado
            // pela quantidade de caixas selecionadas. Isso garante que não haja perda por
            // arredondamento ao converter para preço por unidade.
            if (string.Equals(UnidadeSelecionada, "Caixa", StringComparison.OrdinalIgnoreCase))
            {
                return QuantidadeCaixas * ValorCaixa;
            }
            return Quantidade * ValorUnitario;
        }
    }
}

