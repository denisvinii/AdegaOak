<UserControl x:Class="Adega_Oak.Views.VendaCopaoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1200">
    <Grid Background="#1A1A1A">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Painel de Venda -->
        <Border Grid.Column="0" Background="#2D2D2D" BorderBrush="#AAAAAA" BorderThickness="0,0,2,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <TextBlock Text="Vender Copaes" FontSize="20" FontWeight="Bold" Foreground="#E65100" Margin="0,0,0,20"/>

                    <TextBlock Text="Selecionar Copao" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding CopoesDisponiveis}"
                             SelectedItem="{Binding CopaoSelecionado, Mode=TwoWay}"
                             DisplayMemberPath="Nome"
                             Background="#353535" Foreground="#FFFFFF" BorderBrush="#AAAAAA"
                             Padding="11" MinHeight="40" Margin="0,0,0,16"/>

                    <!-- Detalhes do Copao Selecionado -->
                    <Border Background="#353535" BorderBrush="#555555" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,16"
                           Visibility="{Binding CopaoSelecionado, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Preco Unitario:" Foreground="#BBBBBB" FontSize="12" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding CopaoSelecionado.PrecoVenda, StringFormat=R$ {0:F2}}" 
                                     FontSize="18" FontWeight="Bold" Foreground="#90EE90" Margin="0,0,0,12"/>
                            
                            <TextBlock Text="Descricao:" Foreground="#BBBBBB" FontSize="11" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding CopaoSelecionado.Descricao}" Foreground="#FFFFFF" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Quantidade" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Border Background="#353535" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="6" Padding="1" Margin="0,0,0,16">
                        <TextBox Background="#353535" Foreground="#FFFFFF" BorderThickness="0"
                                 Text="{Binding QuantidadeCopoes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="11" MinHeight="40"/>
                    </Border>

                    <TextBlock Text="Preco Total:" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Border Background="#353535" BorderBrush="#555555" BorderThickness="1" CornerRadius="6" Padding="11" Margin="0,0,0,16">
                        <TextBlock Text="{Binding PrecoTotal, StringFormat=R$ {0:F2}}" 
                                 Foreground="#90EE90" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Responsavel pela Venda" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding Responsaveis}"
                             SelectedItem="{Binding ResponsavelFiltro, Mode=TwoWay}"
                             Text="{Binding ResponsavelVenda, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Background="#353535" Foreground="#FFFFFF" BorderBrush="#AAAAAA"
                             IsEditable="True"
                             Padding="11" MinHeight="40" Margin="0,0,0,16"/>

                    <TextBlock Text="Observacoes" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Border Background="#353535" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="6" Padding="1" Margin="0,0,0,16">
                        <TextBox Background="#353535" Foreground="#FFFFFF" BorderThickness="0"
                                 Text="{Binding Observacoes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="11" MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                    </Border>

                    <TextBlock Text="{Binding MensagemErro}" Foreground="#FF4444" 
                              Visibility="{Binding TemErro, Converter={StaticResource BoolToVisibilityConverter}}"
                              TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <Button Content="Registrar Venda"
                           Command="{Binding VenderCopaoCommand}"
                           Background="#E65100" Foreground="White" FontWeight="Bold" FontSize="14"
                           Padding="12,12" Margin="0,0,0,10" Cursor="Hand" MinHeight="42"/>

                    <Button Content="Limpar"
                           Background="#353535" Foreground="#E65100" FontWeight="Bold"
                           Padding="12,12" Cursor="Hand" MinHeight="40"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Painel de Historico -->
        <Border Grid.Column="1" Background="#1A1A1A">
            <StackPanel Margin="20">
                <TextBlock Text="Historico de Vendas" FontSize="18" FontWeight="Bold" Foreground="#E65100" Margin="0,0,0,15"/>

                <!-- Filtros -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <ComboBox ItemsSource="{Binding Meses}"
                             SelectedItem="{Binding MesFiltro, Mode=TwoWay}"
                             Width="100" Background="#353535" Foreground="#FFFFFF" 
                             BorderBrush="#AAAAAA" Margin="0,0,10,0"/>
                    <ComboBox ItemsSource="{Binding Anos}"
                             SelectedItem="{Binding AnoFiltro, Mode=TwoWay}"
                             Width="100" Background="#353535" Foreground="#FFFFFF" 
                             BorderBrush="#AAAAAA" Margin="0,0,10,0"/>
                    <Button Content="Filtrar"
                           Command="{Binding CarregarHistoricoVendasCommand}"
                           Background="#E65100" Foreground="White" FontWeight="Bold"
                           Padding="12,8" Cursor="Hand"/>
                </StackPanel>

                <!-- Total do Periodo -->
                <Border Background="#353535" BorderBrush="#555555" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,15">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="SpaceBetween">
                        <TextBlock Text="Total do Periodo:" Foreground="#BBBBBB" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TotalVendidoPeriodo, StringFormat=R$ {0:F2}}" 
                                 Foreground="#90EE90" FontSize="16" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Tabela de Historico -->
                <DataGrid ItemsSource="{Binding HistoricoVendas}"
                         AutoGenerateColumns="False"
                         CanUserAddRows="False"
                         CanUserDeleteRows="False"
                         Background="#2D2D2D" 
                         Foreground="#FFFFFF"
                         BorderBrush="#555555" 
                         BorderThickness="1"
                         HeadersVisibility="Column"
                         RowHeight="40"
                         FontSize="12"
                         AlternatingRowBackground="#3A3A3A"
                         AlternationCount="2"
                         IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Data" Binding="{Binding DataVenda, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="150"/>
                        <DataGridTextColumn Header="Copao" Binding="{Binding NomeCopao}" Width="*"/>
                        <DataGridTextColumn Header="Qtd" Binding="{Binding Quantidade}" Width="60" TextAlignment="Center"/>
                        <DataGridTextColumn Header="Preco Unit." Binding="{Binding PrecoUnitario, StringFormat=R$ {0:F2}}" Width="120" TextAlignment="Right"/>
                        <DataGridTextColumn Header="Total" Binding="{Binding PrecoTotal, StringFormat=R$ {0:F2}}" Width="120" TextAlignment="Right"/>
                        <DataGridTextColumn Header="Responsavel" Binding="{Binding Responsavel}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
