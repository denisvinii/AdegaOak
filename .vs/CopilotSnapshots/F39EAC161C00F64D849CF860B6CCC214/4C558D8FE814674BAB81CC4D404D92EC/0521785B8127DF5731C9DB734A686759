<Window x:Class="Adega_Oak.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Adega_Oak.Views"
        xmlns:conv="clr-namespace:Adega_Oak.Converters"
        mc:Ignorable="d"
        Title="Adega Oak" 
        Height="800" 
        Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <!-- Conversores -->
        <conv:StatusToBrushConverter x:Key="StatusToBrushConverter" />
        <!-- Animações -->
        <Storyboard x:Key="MenuOpen">
            <DoubleAnimation Storyboard.TargetProperty="Width" From="60" To="200" Duration="0:0:0.2"/>
        </Storyboard>
        <Storyboard x:Key="MenuClose">
            <DoubleAnimation Storyboard.TargetProperty="Width" From="200" To="60" Duration="0:0:0.2"/>
        </Storyboard>

        <!-- Estilos -->
        <Style x:Key="MenuButton" TargetType="RadioButton">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CFCFCF"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderThickness="4,0,0,0"
                                BorderBrush="Transparent">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter x:Name="icon" Grid.Column="0" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="text" 
                                         Grid.Column="1" 
                                         Text="{TemplateBinding Tag}"
                                         VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2C2C2C"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#8B4513"/>
                                <Setter Property="BorderBrush" Value="#D2691E"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Menu Lateral -->
        <Border x:Name="sidebar" 
                Width="200"
                Background="#1E1E1E">
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" 
                          VerticalAlignment="Center"
                          Margin="15,20">
                    <TextBlock Text="ADEGA OAK"
                             FontFamily="Montserrat"
                             FontSize="24"
                             FontWeight="Bold"
                             Foreground="#D2691E">
                        <TextBlock.Effect>
                            <DropShadowEffect ShadowDepth="1" 
                                            BlurRadius="3" 
                                            Color="#000000"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="GESTÃO DE ESTOQUE"
                             FontSize="12"
                             Foreground="#808080"
                             Margin="2,0,0,0"/>
                </StackPanel>

                <!-- Botões de Navegação -->
                <StackPanel Grid.Row="1" 
                          Margin="10,20">
                    <RadioButton Style="{StaticResource MenuButton}"
                               Command="{Binding NavigateToCommand}"
                               CommandParameter="Inicio"
                               Tag="Início"
                               IsChecked="True">
                        <Path Data="M3,12H7V21H11V15H13V21H17V12H21L12,3L3,12Z" 
                              Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                              Width="18" Height="18"
                              Stretch="Uniform"/>
                    </RadioButton>

                    <RadioButton Style="{StaticResource MenuButton}"
                               Command="{Binding NavigateToCommand}"
                               CommandParameter="Estoque"
                               Tag="Estoque">
                        <Path Data="M19,3H14V5H19V18L5,18V5H10V3H5C3.89,3 3,3.89 3,5V19C3,20.11 3.89,21 5,21H19C20.11,21 21,20.11 21,19V5C21,3.89 20.11,3 19,3M17,10H7V9H17V10M17,14H7V13H17V14Z" 
                              Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                              Width="18" Height="18"
                              Stretch="Uniform"/>
                    </RadioButton>

                    <RadioButton Style="{StaticResource MenuButton}"
                               Command="{Binding NavigateToCommand}"
                               CommandParameter="Historico"
                               Tag="Histórico">
                        <Path Data="M13.5,8H12V13L16.28,15.54L17,14.33L13.5,12.25V8M13,3C8.03,3 4,7.03 4,12H1L4.96,16.03L9,12H6C6,8.13 9.13,5 13,5S20,8.13 20,12 16.87,19 13,19C11.07,19 9.32,18.21 8.06,16.94L6.64,18.36C8.27,20 10.5,21 13,21C17.97,21 22,16.97 22,12S17.97,3 13,3" 
                              Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                              Width="18" Height="18"
                              Stretch="Uniform"/>
                    </RadioButton>

                    <!-- Tabela de Preços -->
                    <RadioButton Style="{StaticResource MenuButton}"
                               Command="{Binding NavigateToCommand}"
                               CommandParameter="TabelaPrecos"
                               Tag="Tabela de Preços">
                        <Path Data="M7,15H9C9,16.08 10.37,17 12,17C13.63,17 15,16.08 15,15C15,13.9 13.96,13.5 11.76,12.97C9.64,12.44 7,11.78 7,9C7,7.21 8.47,5.69 10.5,5.18V3H13.5V5.18C15.53,5.69 17,7.21 17,9H15C15,7.92 13.63,7 12,7C10.37,7 9,7.92 9,9C9,10.1 10.04,10.5 12.24,11.03C14.36,11.56 17,12.22 17,15C17,16.79 15.53,18.31 13.5,18.82V21H10.5V18.82C8.47,18.31 7,16.79 7,15Z" 
                              Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                              Width="18" Height="18"
                              Stretch="Uniform"/>
                    </RadioButton>
                </StackPanel>

                <!-- Configurações e Status -->
                <StackPanel Grid.Row="2" Margin="10,0,10,10">
                    <!-- Sincronizar -->
                    <Button Height="40"
                            Background="#2D2D2D"
                            BorderThickness="0"
                            Command="{Binding SincronizarCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12,18C8.69,18 6,15.31 6,12C6,11 6.25,10.03 6.7,9.2L5.24,7.74C4.46,8.97 4,10.43 4,12C4,16.42 7.58,20 12,20V23L16,19L12,15M12,4V1L8,5L12,9V6C15.31,6 18,8.69 18,12C18,13 17.75,13.97 17.3,14.8L18.76,16.26C19.54,15.03 20,13.57 20,12C20,7.58 16.42,4 12,4Z" 
                                  Fill="#CFCFCF"
                                  Width="16" Height="16"
                                  Stretch="Uniform"
                                  Margin="0,0,10,0"/>
                            <TextBlock Text="Sincronizar"
                                     Foreground="#CFCFCF"
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Status Online/Offline -->
                    <Border Height="32" 
                            Margin="0,8,0,8" 
                            CornerRadius="6" 
                            Background="#2D2D2D">
                        <StackPanel Orientation="Horizontal" 
                                  VerticalAlignment="Center" 
                                  HorizontalAlignment="Left"
                                  Margin="10,0">
                            <Ellipse Width="12" 
                                     Height="12" 
                                     Margin="0,0,8,0"
                                     Fill="{Binding StatusText, Converter={StaticResource StatusToBrushConverter}}"/>
                            <TextBlock Text="{Binding StatusText}" 
                                     FontWeight="Bold" 
                                     Foreground="#CFCFCF" 
                                     FontSize="14" 
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Trocar Tema -->
                    <Button Height="40"
                            Background="#2D2D2D"
                            BorderThickness="0"
                            Command="{Binding TrocarTemaCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M20,8.69V4H15.31L12,0.69L8.69,4H4V8.69L0.69,12L4,15.31V20H8.69L12,23.31L15.31,20H20V15.31L23.31,12L20,8.69Z" 
                                  Fill="#CFCFCF"
                                  Width="16" Height="16"
                                  Stretch="Uniform"
                                  Margin="0,0,10,0"/>
                            <TextBlock Text="Trocar Tema"
                                     Foreground="#CFCFCF"
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Conteúdo Principal -->
        <Border Grid.Column="1" 
                Background="{DynamicResource BackgroundBrush}"
                Margin="0">
            <ContentControl Content="{Binding CurrentView}"
                          Margin="3">
                <ContentControl.Effect>
                    <DropShadowEffect BlurRadius="20"
                                    ShadowDepth="0"
                                    Opacity="0.3"/>
                </ContentControl.Effect>
            </ContentControl>
        </Border>
    </Grid>
</Window>