using System.Windows;
using System.Windows.Controls;
using Adega_Oak.Features.MainWindow;

namespace Adega_Oak.Views;

public partial class InicioView : UserControl
{
    #region Construtor
    // Inicializa a view de início
    public InicioView()
    {
        InitializeComponent();
    }
    #endregion

    private void QuantidadeMenos_Click(object sender, RoutedEventArgs e)
    {
        if (QuantidadeUpDown.Value > QuantidadeUpDown.Minimum)
            QuantidadeUpDown.Value--;
    }

    private void QuantidadeMais_Click(object sender, RoutedEventArgs e)
    {
        if (QuantidadeUpDown.Value < QuantidadeUpDown.Maximum)
            QuantidadeUpDown.Value++;
    }
}