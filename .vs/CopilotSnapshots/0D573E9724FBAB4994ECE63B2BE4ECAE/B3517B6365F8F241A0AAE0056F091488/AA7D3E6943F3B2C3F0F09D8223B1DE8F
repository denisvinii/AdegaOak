using System.Text.RegularExpressions;
using System.Windows;
using System.Windows.Controls;
using System.Windows.Input;

namespace Adega_Oak.Controls
{
    public partial class QuantidadeControl : UserControl
    {
        public static readonly DependencyProperty QuantidadeProperty = DependencyProperty.Register(
            nameof(Quantidade), typeof(int), typeof(QuantidadeControl), new FrameworkPropertyMetadata(1, FrameworkPropertyMetadataOptions.BindsTwoWayByDefault));

        public int Quantidade
        {
            get => (int)GetValue(QuantidadeProperty);
            set => SetValue(QuantidadeProperty, value < 1 ? 1 : value);
        }

        public QuantidadeControl()
        {
            InitializeComponent();
            DataContext = this;
        }

        private void Increment_Click(object sender, RoutedEventArgs e)
        {
            Quantidade++;
        }

        private void Decrement_Click(object sender, RoutedEventArgs e)
        {
            if (Quantidade > 1)
                Quantidade--;
        }

        private void TextBox_PreviewTextInput(object sender, TextCompositionEventArgs e)
        {
            e.Handled = !Regex.IsMatch(e.Text, "^[0-9]+$");
        }
    }
}
