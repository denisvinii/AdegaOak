using Adega_Oak.Models;
using Adega_Oak.Services;
using System.Collections.ObjectModel;

namespace Adega_Oak.Repositories;

public class DespesaRepository
{
    private readonly DatabaseService _dbService;

    public DespesaRepository(DatabaseService dbService)
    {
        _dbService = dbService;
        CriarTabelaSeDesnecessario();
    }

    private void CriarTabelaSeDesnecessario()
    {
        try
        {
            using var conn = _dbService.GetConnection();
            using var cmd = conn.CreateCommand();
            cmd.CommandText = @"
                CREATE TABLE IF NOT EXISTS despesas (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    descricao TEXT NOT NULL,
                    valor REAL NOT NULL,
                    data DATETIME NOT NULL,
                    tipo INTEGER NOT NULL,
                    pago BOOLEAN DEFAULT 0,
                    data_pagamento DATETIME,
                    notas TEXT,
                    criado_em DATETIME DEFAULT CURRENT_TIMESTAMP
                )";
            cmd.ExecuteNonQuery();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Erro ao criar tabela despesas: {ex.Message}");
        }
    }

    public void AdicionarDespesa(Despesa despesa)
    {
        try
        {
            using var conn = _dbService.GetConnection();
            using var cmd = conn.CreateCommand();
            cmd.CommandText = @"
                INSERT INTO despesas (descricao, valor, data, tipo, pago, data_pagamento, notas, criado_em)
                VALUES (@descricao, @valor, @data, @tipo, @pago, @data_pagamento, @notas, @criado_em)";
            
            cmd.Parameters.AddWithValue("@descricao", despesa.Descricao);
            cmd.Parameters.AddWithValue("@valor", despesa.Valor);
            cmd.Parameters.AddWithValue("@data", despesa.Data);
            cmd.Parameters.AddWithValue("@tipo", (int)despesa.Tipo);
            cmd.Parameters.AddWithValue("@pago", despesa.Pago);
            cmd.Parameters.AddWithValue("@data_pagamento", despesa.DataPagamento ?? (object)DBNull.Value);
            cmd.Parameters.AddWithValue("@notas", despesa.Notas ?? string.Empty);
            cmd.Parameters.AddWithValue("@criado_em", despesa.CriadoEm);
            
            cmd.ExecuteNonQuery();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Erro ao adicionar despesa: {ex.Message}");
            throw;
        }
    }

    public void AtualizarDespesa(Despesa despesa)
    {
        try
        {
            using var conn = _dbService.GetConnection();
            using var cmd = conn.CreateCommand();
            cmd.CommandText = @"
                UPDATE despesas 
                SET descricao = @descricao, valor = @valor, data = @data, tipo = @tipo, 
                    pago = @pago, data_pagamento = @data_pagamento, notas = @notas
                WHERE id = @id";
            
            cmd.Parameters.AddWithValue("@id", despesa.Id);
            cmd.Parameters.AddWithValue("@descricao", despesa.Descricao);
            cmd.Parameters.AddWithValue("@valor", despesa.Valor);
            cmd.Parameters.AddWithValue("@data", despesa.Data);
            cmd.Parameters.AddWithValue("@tipo", (int)despesa.Tipo);
            cmd.Parameters.AddWithValue("@pago", despesa.Pago);
            cmd.Parameters.AddWithValue("@data_pagamento", despesa.DataPagamento ?? (object)DBNull.Value);
            cmd.Parameters.AddWithValue("@notas", despesa.Notas ?? string.Empty);
            
            cmd.ExecuteNonQuery();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Erro ao atualizar despesa: {ex.Message}");
            throw;
        }
    }

    public void DeletarDespesa(int id)
    {
        try
        {
            using var conn = _dbService.GetConnection();
            using var cmd = conn.CreateCommand();
            cmd.CommandText = "DELETE FROM despesas WHERE id = @id";
            cmd.Parameters.AddWithValue("@id", id);
            cmd.ExecuteNonQuery();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Erro ao deletar despesa: {ex.Message}");
            throw;
        }
    }

    public List<Despesa> CarregarTodasDespesas()
    {
        var despesas = new List<Despesa>();
        try
        {
            using var conn = _dbService.GetConnection();
            using var cmd = conn.CreateCommand();
            cmd.CommandText = @"
                SELECT id, descricao, valor, data, tipo, pago, data_pagamento, notas, criado_em
                FROM despesas
                ORDER BY data DESC";
            
            using var reader = cmd.ExecuteReader();
            while (reader.Read())
            {
                despesas.Add(new Despesa
                {
                    Id = reader.GetInt32(0),
                    Descricao = reader.GetString(1),
                    Valor = (decimal)reader.GetDouble(2),
                    Data = reader.GetDateTime(3),
                    Tipo = (TipoDespesa)reader.GetInt32(4),
                    Pago = reader.GetBoolean(5),
                    DataPagamento = reader.IsDBNull(6) ? null : reader.GetDateTime(6),
                    Notas = reader.IsDBNull(7) ? null : reader.GetString(7),
                    CriadoEm = reader.GetDateTime(8)
                });
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Erro ao carregar despesas: {ex.Message}");
        }
        return despesas;
    }

    public List<Despesa> CarregarDespesasPorPeriodo(DateTime dataInicio, DateTime dataFim)
    {
        var despesas = new List<Despesa>();
        try
        {
            using var conn = _dbService.GetConnection();
            using var cmd = conn.CreateCommand();
            cmd.CommandText = @"
                SELECT id, descricao, valor, data, tipo, pago, data_pagamento, notas, criado_em
                FROM despesas
                WHERE data BETWEEN @dataInicio AND @dataFim
                ORDER BY data DESC";
            
            cmd.Parameters.AddWithValue("@dataInicio", dataInicio);
            cmd.Parameters.AddWithValue("@dataFim", dataFim);
            
            using var reader = cmd.ExecuteReader();
            while (reader.Read())
            {
                despesas.Add(new Despesa
                {
                    Id = reader.GetInt32(0),
                    Descricao = reader.GetString(1),
                    Valor = (decimal)reader.GetDouble(2),
                    Data = reader.GetDateTime(3),
                    Tipo = (TipoDespesa)reader.GetInt32(4),
                    Pago = reader.GetBoolean(5),
                    DataPagamento = reader.IsDBNull(6) ? null : reader.GetDateTime(6),
                    Notas = reader.IsDBNull(7) ? null : reader.GetString(7),
                    CriadoEm = reader.GetDateTime(8)
                });
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Erro ao carregar despesas por período: {ex.Message}");
        }
        return despesas;
    }

    public List<Despesa> CarregarDespesasNaoPagas()
    {
        var despesas = new List<Despesa>();
        try
        {
            using var conn = _dbService.GetConnection();
            using var cmd = conn.CreateCommand();
            cmd.CommandText = @"
                SELECT id, descricao, valor, data, tipo, pago, data_pagamento, notas, criado_em
                FROM despesas
                WHERE pago = 0
                ORDER BY data ASC";
            
            using var reader = cmd.ExecuteReader();
            while (reader.Read())
            {
                despesas.Add(new Despesa
                {
                    Id = reader.GetInt32(0),
                    Descricao = reader.GetString(1),
                    Valor = (decimal)reader.GetDouble(2),
                    Data = reader.GetDateTime(3),
                    Tipo = (TipoDespesa)reader.GetInt32(4),
                    Pago = reader.GetBoolean(5),
                    DataPagamento = reader.IsDBNull(6) ? null : reader.GetDateTime(6),
                    Notas = reader.IsDBNull(7) ? null : reader.GetString(7),
                    CriadoEm = reader.GetDateTime(8)
                });
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Erro ao carregar despesas não pagas: {ex.Message}");
        }
        return despesas;
    }

    public decimal ObterTotalDespesasNaoPagas()
    {
        try
        {
            using var conn = _dbService.GetConnection();
            using var cmd = conn.CreateCommand();
            cmd.CommandText = "SELECT COALESCE(SUM(valor), 0) FROM despesas WHERE pago = 0";
            
            var result = cmd.ExecuteScalar();
            return result != null ? Convert.ToDecimal(result) : 0m;
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Erro ao obter total de despesas não pagas: {ex.Message}");
            return 0m;
        }
    }

    public decimal ObterTotalDespesasDoMes(int mes, int ano)
    {
        try
        {
            using var conn = _dbService.GetConnection();
            using var cmd = conn.CreateCommand();
            cmd.CommandText = @"
                SELECT COALESCE(SUM(valor), 0) FROM despesas 
                WHERE strftime('%m', data) = @mes AND strftime('%Y', data) = @ano";
            
            cmd.Parameters.AddWithValue("@mes", mes.ToString("D2"));
            cmd.Parameters.AddWithValue("@ano", ano.ToString());
            
            var result = cmd.ExecuteScalar();
            return result != null ? Convert.ToDecimal(result) : 0m;
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Erro ao obter total do mês: {ex.Message}");
            return 0m;
        }
    }

    public decimal ObterTotalDespesasPagas()
    {
        try
        {
            using var conn = _dbService.GetConnection();
            using var cmd = conn.CreateCommand();
            cmd.CommandText = "SELECT COALESCE(SUM(valor), 0) FROM despesas WHERE pago = 1";
            
            var result = cmd.ExecuteScalar();
            return result != null ? Convert.ToDecimal(result) : 0m;
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Erro ao obter total de despesas pagas: {ex.Message}");
            return 0m;
        }
    }
}
