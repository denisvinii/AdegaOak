namespace Adega_Oak.Models;

public class Despesa
{
    public int Id { get; set; }
    public string Descricao { get; set; } = string.Empty;
    public decimal Valor { get; set; }
    public DateTime Data { get; set; }
    public TipoDespesa Tipo { get; set; }
    public bool Pago { get; set; }
    public DateTime? DataPagamento { get; set; }
    public string? Notas { get; set; }
    public DateTime CriadoEm { get; set; } = DateTime.Now;
}

public enum TipoDespesa
{
    Aluguel = 0,
    Salario = 1,
    Luz = 2,
    Agua = 3,
    Internet = 4,
    Manutencao = 5,
    Limpeza = 6,
    Publicidade = 7,
    Transporte = 8,
    Outros = 9
}

public static class TipoDespesaHelper
{
    public static string GetDisplayName(TipoDespesa tipo)
    {
        return tipo switch
        {
            TipoDespesa.Aluguel => "Aluguel",
            TipoDespesa.Salario => "Salário",
            TipoDespesa.Luz => "Energia Elétrica",
            TipoDespesa.Agua => "Água",
            TipoDespesa.Internet => "Internet",
            TipoDespesa.Manutencao => "Manutenção",
            TipoDespesa.Limpeza => "Limpeza",
            TipoDespesa.Publicidade => "Publicidade",
            TipoDespesa.Transporte => "Transporte",
            TipoDespesa.Outros => "Outros",
            _ => "Desconhecido"
        };
    }

    public static string GetColor(TipoDespesa tipo)
    {
        return tipo switch
        {
            TipoDespesa.Aluguel => "#E74C3C",       // Vermelho
            TipoDespesa.Salario => "#C0392B",       // Vermelho Escuro
            TipoDespesa.Luz => "#F39C12",           // Laranja
            TipoDespesa.Agua => "#3498DB",          // Azul
            TipoDespesa.Internet => "#2980B9",      // Azul Escuro
            TipoDespesa.Manutencao => "#9B59B6",    // Roxo
            TipoDespesa.Limpeza => "#1ABC9C",       // Teal
            TipoDespesa.Publicidade => "#E67E22",   // Laranja Escuro
            TipoDespesa.Transporte => "#34495E",    // Cinza Escuro
            TipoDespesa.Outros => "#95A5A6",        // Cinza
            _ => "#7F8C8D"                          // Cinza Padrão
        };
    }

    public static string GetIcon(TipoDespesa tipo)
    {
        return tipo switch
        {
            TipoDespesa.Aluguel => "🏠",
            TipoDespesa.Salario => "💼",
            TipoDespesa.Luz => "💡",
            TipoDespesa.Agua => "💧",
            TipoDespesa.Internet => "📡",
            TipoDespesa.Manutencao => "🔧",
            TipoDespesa.Limpeza => "🧹",
            TipoDespesa.Publicidade => "📢",
            TipoDespesa.Transporte => "🚛",
            TipoDespesa.Outros => "📋",
            _ => "❓"
        };
    }
}
