            qtd = 0;
        qtd++;
        Quantidade = qtd.ToString();
    }

    [RelayCommand]
    private void DecrementarQuantidade()
    {
        if (!int.TryParse(Quantidade, out int qtd))
            qtd = 0;
        if (qtd > 1)
            qtd--;
        else
            qtd = 1;
        Quantidade = qtd.ToString();
    }
