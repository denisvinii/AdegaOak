using Adega_Oak.Features.MainWindow;
using System.Windows;
using System.Windows.Controls;
using System.Windows.Input;

namespace Adega_Oak.Views;

public partial class InicioView : UserControl
{
    #region Construtor
    // Inicializa a view de início
    public InicioView()
    {
        InitializeComponent();
    }
    #endregion

    private void QuantidadeMenos_Click(object sender, MouseButtonEventArgs e)
    {
        if (DataContext is MainWindowViewModel vm)
        {
            if (!int.TryParse(vm.Quantidade, out int qtd))
                qtd = 0;
            if (qtd > 1)
                qtd--;
//            else
//                qtd = 1;
            vm.Quantidade = qtd.ToString();
        }
    }

    private void QuantidadeMais_Click(object sender, MouseButtonEventArgs e)
    {
        if (DataContext is MainWindowViewModel vm)
        {
            if (!int.TryParse(vm.Quantidade, out int qtd))
                qtd = 0;
            qtd++;
            vm.Quantidade = qtd.ToString();
        }
    }

    private void QuantidadeTextBox_TextChanged(object sender, TextChangedEventArgs e)
    {

    }

    private void TextBox_TextChanged(object sender, TextChangedEventArgs e)
    {

    }

    private void ProdutoComboBox_SelectionChanged(object sender, SelectionChangedEventArgs e)
    {
        if (sender is ComboBox comboBox && 
            comboBox.SelectedItem is Features.MainWindow.MainRepository.Produto produto &&
            DataContext is MainWindowViewModel vm)
        {
            // Atualiza o texto do ComboBox com a descrição completa do produto selecionado
            vm.ProdutoFiltroTexto = produto.Descricao;
        }
    }
}