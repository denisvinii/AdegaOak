using System.Text;
using System.Windows;
using System.Windows.Controls;

namespace Adega_Oak.Views;

public partial class DrinksView : UserControl
{
    public DrinksView()
    {
        InitializeComponent();
    }

    private void OnSalvarComboClick(object sender, RoutedEventArgs e)
    {
        var vm = DataContext as Adega_Oak.Features.Drinks.DrinksViewModel;
        if (vm == null) return;

        var result = MessageBox.Show("Confirm save this combo?", "Confirm", MessageBoxButton.YesNo, MessageBoxImage.Question);
        if (result == MessageBoxResult.Yes)
        {
            vm.SalvarComboCommand.Execute(null);
            MessageBox.Show("Combo saved successfully.", "Info", MessageBoxButton.OK, MessageBoxImage.Information);
        }
    }

    private void OnFinalizeSaleClick(object sender, RoutedEventArgs e)
    {
        var vm = DataContext as Adega_Oak.Features.Drinks.DrinksViewModel;
        if (vm == null) return;

        if (!vm.SaleCart.Any())
        {
            MessageBox.Show("Cart is empty.", "Warning", MessageBoxButton.OK, MessageBoxImage.Warning);
            return;
        }

        var sb = new StringBuilder();
        sb.AppendLine("You are about to finalize the sale with the following items:");
        foreach (var line in vm.SaleCart)
        {
            sb.AppendLine($"- {line.Nome} x {line.Quantidade} => {line.Preco:C}");
        }
        sb.AppendLine($"Total: {vm.SaleCart.Select(l => l.Preco * l.Quantidade).Sum():C}");

        var res = MessageBox.Show(sb.ToString(), "Confirm Sale", MessageBoxButton.YesNo, MessageBoxImage.Question);
        if (res == MessageBoxResult.Yes)
        {
            vm.FinalizeSaleCommand.Execute(null);
        }
    }
}