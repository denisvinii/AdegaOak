using Adega_Oak.Services;
using System.Data;
using System.Collections.Generic;
using System;

namespace Adega_Oak.Repositories;

public class DrinksRepository
{
    private readonly DatabaseService _dbService;
    private readonly MainRepository _mainRepository;

    public DrinksRepository(DatabaseService dbService, MainRepository mainRepository)
    {
        _dbService = dbService;
        _mainRepository = mainRepository;
    }

    public class ComboItem
    {
        public int ComboId { get; set; }
        public int ProductId { get; set; }
        public int Quantidade { get; set; }
    }

    public class Combo
    {
        public int ComboId { get; set; }
        public string Nome { get; set; } = string.Empty;
        public string? Descricao { get; set; }
        public decimal Valor { get; set; }
        public List<ComboItem> Items { get; set; } = new();
    }

    public List<Combo> GetCombos()
    {
        var combos = new List<Combo>();
        using var conn = _dbService.GetConnection();
        using var cmd = conn.CreateCommand();
        cmd.CommandText = "SELECT comboid, nome, descricao, valor FROM combos ORDER BY comboid";
        using var reader = cmd.ExecuteReader();
        while (reader.Read())
        {
            combos.Add(new Combo
            {
                ComboId = reader.GetInt32(0),
                Nome = reader.GetString(1),
                Descricao = reader.IsDBNull(2) ? null : reader.GetString(2),
                Valor = reader.IsDBNull(3) ? 0m : reader.GetDecimal(3)
            });
        }

        // load items
        foreach (var c in combos)
        {
            c.Items = GetComboItems(c.ComboId);
        }

        return combos;
    }

    public List<ComboItem> GetComboItems(int comboId)
    {
        var items = new List<ComboItem>();
        using var conn = _dbService.GetConnection();
        using var cmd = conn.CreateCommand();
        cmd.CommandText = "SELECT comboid, productid, quantidade FROM combo_items WHERE comboid = @comboid";
        var p = cmd.CreateParameter(); p.ParameterName = "@comboid"; p.Value = comboId; cmd.Parameters.Add(p);
        using var reader = cmd.ExecuteReader();
        while (reader.Read())
        {
            items.Add(new ComboItem
            {
                ComboId = reader.GetInt32(0),
                ProductId = reader.GetInt32(1),
                Quantidade = reader.GetInt32(2)
            });
        }
        return items;
    }

    public int CreateCombo(Combo combo)
    {
        using var conn = _dbService.GetConnection();
        using var tx = conn.BeginTransaction();
        using var cmd = conn.CreateCommand();
        cmd.Transaction = tx;

        // determine next id
        cmd.CommandText = "SELECT COALESCE(MAX(comboid), 0) + 1 FROM combos";
        var nextId = Convert.ToInt32(cmd.ExecuteScalar());

        cmd.CommandText = "INSERT INTO combos (comboid, nome, descricao, valor) VALUES (@id, @nome, @descricao, @valor)";
        cmd.Parameters.AddWithValue("@id", nextId);
        cmd.Parameters.AddWithValue("@nome", combo.Nome);
        cmd.Parameters.AddWithValue("@descricao", combo.Descricao ?? string.Empty);
        cmd.Parameters.AddWithValue("@valor", combo.Valor);
        cmd.ExecuteNonQuery();

        // insert items
        foreach (var item in combo.Items)
        {
            using var icmd = conn.CreateCommand();
            icmd.Transaction = tx;
            icmd.CommandText = "INSERT INTO combo_items (comboid, productid, quantidade) VALUES (@comboid, @productid, @quantidade)";
            icmd.Parameters.AddWithValue("@comboid", nextId);
            icmd.Parameters.AddWithValue("@productid", item.ProductId);
            icmd.Parameters.AddWithValue("@quantidade", item.Quantidade);
            icmd.ExecuteNonQuery();
        }

        tx.Commit();
        return nextId;
    }

    public void UpdateCombo(Combo combo)
    {
        using var conn = _dbService.GetConnection();
        using var tx = conn.BeginTransaction();
        using var cmd = conn.CreateCommand();
        cmd.Transaction = tx;

        cmd.CommandText = "UPDATE combos SET nome = @nome, descricao = @descricao, valor = @valor WHERE comboid = @id";
        cmd.Parameters.AddWithValue("@nome", combo.Nome);
        cmd.Parameters.AddWithValue("@descricao", combo.Descricao ?? string.Empty);
        cmd.Parameters.AddWithValue("@valor", combo.Valor);
        cmd.Parameters.AddWithValue("@id", combo.ComboId);
        cmd.ExecuteNonQuery();

        // replace items: delete existing, insert new
        using (var del = conn.CreateCommand())
        {
            del.Transaction = tx;
            del.CommandText = "DELETE FROM combo_items WHERE comboid = @comboid";
            del.Parameters.AddWithValue("@comboid", combo.ComboId);
            del.ExecuteNonQuery();
        }

        foreach (var item in combo.Items)
        {
            using var icmd = conn.CreateCommand();
            icmd.Transaction = tx;
            icmd.CommandText = "INSERT INTO combo_items (comboid, productid, quantidade) VALUES (@comboid, @productid, @quantidade)";
            icmd.Parameters.AddWithValue("@comboid", combo.ComboId);
            icmd.Parameters.AddWithValue("@productid", item.ProductId);
            icmd.Parameters.AddWithValue("@quantidade", item.Quantidade);
            icmd.ExecuteNonQuery();
        }

        tx.Commit();
    }

    public void DeleteCombo(int comboId)
    {
        using var conn = _dbService.GetConnection();
        using var tx = conn.BeginTransaction();
        using var cmd = conn.CreateCommand();
        cmd.Transaction = tx;

        cmd.CommandText = "DELETE FROM combo_items WHERE comboid = @comboid";
        cmd.Parameters.AddWithValue("@comboid", comboId);
        cmd.ExecuteNonQuery();

        cmd.CommandText = "DELETE FROM combos WHERE comboid = @id";
        cmd.Parameters.AddWithValue("@id", comboId);
        cmd.ExecuteNonQuery();

        tx.Commit();
    }

    public void RegisterComboOperation(int comboId, int quantidade, string responsavel, bool isConsumo)
    {
        // Load combo items
        var items = GetComboItems(comboId);
        if (items == null || items.Count == 0) return;

        foreach (var item in items)
        {
            // For each item, create a movimentacao for the used units
            int unidades = item.Quantidade * quantidade;

            // Determine unit price from estoque (valor_venda or valor)
            decimal unitPrice = 0m;
            using var conn = _dbService.GetConnection();
            using var cmd = conn.CreateCommand();
            cmd.CommandText = "SELECT COALESCE(valor_venda, valor) FROM estoque WHERE productid = @productid";
            cmd.Parameters.AddWithValue("@productid", item.ProductId);
            var res = cmd.ExecuteScalar();
            unitPrice = res == null || res == DBNull.Value ? 0m : Convert.ToDecimal(res);

            var mov = new MainRepository.Movimentacao
            {
                Data = DateTime.Now,
                Tipo = "Saída",
                TipoVenda = "Varejo",
                ProductId = item.ProductId,
                ProdutoDescricao = GetProductDescricao(item.ProductId),
                Quantidade = unidades,
                Responsavel = responsavel,
                TipoSaida = isConsumo ? "Consumo" : "Venda Combo",
                ValorUnitario = isConsumo ? 0m : unitPrice
            };

            // Use MainRepository to register movement
            _mainRepository.RegistrarMovimentacao(mov);
        }

        // Insert into drinks_history table for auditing
        using (var conn2 = _dbService.GetConnection())
        using (var cmd2 = conn2.CreateCommand())
        {
            cmd2.CommandText = "INSERT INTO drinks_history (comboid, data, tipo, responsavel, quantidade, valor_total) VALUES (@comboid, @data, @tipo, @responsavel, @quantidade, @valor_total)";
            cmd2.Parameters.AddWithValue("@comboid", comboId);
            if (conn2 is Microsoft.Data.Sqlite.SqliteConnection)
                cmd2.Parameters.AddWithValue("@data", DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss"));
            else
                cmd2.Parameters.AddWithValue("@data", DateTime.Now);
            cmd2.Parameters.AddWithValue("@tipo", isConsumo ? "Consumo" : "Saída");
            cmd2.Parameters.AddWithValue("@responsavel", responsavel);
            cmd2.Parameters.AddWithValue("@quantidade", quantidade);
            // valor_total: if consumo -> 0 else get combo.valor
            decimal valorTotal = 0m;
            using var cmdGet = conn2.CreateCommand();
            cmdGet.CommandText = "SELECT valor FROM combos WHERE comboid = @id";
            cmdGet.Parameters.AddWithValue("@id", comboId);
            var v = cmdGet.ExecuteScalar();
            valorTotal = v == null || v == DBNull.Value ? 0m : Convert.ToDecimal(v);
            cmd2.Parameters.AddWithValue("@valor_total", isConsumo ? 0m : valorTotal * quantidade);
            cmd2.ExecuteNonQuery();
        }
    }

    private string GetProductDescricao(int productId)
    {
        using var conn = _dbService.GetConnection();
        using var cmd = conn.CreateCommand();
        cmd.CommandText = "SELECT bebida, tamanho, material FROM estoque WHERE productid = @id";
        cmd.Parameters.AddWithValue("@id", productId);
        using var reader = cmd.ExecuteReader();
        if (reader.Read())
        {
            var b = reader.IsDBNull(0) ? "" : reader.GetString(0);
            var t = reader.IsDBNull(1) ? "" : reader.GetString(1);
            var m = reader.IsDBNull(2) ? "" : reader.GetString(2);
            return $"{b} - {t} - {m}";
        }
        return "Produto Desconhecido";
    }
}
