        public int Quantidade { get; set; }
        private int _consumedPerCombo;
        public int ConsumedPerCombo { get => _consumedPerCombo; set => SetProperty(ref _consumedPerCombo, value); }
    }

    public class EditableComboItem : ObservableObject
    {
        private int _productId;
        public int ProductId { get => _productId; set => SetProperty(ref _productId, value); }

        private int _quantidade;
        public int Quantidade { get => _quantidade; set => SetProperty(ref _quantidade, value); }

        private string _produtoDescricao = string.Empty;
        public string ProdutoDescricao { get => _produtoDescricao; set => SetProperty(ref _produtoDescricao, value); }
    }
}
