using CommunityToolkit.Mvvm.ComponentModel;
using CommunityToolkit.Mvvm.Input;
using System.Collections.ObjectModel;
using System.Linq;
using System.Windows;

namespace Adega_Oak.Features.Drinks;

public partial class DrinksViewModel : ObservableObject
{
    private readonly DrinksRepository _drinksRepository;
    private readonly MainRepository _mainRepository;

    private ObservableCollection<DrinksRepository.Combo> _combos = new();
    public ObservableCollection<DrinksRepository.Combo> Combos { get => _combos; set => SetProperty(ref _combos, value); }

    private DrinksRepository.Combo? _selectedCombo;
    public DrinksRepository.Combo? SelectedCombo
    {
        get => _selectedCombo;
        set
        {
            if (SetProperty(ref _selectedCombo, value))
            {
                OnSelectedComboChanged(value);
            }
        }
    }

    private string _editNome = string.Empty;
    public string EditNome { get => _editNome; set => SetProperty(ref _editNome, value); }

    private string _editDescricao = string.Empty;
    public string EditDescricao { get => _editDescricao; set => SetProperty(ref _editDescricao, value); }

    private decimal _editValor = 0m;
    public decimal EditValor { get => _editValor; set => SetProperty(ref _editValor, value); }

    // Editable items for UI (Product selection + quantity)
    private ObservableCollection<EditableComboItem> _editItems = new();
    public ObservableCollection<EditableComboItem> EditItems { get => _editItems; set => SetProperty(ref _editItems, value); }

    // Products available to choose when editing/creating combos
    private ObservableCollection<MainRepository.Produto> _availableProducts = new();
    public ObservableCollection<MainRepository.Produto> AvailableProducts { get => _availableProducts; set => SetProperty(ref _availableProducts, value); }

    private MainRepository.Produto? _selectedProductForNewItem;
    public MainRepository.Produto? SelectedProductForNewItem { get => _selectedProductForNewItem; set => SetProperty(ref _selectedProductForNewItem, value); }

    private int _newItemQuantidade = 1;
    public int NewItemQuantidade { get => _newItemQuantidade; set => SetProperty(ref _newItemQuantidade, value); }

    private ObservableCollection<SelectableComboItem> _consumableItems = new();
    public ObservableCollection<SelectableComboItem> ConsumableItems { get => _consumableItems; set => SetProperty(ref _consumableItems, value); }

    private int _operationQuantity = 1;
    public int OperationQuantity { get => _operationQuantity; set => SetProperty(ref _operationQuantity, value); }

    // Responsaveis for selecting who performed the operation
    private ObservableCollection<string> _responsaveis = new();
    public ObservableCollection<string> Responsaveis { get => _responsaveis; set => SetProperty(ref _responsaveis, value); }

    private string? _selectedResponsavel;
    public string? SelectedResponsavel { get => _selectedResponsavel; set => SetProperty(ref _selectedResponsavel, value); }

    private string? _productSearchText;
    public string? ProductSearchText
    {
        get => _productSearchText;
        set
        {
            if (SetProperty(ref _productSearchText, value))
            {
                UpdateFilteredProducts();
            }
        }
    }

    private ObservableCollection<MainRepository.Produto> _filteredProducts = new();
    public ObservableCollection<MainRepository.Produto> FilteredProducts { get => _filteredProducts; set => SetProperty(ref _filteredProducts, value); }

    private ObservableCollection<EditableComboItem> _selectedComboPreviewItems = new();
    public ObservableCollection<EditableComboItem> SelectedComboPreviewItems { get => _selectedComboPreviewItems; set => SetProperty(ref _selectedComboPreviewItems, value); }

    // Sale cart
    private ObservableCollection<SaleLine> _saleCart = new();
    public ObservableCollection<SaleLine> SaleCart { get => _saleCart; set => SetProperty(ref _saleCart, value); }

    private decimal _salePriceOverride = 0m;
    public decimal SalePriceOverride { get => _salePriceOverride; set => SetProperty(ref _salePriceOverride, value); }

    public class SaleLine : ObservableObject
    {
        private int _comboId;
        public int ComboId { get => _comboId; set => SetProperty(ref _comboId, value); }

        private string _nome = string.Empty;
        public string Nome { get => _nome; set => SetProperty(ref _nome, value); }

        private int _quantidade;
        public int Quantidade { get => _quantidade; set => SetProperty(ref _quantidade, value); }

        private decimal _preco;
        public decimal Preco { get => _preco; set => SetProperty(ref _preco, value); }

        public decimal Total => Preco * Quantidade;
    }

    public DrinksViewModel(DrinksRepository drinksRepository, MainRepository mainRepository)
    {
        _drinksRepository = drinksRepository;
        _mainRepository = mainRepository;
        LoadProducts();
        LoadResponsaveis();
        CarregarCombos();
    }

    private void LoadProducts()
    {
        var produtos = _mainRepository.CarregarProdutos();
        AvailableProducts = new ObservableCollection<MainRepository.Produto>(produtos);
        SelectedProductForNewItem = AvailableProducts.FirstOrDefault();
        UpdateFilteredProducts();
    }

    private void LoadResponsaveis()
    {
        var responsaveis = _mainRepository.CarregarResponsaveis();
        Responsaveis = new ObservableCollection<string>(responsaveis);
        SelectedResponsavel = Responsaveis.FirstOrDefault();
    }

    private void UpdateFilteredProducts()
    {
        if (string.IsNullOrWhiteSpace(ProductSearchText))
        {
            FilteredProducts = new ObservableCollection<MainRepository.Produto>(AvailableProducts);
            return;
        }
        var q = ProductSearchText.Trim().ToLowerInvariant();
        var filtered = AvailableProducts.Where(p => p.Descricao.ToLowerInvariant().Contains(q)).ToList();
        FilteredProducts = new ObservableCollection<MainRepository.Produto>(filtered);
    }

    private void OnSelectedComboChanged(DrinksRepository.Combo? value)
    {
        if (value == null)
        {
            EditNome = string.Empty;
            EditDescricao = string.Empty;
            EditValor = 0m;
            EditItems = new ObservableCollection<EditableComboItem>();
            ConsumableItems = new ObservableCollection<SelectableComboItem>();
            SelectedComboPreviewItems = new ObservableCollection<EditableComboItem>();
            SalePriceOverride = 0m;
            return;
        }

        EditNome = value.Nome;
        EditDescricao = value.Descricao ?? string.Empty;
        EditValor = value.Valor;

        // populate editable items from repository items
        var wrappers = new ObservableCollection<EditableComboItem>();
        var produtos = _mainRepository.CarregarProdutos();
        foreach (var it in value.Items)
        {
            var prod = produtos.FirstOrDefault(p => p.ProductId == it.ProductId);
            var desc = prod != null ? prod.Descricao : "Produto Desconhecido";
            wrappers.Add(new EditableComboItem
            {
                ProductId = it.ProductId,
                ProdutoDescricao = desc,
                Quantidade = it.Quantidade
            });
        }
        EditItems = wrappers;

        // build preview items for sales tab
        var preview = new ObservableCollection<EditableComboItem>();
        foreach (var it in value.Items)
        {
            var prod = produtos.FirstOrDefault(p => p.ProductId == it.ProductId);
            var desc = prod != null ? prod.Descricao : "Produto Desconhecido";
            preview.Add(new EditableComboItem
            {
                ProductId = it.ProductId,
                ProdutoDescricao = desc,
                Quantidade = it.Quantidade
            });
        }
        SelectedComboPreviewItems = preview;
        // default sale price override to combo value (editable by user)
        SalePriceOverride = value.Valor;

        // populate consumable selectable items with product descriptions using main repository
        var selectable = new ObservableCollection<SelectableComboItem>();
        foreach (var it in value.Items)
        {
            var prod = produtos.FirstOrDefault(p => p.ProductId == it.ProductId);
            string desc;
            if (prod != null)
                desc = prod.Descricao;
            else
                desc = "Produto Desconhecido";

            selectable.Add(new SelectableComboItem
            {
                ProductId = it.ProductId,
                ProdutoDescricao = desc,
                Quantidade = it.Quantidade,
                IsFullyConsumed = false,
                ConsumedPerCombo = it.Quantidade
            });
        }
        ConsumableItems = selectable;
    }

    [RelayCommand]
    public void CarregarCombos()
    {
        Combos = new ObservableCollection<DrinksRepository.Combo>(_drinksRepository.GetCombos());
    }

    [RelayCommand]
    public void NovoCombo()
    {
        SelectedCombo = new DrinksRepository.Combo { ComboId = 0, Nome = "Novo Combo" };
        EditNome = SelectedCombo.Nome;
        EditDescricao = string.Empty;
        EditValor = 0m;
        EditItems = new ObservableCollection<EditableComboItem>();
    }

    [RelayCommand]
    public void EditarCombo()
    {
        if (SelectedCombo == null) return;
        // already in edit mode
    }

    [RelayCommand]
    public void ExcluirCombo()
    {
        if (SelectedCombo == null || SelectedCombo.ComboId == 0) return;
        if (MessageBox.Show($"Deseja excluir o combo '{SelectedCombo.Nome}'?", "Confirmar", MessageBoxButton.YesNo) == MessageBoxResult.Yes)
        {
            _drinksRepository.DeleteCombo(SelectedCombo.ComboId);
            CarregarCombos();
        }
    }

    [RelayCommand]
    public void SalvarCombo()
    {
        var combo = new DrinksRepository.Combo
        {
            ComboId = SelectedCombo?.ComboId ?? 0,
            Nome = EditNome,
            Descricao = EditDescricao,
            Valor = EditValor,
            Items = EditItems.Select(i => new DrinksRepository.ComboItem { ComboId = SelectedCombo?.ComboId ?? 0, ProductId = i.ProductId, Quantidade = i.Quantidade }).ToList()
        };

        if (combo.ComboId == 0)
        {
            var id = _drinksRepository.CreateCombo(combo);
            SelectedCombo = _drinksRepository.GetCombos().FirstOrDefault(c => c.ComboId == id);
        }
        else
        {
            _drinksRepository.UpdateCombo(combo);
        }

        CarregarCombos();
    }

    [RelayCommand]
    public void AdicionarItem()
    {
        if (SelectedProductForNewItem == null)
        {
            MessageBox.Show("Selecione um produto para adicionar ao combo.", "Aviso", MessageBoxButton.OK, MessageBoxImage.Warning);
            return;
        }
        if (NewItemQuantidade <= 0) NewItemQuantidade = 1;

        EditItems.Add(new EditableComboItem
        {
            ProductId = SelectedProductForNewItem.ProductId,
            ProdutoDescricao = SelectedProductForNewItem.Descricao,
            Quantidade = NewItemQuantidade
        });

        // reset new item quantity
        NewItemQuantidade = 1;
    }

    [RelayCommand]
    public void RemoverItem(EditableComboItem? item)
    {
        if (item == null)
        {
            if (EditItems.Any()) EditItems.RemoveAt(EditItems.Count - 1);
        }
        else
        {
            EditItems.Remove(item);
        }
    }

    [RelayCommand]
    public void RegistrarSaida()
    {
        if (SelectedCombo == null) return;
        var resp = SelectedResponsavel ?? "admin"; // use selected responsavel
        _drinksRepository.RegisterComboOperation(SelectedCombo.ComboId, 1, resp, false);
        MessageBox.Show("Saida registrada");
    }

    [RelayCommand]
    public void RegistrarConsumo()
    {
        if (SelectedCombo == null) return;
        var resp = SelectedResponsavel ?? "admin";
        _drinksRepository.RegisterComboOperation(SelectedCombo.ComboId, 1, resp, true);
        MessageBox.Show("Consumo registrado (valor 0)");
    }

    [RelayCommand]
    public void RegistrarConsumoParcial()
    {
        if (SelectedCombo == null) return;
        var itemsToConsume = new List<(int productId, int unidades)>();
        foreach (var it in ConsumableItems)
        {
            if (!it.IsFullyConsumed) continue; // only full consumption
            var unidades = it.Quantidade * (OperationQuantity > 0 ? OperationQuantity : 1);
            itemsToConsume.Add((it.ProductId, unidades));
        }
        if (!itemsToConsume.Any())
        {
            MessageBox.Show("Selecione ao menos um produto consumido completamente.", "Aviso", MessageBoxButton.OK, MessageBoxImage.Warning);
            return;
        }
        var resp = SelectedResponsavel ?? "admin";
        _drinksRepository.RegisterConsumptionPerItemQuantities(SelectedCombo.ComboId, itemsToConsume, resp);
        MessageBox.Show("Consumo parcial registrado (itens baixados)");
    }

    [RelayCommand]
    public void AddToCart()
    {
        if (SelectedCombo == null) return;
        if (OperationQuantity <= 0) OperationQuantity = 1;
        if (SalePriceOverride <= 0m)
        {
            MessageBox.Show("Set a price greater than 0 before adding to cart.", "Warning", MessageBoxButton.OK, MessageBoxImage.Warning);
            return;
        }

        var line = new SaleLine
        {
            ComboId = SelectedCombo.ComboId,
            Nome = SelectedCombo.Nome,
            Quantidade = OperationQuantity,
            Preco = SalePriceOverride
        };
        SaleCart.Add(line);
        MessageBox.Show("Combo added to cart.", "Info", MessageBoxButton.OK, MessageBoxImage.Information);
    }

    [RelayCommand]
    public void RemoveCartItem(SaleLine? line)
    {
        if (line == null) return;
        if (SaleCart.Contains(line)) SaleCart.Remove(line);
    }

    [RelayCommand]
    public void FinalizeSale()
    {
        if (!SaleCart.Any())
        {
            MessageBox.Show("Cart is empty.", "Warning", MessageBoxButton.OK, MessageBoxImage.Warning);
            return;
        }
        var resp = SelectedResponsavel ?? "admin";
        if (MessageBox.Show("Confirm finalize sale?", "Confirm", MessageBoxButton.YesNo, MessageBoxImage.Question) != MessageBoxResult.Yes) return;

        foreach (var line in SaleCart.ToList())
        {
            // register movements (use existing RegisterComboOperation for movements)
            _drinksRepository.RegisterComboOperation(line.ComboId, line.Quantidade, resp, false);
            // record history with overridden price
            _drinksRepository.RegisterSaleWithOverride(line.ComboId, line.Quantidade, resp, line.Preco);
        }
        SaleCart.Clear();
        MessageBox.Show("Sale finalized.", "Info", MessageBoxButton.OK, MessageBoxImage.Information);
    }

