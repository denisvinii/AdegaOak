<UserControl x:Class="Adega_Oak.Views.DrinksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Adega_Oak.Features.Drinks"
             xmlns:local="clr-namespace:Adega_Oak.Views"
             Height="Auto" Width="Auto">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: list of combos -->
        <Border Grid.Column="0" Background="#2D2D2D" CornerRadius="6" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Combos" Foreground="#CFCFCF" FontSize="18" FontWeight="Bold"/>
                <ListView Grid.Row="1" ItemsSource="{Binding Combos}" SelectedItem="{Binding SelectedCombo}" Margin="0,8,0,8">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="{Binding Nome}" Foreground="#FFFFFF" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Descricao}" Foreground="#CFCFCF" FontSize="12"/>
                                <TextBlock Text="{Binding Valor, StringFormat=C}" Foreground="#FFD700" FontSize="14" FontWeight="Bold"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                    <Button Content="Novo" Command="{Binding NovoComboCommand}" Width="90"/>
                    <Button Content="Editar" Command="{Binding EditarComboCommand}" Width="90"/>
                    <Button Content="Excluir" Command="{Binding ExcluirComboCommand}" Width="90"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right: detalhes e ações -->
        <Border Grid.Column="1" Background="#1E1E1E" CornerRadius="6" Padding="10" Margin="10,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Detalhes do Combo" Foreground="#CFCFCF" FontSize="18" FontWeight="Bold"/>

                <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,8,0,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox Width="300" Text="{Binding EditNome, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Nome do combo" />
                        <TextBox Width="200" Text="{Binding EditValor, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <TextBox Text="{Binding EditDescricao}" AcceptsReturn="True" Height="80"/>

                    <GroupBox Header="Itens" Foreground="#CFCFCF" Margin="0,8,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ListView ItemsSource="{Binding EditItems}" Grid.Row="0">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding ProdutoDescricao}" Foreground="#FFFFFF"/>
                                            <TextBlock Text="x {Binding Quantidade}" Foreground="#CFCFCF"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                <Button Content="Adicionar Item" Command="{Binding AdicionarItemCommand}"/>
                                <Button Content="Remover Item" Command="{Binding RemoverItemCommand}"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                    <Button Content="Salvar" Command="{Binding SalvarComboCommand}" Width="100"/>
                    <Button Content="Registrar Saída" Command="{Binding RegistrarSaidaCommand}" Width="130"/>
                    <Button Content="Registrar Consumo" Command="{Binding RegistrarConsumoCommand}" Width="130"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>