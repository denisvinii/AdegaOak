<UserControl x:Class="Adega_Oak.Views.TabelaPrecosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:Adega_Oak.Converters"
             mc:Ignorable="d"
             Background="{DynamicResource MaterialDesignPaper}">

    <UserControl.Resources>
        <converters:LessThanZeroConverter x:Key="LessThanZeroConverter"/>
        <converters:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter"/>
        
        <!-- Estilo para highlight de campo editável -->
        <Style x:Key="EditableFieldStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
        </Style>
        
        <!-- Estilo para TextBox de edição com validação -->
        <Style x:Key="EditableTextBoxStyle" TargetType="TextBox">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#4CAF50"/>
            <Setter Property="Background" Value="#F1F8E9"/>
        </Style>

        <Style x:Key="InvalidPriceStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F44336"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="{DynamicResource MaterialDesignCardBackground}"
                CornerRadius="8"
                Effect="{DynamicResource MaterialDesignElevationShadow2}"
                Margin="0,10,0,24">
            <Grid Margin="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="📊 Tabela de Preços"
                             Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                             Foreground="{DynamicResource MaterialDesignBody}"/>
                    <TextBlock Text="Clique uma vez para editar • Pressione Enter para confirmar • Esc para cancelar"
                             Style="{StaticResource MaterialDesignCaptionTextBlock}"
                             Margin="0,8,0,0"
                             Opacity="0.7"/>
                    <TextBox Width="300"
                            Margin="0,16,0,0"
                            Padding="8,4"
                            materialDesign:HintAssist.Hint="🔍 Filtrar produtos..."
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Text="{Binding Filtro, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTEÚDO PRINCIPAL -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400"/>
                <ColumnDefinition Width="350" MaxWidth="400"/>
            </Grid.ColumnDefinitions>

            <!-- TABELA PRINCIPAL COM ABAS -->
            <Border Grid.Column="0"
                    Background="{DynamicResource MaterialDesignCardBackground}"
                    CornerRadius="8"
                    Effect="{DynamicResource MaterialDesignElevationShadow2}"
                    Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- ABAS DE PREÇOS -->
                    <TabControl Grid.Row="0" 
                                Margin="16,16,16,0"
                                Style="{StaticResource MaterialDesignTabControl}">
                        
                        <!-- ABA VAREJO -->
                        <TabItem Header="💵 Varejo (Unitário)">
                            <DataGrid ItemsSource="{Binding ProdutosView}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      SelectedItem="{Binding ProdutoSelecionado}"
                                      PreviewMouseLeftButtonDown="DataGrid_PreviewMouseLeftButtonDown"
                                      Margin="0"
                                      Padding="16"
                                      RowHeight="40">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Produto" 
                                                      Binding="{Binding Descricao}" 
                                                      Width="*"
                                                      IsReadOnly="True"/>

                                    <DataGridTextColumn Header="Custo" 
                                                      Binding="{Binding ValorCusto, StringFormat=C2}" 
                                                      Width="100"
                                                      IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="Margin" Value="8,0"/>
                                                <Setter Property="Opacity" Value="0.7"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="💰 Preço Venda" 
                                                      Binding="{Binding ValorVenda, StringFormat=C2, UpdateSourceTrigger=PropertyChanged}" 
                                                      Width="120">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource EditableFieldStyle}">
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Foreground" Value="#1976D2"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                        <DataGridTextColumn.EditingElementStyle>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource EditableTextBoxStyle}"/>
                                        </DataGridTextColumn.EditingElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Margem %" 
                                                      Binding="{Binding PorcentagemLucro, StringFormat='{}{0:N1}%'}"
                                                      Width="90"
                                                      IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="Margin" Value="8,0"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PorcentagemLucro}" Value="0">
                                                        <Setter Property="Foreground" Value="#FFB74D"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PorcentagemLucro, Converter={StaticResource LessThanZeroConverter}}" Value="True">
                                                        <Setter Property="Foreground" Value="#F44336"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PorcentagemLucro, Converter={StaticResource GreaterThanZeroConverter}}" Value="True">
                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <!-- ABA CAIXA -->
                        <TabItem Header="📦 Caixa">
                            <DataGrid ItemsSource="{Binding ProdutosView}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      SelectedItem="{Binding ProdutoSelecionado}"
                                      PreviewMouseLeftButtonDown="DataGrid_PreviewMouseLeftButtonDown"
                                      Margin="0"
                                      Padding="16"
                                      RowHeight="40">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Produto" 
                                                      Binding="{Binding Descricao}" 
                                                      Width="*"
                                                      IsReadOnly="True"/>

                                    <DataGridTextColumn Header="Qtd/Caixa" 
                                                      Binding="{Binding QuantidadeCaixa, UpdateSourceTrigger=PropertyChanged}"
                                                      Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource EditableFieldStyle}">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                        <DataGridTextColumn.EditingElementStyle>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource EditableTextBoxStyle}">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.EditingElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="🎁 Valor Caixa" 
                                                      Binding="{Binding ValorCaixa, StringFormat=C2, UpdateSourceTrigger=PropertyChanged}"
                                                      Width="120">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource EditableFieldStyle}">
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Foreground" Value="#7B1FA2"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                        <DataGridTextColumn.EditingElementStyle>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource EditableTextBoxStyle}"/>
                                        </DataGridTextColumn.EditingElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Margem %" 
                                                      Binding="{Binding PorcentagemLucroCaixa, StringFormat='{}{0:N1}%'}"
                                                      Width="90"
                                                      IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="Margin" Value="8,0"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PorcentagemLucroCaixa}" Value="0">
                                                        <Setter Property="Foreground" Value="#FFB74D"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PorcentagemLucroCaixa, Converter={StaticResource LessThanZeroConverter}}" Value="True">
                                                        <Setter Property="Foreground" Value="#F44336"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PorcentagemLucroCaixa, Converter={StaticResource GreaterThanZeroConverter}}" Value="True">
                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <!-- ABA ATACADO -->
                        <TabItem Header="🚚 Atacado">
                            <DataGrid ItemsSource="{Binding ProdutosView}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      SelectedItem="{Binding ProdutoSelecionado}"
                                      PreviewMouseLeftButtonDown="DataGrid_PreviewMouseLeftButtonDown"
                                      Margin="0"
                                      Padding="16"
                                      RowHeight="40">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Produto" 
                                                      Binding="{Binding Descricao}" 
                                                      Width="*"
                                                      IsReadOnly="True"/>

                                    <DataGridTextColumn Header="Qtd Mín." 
                                                      Binding="{Binding QuantidadeMinimaAtacado, UpdateSourceTrigger=PropertyChanged}"
                                                      Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource EditableFieldStyle}">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                        <DataGridTextColumn.EditingElementStyle>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource EditableTextBoxStyle}">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.EditingElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="💳 Valor Atacado" 
                                                      Binding="{Binding ValorAtacadoCaixa, StringFormat=C2, UpdateSourceTrigger=PropertyChanged}"
                                                      Width="120">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource EditableFieldStyle}">
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Foreground" Value="#C62828"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                        <DataGridTextColumn.EditingElementStyle>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource EditableTextBoxStyle}"/>
                                        </DataGridTextColumn.EditingElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Margem %" 
                                                      Binding="{Binding PorcentagemLucroAtacado, StringFormat='{}{0:N1}%'}"
                                                      Width="90"
                                                      IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="Margin" Value="8,0"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PorcentagemLucroAtacado}" Value="0">
                                                        <Setter Property="Foreground" Value="#FFB74D"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PorcentagemLucroAtacado, Converter={StaticResource LessThanZeroConverter}}" Value="True">
                                                        <Setter Property="Foreground" Value="#F44336"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PorcentagemLucroAtacado, Converter={StaticResource GreaterThanZeroConverter}}" Value="True">
                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <!-- PAINEL LATERAL DE DETALHES -->
            <Border Grid.Column="1"
                    Background="{DynamicResource MaterialDesignCardBackground}"
                    CornerRadius="8"
                    Effect="{DynamicResource MaterialDesignElevationShadow2}"
                    Padding="16">
                
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- HEADER DO PAINEL -->
                        <TextBlock Text="📋 Detalhes do Produto"
                                 Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                 Margin="0,0,0,16"
                                 Foreground="{DynamicResource MaterialDesignBody}"/>

                        <!-- PRODUTO SELECIONADO -->
                        <Border Background="#F5F5F5" 
                                CornerRadius="4" 
                                Padding="12"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Produto:"
                                         Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                         Opacity="0.7"/>
                                <TextBlock Text="{Binding ProdutoSelecionado.Descricao}"
                                         Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                         TextWrapping="Wrap"
                                         Margin="0,4,0,0"
                                         Foreground="#1976D2"/>
                            </StackPanel>
                        </Border>

                        <!-- CUSTO -->
                        <Border Background="#FFF3E0" 
                                CornerRadius="4" 
                                Padding="12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="💰 Custo Unitário"
                                         Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                         Opacity="0.8"/>
                                <TextBlock Text="{Binding ProdutoSelecionado.ValorCusto, StringFormat=C2}"
                                         Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                         Margin="0,4,0,0"
                                         Foreground="#F57C00"/>
                            </StackPanel>
                        </Border>

                        <!-- VAREJO -->
                        <Border Background="#E3F2FD" 
                                CornerRadius="4" 
                                Padding="12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="💵 Preço Varejo"
                                         Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                         Opacity="0.8"/>
                                <TextBlock Text="{Binding ProdutoSelecionado.ValorVenda, StringFormat=C2}"
                                         Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                         Margin="0,4,0,0"
                                         Foreground="#1976D2"/>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Margem:"
                                             Style="{StaticResource MaterialDesignCaptionTextBlock}"/>
                                    <TextBlock Grid.Column="1"
                                             Text="{Binding ProdutoSelecionado.PorcentagemLucro, StringFormat='{}{0:N1}%'}"
                                             Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                             FontWeight="Bold">
                                        <TextBlock.Foreground>
                                            <MultiBinding Converter="{StaticResource GreaterThanZeroConverter}">
                                                <Binding Path="ProdutoSelecionado.PorcentagemLucro"/>
                                            </MultiBinding>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- CAIXA -->
                        <Border Background="#F3E5F5" 
                                CornerRadius="4" 
                                Padding="12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="📦 Preço Caixa"
                                         Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                         Opacity="0.8"/>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding ProdutoSelecionado.QuantidadeCaixa}" 
                                                 Style="{StaticResource MaterialDesignCaptionTextBlock}"/>
                                        <TextBlock Text="unidades"
                                                 Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                 Opacity="0.6"
                                                 Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding ProdutoSelecionado.ValorCaixa, StringFormat=C2}"
                                                 Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                                 Foreground="#7B1FA2"/>
                                        <TextBlock Text="{Binding ProdutoSelecionado.PorcentagemLucroCaixa, StringFormat='{}{0:N1}%'}"
                                                 Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                 FontWeight="Bold"
                                                 Margin="0,2,0,0"
                                                 HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ATACADO -->
                        <Border Background="#FFEBEE" 
                                CornerRadius="4" 
                                Padding="12">
                            <StackPanel>
                                <TextBlock Text="🚚 Preço Atacado"
                                         Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                         Opacity="0.8"/>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding ProdutoSelecionado.QuantidadeMinimaAtacado}" 
                                                 Style="{StaticResource MaterialDesignCaptionTextBlock}"/>
                                        <TextBlock Text="caixas mín."
                                                 Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                 Opacity="0.6"
                                                 Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding ProdutoSelecionado.ValorAtacadoCaixa, StringFormat=C2}"
                                                 Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                                 Foreground="#C62828"/>
                                        <TextBlock Text="{Binding ProdutoSelecionado.PorcentagemLucroAtacado, StringFormat='{}{0:N1}%'}"
                                                 Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                 FontWeight="Bold"
                                                 Margin="0,2,0,0"
                                                 HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
