<UserControl x:Class="Adega_Oak.Views.TabelaPrecosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:Adega_Oak.Converters"
             mc:Ignorable="d"
             Background="#F5F5F5">

    <UserControl.Resources>
        <converters:LessThanZeroConverter x:Key="LessThanZeroConverter"/>
        <converters:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter"/>
        <converters:MarginToBrushConverter x:Key="MarginToBrushConverter"/>
        
        <Color x:Key="CorAzulVarejo">#2196F3</Color>
        <Color x:Key="CorRoxoCaixa">#9C27B0</Color>
        <Color x:Key="CorVermAtacado">#D32F2F</Color>
        <Color x:Key="CorVerde">#4CAF50</Color>
        <Color x:Key="CorAmarelo">#FFC107</Color>
        <Color x:Key="CorRed">#F44336</Color>

        <SolidColorBrush x:Key="BrushAzulVarejo" Color="#2196F3"/>
        <SolidColorBrush x:Key="BrushRoxoCaixa" Color="#9C27B0"/>
        <SolidColorBrush x:Key="BrushVermAtacado" Color="#D32F2F"/>
        
        <Style x:Key="CampoEditavelStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="12,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <Style x:Key="CampoPrecoStyle" TargetType="TextBlock" BasedOn="{StaticResource CampoEditavelStyle}">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="TextBoxEdicaoStyle" TargetType="TextBox">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#2196F3"/>
            <Setter Property="Background" Value="#E3F2FD"/>
            <Setter Property="Foreground" Value="#1976D2"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="MargemPositivaStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#2E7D32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#C8E6C9"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MargemNeutraStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F57F17"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#FFF9C4"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MargemNegativaStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C62828"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#FFCDD2"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="HeaderColunaiStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="Margin" Value="0,4,0,2"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER COM TITULO ===== -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                Padding="24"
                Margin="0,0,0,20"
                BorderThickness="1"
                BorderBrush="#E0E0E0">
            <StackPanel>
                <TextBlock Text="Tabela de Precos - Gerenciamento Completo"
                         FontSize="24"
                         FontWeight="Bold"
                         Foreground="#1976D2"
                         Margin="0,0,0,4"/>
                
                <TextBlock Text="Clique 1x para editar • Enter para confirmar • Esc para cancelar"
                         FontSize="12"
                         Foreground="#999"
                         Margin="0,0,0,16"/>

                <!-- Filtro -->
                <TextBox Width="350"
                        Padding="12,8"
                        materialDesign:HintAssist.Hint="🔍 Filtrar produtos..."
                        HorizontalAlignment="Left"
                        BorderThickness="2"
                        BorderBrush="#E0E0E0"
                        Background="White"
                        Text="{Binding Filtro, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </Border>

        <!-- ===== CONTEUDO PRINCIPAL ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="500"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- ===== TABELA COM ABAS ===== -->
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="12"
                    BorderThickness="1"
                    BorderBrush="#E0E0E0"
                    Margin="0,0,16,0"
                    Padding="0">

                <TabControl Style="{StaticResource MaterialDesignTabControl}">
                    
                    <!-- ===== ABA VAREJO ===== -->
                    <TabItem Header="Varejo (Unitario)">
                        <Grid Background="White">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Header Info -->
                            <Border Grid.Row="0" Background="#E3F2FD" Padding="16" BorderThickness="0,0,0,2" BorderBrush="#2196F3">
                                <TextBlock Text="Preco unitario de venda no varejo (por unidade)" 
                                         Foreground="#1976D2" FontWeight="Bold" FontSize="13"/>
                            </Border>

                            <!-- Grid com Dados -->
                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding ProdutosView}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      SelectedItem="{Binding ProdutoSelecionado}"
                                      PreviewMouseLeftButtonDown="DataGrid_PreviewMouseLeftButtonDown"
                                      RowHeight="50"
                                      Padding="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Produto" 
                                                      Binding="{Binding Descricao}" 
                                                      Width="*"
                                                      IsReadOnly="True">
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#2196F3"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Margin" Value="12,0"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Custo" 
                                                      Binding="{Binding ValorCusto, StringFormat=C2}" 
                                                      Width="100"
                                                      IsReadOnly="True">
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#FFA726"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource CampoEditavelStyle}">
                                                <Setter Property="Opacity" Value="0.7"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Venda" 
                                                      Binding="{Binding ValorVenda, StringFormat=C2, UpdateSourceTrigger=PropertyChanged}" 
                                                      Width="110">
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#2196F3"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource CampoPrecoStyle}">
                                                <Setter Property="Foreground" Value="#2196F3"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                        <DataGridTextColumn.EditingElementStyle>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource TextBoxEdicaoStyle}"/>
                                        </DataGridTextColumn.EditingElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Margem %" 
                                                      Binding="{Binding PorcentagemLucro, StringFormat='{}{0:N1}%'}"
                                                      Width="100"
                                                      IsReadOnly="True">
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#4CAF50"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Margin" Value="4"/>
                                                <Setter Property="Padding" Value="6,2"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PorcentagemLucro}" Value="0">
                                                        <Setter Property="Background" Value="#FFF9C4"/>
                                                        <Setter Property="Foreground" Value="#F57F17"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PorcentagemLucro, Converter={StaticResource LessThanZeroConverter}}" Value="True">
                                                        <Setter Property="Background" Value="#FFCDD2"/>
                                                        <Setter Property="Foreground" Value="#C62828"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PorcentagemLucro, Converter={StaticResource GreaterThanZeroConverter}}" Value="True">
                                                        <Setter Property="Background" Value="#C8E6C9"/>
                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <!-- ===== ABA CAIXA ===== -->
                    <TabItem Header="Caixa">
                        <Grid Background="White">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <Border Grid.Row="0" Background="#F3E5F5" Padding="16" BorderThickness="0,0,0,2" BorderBrush="#9C27B0">
                                <TextBlock Text="Preco de venda por caixa (multiplo de unidades)" 
                                         Foreground="#6A1B9A" FontWeight="Bold" FontSize="13"/>
                            </Border>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding ProdutosView}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      SelectedItem="{Binding ProdutoSelecionado}"
                                      PreviewMouseLeftButtonDown="DataGrid_PreviewMouseLeftButtonDown"
                                      RowHeight="50"
                                      Padding="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Produto" 
                                                      Binding="{Binding Descricao}" 
                                                      Width="*"
                                                      IsReadOnly="True">
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#9C27B0"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Margin" Value="12,0"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Qtd/Cx" 
                                                      Binding="{Binding QuantidadeCaixa, UpdateSourceTrigger=PropertyChanged}"
                                                      Width="75">
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#9C27B0"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource CampoEditavelStyle}">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                        <DataGridTextColumn.EditingElementStyle>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource TextBoxEdicaoStyle}">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.EditingElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Valor Caixa" 
                                                      Binding="{Binding ValorCaixa, StringFormat=C2, UpdateSourceTrigger=PropertyChanged}"
                                                      Width="120">
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#9C27B0"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource CampoPrecoStyle}">
                                                <Setter Property="Foreground" Value="#7B1FA2"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                        <DataGridTextColumn.EditingElementStyle>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource TextBoxEdicaoStyle}"/>
                                        </DataGridTextColumn.EditingElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Margem %" 
                                                      Binding="{Binding PorcentagemLucroCaixa, StringFormat='{}{0:N1}%'}"
                                                      Width="100"
                                                      IsReadOnly="True">
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#4CAF50"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Margin" Value="4"/>
                                                <Setter Property="Padding" Value="6,2"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PorcentagemLucroCaixa}" Value="0">
                                                        <Setter Property="Background" Value="#FFF9C4"/>
                                                        <Setter Property="Foreground" Value="#F57F17"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PorcentagemLucroCaixa, Converter={StaticResource LessThanZeroConverter}}" Value="True">
                                                        <Setter Property="Background" Value="#FFCDD2"/>
                                                        <Setter Property="Foreground" Value="#C62828"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PorcentagemLucroCaixa, Converter={StaticResource GreaterThanZeroConverter}}" Value="True">
                                                        <Setter Property="Background" Value="#C8E6C9"/>
                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <!-- ===== ABA ATACADO ===== -->
                    <TabItem Header="Atacado">
                        <Grid Background="White">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <Border Grid.Row="0" Background="#FFEBEE" Padding="16" BorderThickness="0,0,0,2" BorderBrush="#D32F2F">
                                <TextBlock Text="Preco especial para compras em grande quantidade (atacado)" 
                                         Foreground="#B71C1C" FontWeight="Bold" FontSize="13"/>
                            </Border>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding ProdutosView}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      SelectedItem="{Binding ProdutoSelecionado}"
                                      PreviewMouseLeftButtonDown="DataGrid_PreviewMouseLeftButtonDown"
                                      RowHeight="50"
                                      Padding="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Produto" 
                                                      Binding="{Binding Descricao}" 
                                                      Width="*"
                                                      IsReadOnly="True">
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#D32F2F"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Margin" Value="12,0"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Qtd Min" 
                                                      Binding="{Binding QuantidadeMinimaAtacado, UpdateSourceTrigger=PropertyChanged}"
                                                      Width="75">
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#D32F2F"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource CampoEditavelStyle}">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                        <DataGridTextColumn.EditingElementStyle>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource TextBoxEdicaoStyle}">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.EditingElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Valor Atacado" 
                                                      Binding="{Binding ValorAtacadoCaixa, StringFormat=C2, UpdateSourceTrigger=PropertyChanged}"
                                                      Width="120">
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#D32F2F"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource CampoPrecoStyle}">
                                                <Setter Property="Foreground" Value="#D32F2F"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                        <DataGridTextColumn.EditingElementStyle>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource TextBoxEdicaoStyle}"/>
                                        </DataGridTextColumn.EditingElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Margem %" 
                                                      Binding="{Binding PorcentagemLucroAtacado, StringFormat='{}{0:N1}%'}"
                                                      Width="100"
                                                      IsReadOnly="True">
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#4CAF50"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Margin" Value="4"/>
                                                <Setter Property="Padding" Value="6,2"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PorcentagemLucroAtacado}" Value="0">
                                                        <Setter Property="Background" Value="#FFF9C4"/>
                                                        <Setter Property="Foreground" Value="#F57F17"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PorcentagemLucroAtacado, Converter={StaticResource LessThanZeroConverter}}" Value="True">
                                                        <Setter Property="Background" Value="#FFCDD2"/>
                                                        <Setter Property="Foreground" Value="#C62828"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PorcentagemLucroAtacado, Converter={StaticResource GreaterThanZeroConverter}}" Value="True">
                                                        <Setter Property="Background" Value="#C8E6C9"/>
                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>

            <!-- ===== PAINEL LATERAL ===== -->
            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="12"
                    BorderThickness="1"
                    BorderBrush="#E0E0E0"
                    Padding="16">
                
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Detalhes do Produto"
                                 FontSize="16"
                                 FontWeight="Bold"
                                 Foreground="#1976D2"
                                 Margin="0,0,0,20"/>

                        <!-- Produto Selecionado -->
                        <Border Background="#F5F5F5" 
                                CornerRadius="8" 
                                Padding="12"
                                Margin="0,0,0,16"
                                BorderThickness="2"
                                BorderBrush="#2196F3">
                            <StackPanel>
                                <TextBlock Text="Produto:" 
                                         FontSize="11" Foreground="#666" FontWeight="Bold"/>
                                <TextBlock Text="{Binding ProdutoSelecionado.Descricao}"
                                         FontSize="13"
                                         TextWrapping="Wrap"
                                         Margin="0,6,0,0"
                                         Foreground="#1976D2"
                                         FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <!-- Custo -->
                        <Border Background="#FFF3E0" 
                                CornerRadius="8" 
                                Padding="12"
                                Margin="0,0,0,12"
                                BorderThickness="2"
                                BorderBrush="#FF9800">
                            <StackPanel>
                                <TextBlock Text="Custo Unitario"
                                         FontSize="11" Foreground="#E65100" FontWeight="Bold"/>
                                <TextBlock Text="{Binding ProdutoSelecionado.ValorCusto, StringFormat=C2}"
                                         FontSize="18"
                                         Margin="0,6,0,0"
                                         Foreground="#E65100"
                                         FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <!-- Varejo -->
                        <Border Background="#E3F2FD" 
                                CornerRadius="8" 
                                Padding="12"
                                Margin="0,0,0,12"
                                BorderThickness="2"
                                BorderBrush="#2196F3">
                            <StackPanel>
                                <TextBlock Text="Preco Varejo (Unitario)"
                                         FontSize="11" Foreground="#0D47A1" FontWeight="Bold"/>
                                <TextBlock Text="{Binding ProdutoSelecionado.ValorVenda, StringFormat=C2}"
                                         FontSize="18"
                                         Margin="0,8,0,0"
                                         Foreground="#2196F3"
                                         FontWeight="Bold"/>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Margem:" FontSize="11" Foreground="#666"/>
                                    <TextBlock Grid.Column="1"
                                             Text="{Binding ProdutoSelecionado.PorcentagemLucro, StringFormat='{}{0:N1}%'}"
                                             FontSize="12"
                                             FontWeight="Bold"
                                             Foreground="#2E7D32"
                                             Padding="6,2"
                                             Background="#C8E6C9"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Caixa -->
                        <Border Background="#F3E5F5" 
                                CornerRadius="8" 
                                Padding="12"
                                Margin="0,0,0,12"
                                BorderThickness="2"
                                BorderBrush="#9C27B0">
                            <StackPanel>
                                <TextBlock Text="Preco Caixa"
                                         FontSize="11" Foreground="#4A148C" FontWeight="Bold"/>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding ProdutoSelecionado.QuantidadeCaixa}" 
                                                 FontSize="13" FontWeight="Bold" Foreground="#4A148C"/>
                                        <TextBlock Text="unidades"
                                                 FontSize="10" Foreground="#999" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding ProdutoSelecionado.ValorCaixa, StringFormat=C2}"
                                                 FontSize="15"
                                                 Foreground="#9C27B0"
                                                 FontWeight="Bold"/>
                                        <TextBlock Text="{Binding ProdutoSelecionado.PorcentagemLucroCaixa, StringFormat='{}{0:N1}%'}"
                                                 FontSize="11"
                                                 FontWeight="Bold"
                                                 Margin="0,4,0,0"
                                                 HorizontalAlignment="Right"
                                                 Foreground="#2E7D32"
                                                 Padding="4,2"
                                                 Background="#C8E6C9"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Atacado -->
                        <Border Background="#FFEBEE" 
                                CornerRadius="8" 
                                Padding="12"
                                BorderThickness="2"
                                BorderBrush="#D32F2F">
                            <StackPanel>
                                <TextBlock Text="Preco Atacado"
                                         FontSize="11" Foreground="#B71C1C" FontWeight="Bold"/>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding ProdutoSelecionado.QuantidadeMinimaAtacado}" 
                                                 FontSize="13" FontWeight="Bold" Foreground="#B71C1C"/>
                                        <TextBlock Text="caixas minimas"
                                                 FontSize="10" Foreground="#999" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding ProdutoSelecionado.ValorAtacadoCaixa, StringFormat=C2}"
                                                 FontSize="15"
                                                 Foreground="#D32F2F"
                                                 FontWeight="Bold"/>
                                        <TextBlock Text="{Binding ProdutoSelecionado.PorcentagemLucroAtacado, StringFormat='{}{0:N1}%'}"
                                                 FontSize="11"
                                                 FontWeight="Bold"
                                                 Margin="0,4,0,0"
                                                 HorizontalAlignment="Right"
                                                 Foreground="#2E7D32"
                                                 Padding="4,2"
                                                 Background="#C8E6C9"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
