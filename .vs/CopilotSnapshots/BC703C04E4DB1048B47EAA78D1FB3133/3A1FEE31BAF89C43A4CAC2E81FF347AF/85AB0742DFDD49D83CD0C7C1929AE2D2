    public decimal ObterTotalVendidoPeriodo(int mes, int ano)
    {
        using var conn = _dbService.GetConnection();
        using var cmd = conn.CreateCommand();

        if (conn is Npgsql.NpgsqlConnection)
            cmd.CommandText = @"
                SELECT COALESCE(SUM(preco_total), 0) 
                FROM copao_vendas 
                WHERE EXTRACT(MONTH FROM data_venda)::int = @mes 
                AND EXTRACT(YEAR FROM data_venda)::int = @ano";
        else
            cmd.CommandText = @"
                SELECT COALESCE(SUM(preco_total), 0) 
                FROM copao_vendas 
                WHERE strftime('%m', data_venda) = @mes 
                AND strftime('%Y', data_venda) = @ano";

        var pMes = cmd.CreateParameter();
        pMes.ParameterName = "@mes";
        pMes.Value = mes;  // Enviar como INT, não como string
        cmd.Parameters.Add(pMes);

        var pAno = cmd.CreateParameter();
        pAno.ParameterName = "@ano";
        pAno.Value = ano;
        cmd.Parameters.Add(pAno);

        var resultado = cmd.ExecuteScalar();
        return resultado != null ? Convert.ToDecimal(resultado) : 0;
    }

    // ==================== HELPER ====================

    private void RegistrarSaidaEstoque(IDbConnection conn, IDbTransaction transaction, int productId, int quantidade, string tipo, string responsavel, string? saida)
    {
        // Lookup product description from estoque to fill 'produto' column (required)
        string produtoDescricao = "";
        try
        {
            using var cmdSel = conn.CreateCommand();
            cmdSel.CommandText = "SELECT bebida, tamanho, material FROM estoque WHERE productid = @productId";
            var p = cmdSel.CreateParameter();
            p.ParameterName = "@productId";
            p.Value = productId;
            cmdSel.Parameters.Add(p);

            using var rdr = cmdSel.ExecuteReader();
            if (rdr.Read())
            {
                var bebida = rdr.IsDBNull(0) ? "" : rdr.GetString(0);
                var tamanho = rdr.IsDBNull(1) ? "" : rdr.GetString(1);
                var material = rdr.IsDBNull(2) ? "" : rdr.GetString(2);
                produtoDescricao = string.Join(" - ", new[] { bebida, tamanho, material }.Where(s => !string.IsNullOrWhiteSpace(s)));
            }
        }
        catch
        {
            // ignore lookup errors and continue with empty description
        }

        var cmd = conn.CreateCommand();
        cmd.CommandText = @"
            INSERT INTO movimentacoes (data, tipo, tipo_venda, productid, produto, quantidade, responsavel, saida, valor_unitario)
            VALUES (@data, @tipo, @tipo_venda, @productid, @produto, @quantidade, @responsavel, @saida, @valor_unitario)";

        cmd.Transaction = transaction;

        var pData = cmd.CreateParameter();
        pData.ParameterName = "@data";
        if (conn is Microsoft.Data.Sqlite.SqliteConnection)
            pData.Value = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss");
        else
            pData.Value = DateTime.Now;
        cmd.Parameters.Add(pData);

        var pTipo = cmd.CreateParameter();
        pTipo.ParameterName = "@tipo";
        pTipo.Value = tipo;
        cmd.Parameters.Add(pTipo);

        var pTipoVenda = cmd.CreateParameter();
        pTipoVenda.ParameterName = "@tipo_venda";
        pTipoVenda.Value = "Varejo";
        cmd.Parameters.Add(pTipoVenda);

        var pProductId = cmd.CreateParameter();
        pProductId.ParameterName = "@productid";
        pProductId.Value = productId;
        cmd.Parameters.Add(pProductId);

        var pProduto = cmd.CreateParameter();
        pProduto.ParameterName = "@produto";
        pProduto.Value = string.IsNullOrWhiteSpace(produtoDescricao) ? (object)"Produto desconhecido" : produtoDescricao;
        cmd.Parameters.Add(pProduto);

        var pQtd = cmd.CreateParameter();
        pQtd.ParameterName = "@quantidade";
        pQtd.Value = quantidade;
        cmd.Parameters.Add(pQtd);

        var pResponsavel = cmd.CreateParameter();
        pResponsavel.ParameterName = "@responsavel";
        pResponsavel.Value = string.IsNullOrWhiteSpace(responsavel) ? (object)"Sistema" : responsavel;
        cmd.Parameters.Add(pResponsavel);

        var pSaida = cmd.CreateParameter();
        pSaida.ParameterName = "@saida";
        pSaida.Value = saida ?? (object)DBNull.Value;
        cmd.Parameters.Add(pSaida);

        var pValor = cmd.CreateParameter();
        pValor.ParameterName = "@valor_unitario";
        pValor.Value = 0;
        cmd.Parameters.Add(pValor);

        cmd.ExecuteNonQuery();
    }
}
