    // ==================== CRIAR/EDITAR ====================

    public int CriarCopao(Copao copao, List<CopaoComposicao> composicao)
    {
        if (string.IsNullOrWhiteSpace(copao.Nome))
            throw new ArgumentException("Nome do copão é obrigatório");

        if (copao.PrecoVenda <= 0)
            throw new ArgumentException("Preço deve ser maior que zero");

        if (composicao == null || composicao.Count == 0)
            throw new ArgumentException("Copão deve ter pelo menos um produto");

        // Validar nome duplicado
        if (ValidarNomeDuplicado(copao.Nome))
            throw new InvalidOperationException($"Já existe um copão com o nome '{copao.Nome}'");

        using var conn = _dbService.GetConnection();
        // Ensure connection is open but avoid double-open
        if (conn.State != ConnectionState.Open)
            conn.Open();

        using var transaction = conn.BeginTransaction();

        try
        {
            // Inserir copão
            using var cmd = conn.CreateCommand();
            
            // Detectar banco de dados e usar syntax apropriada
            if (conn is Npgsql.NpgsqlConnection)
                cmd.CommandText = @"
                    INSERT INTO copoes (nome, descricao, preco_venda, ativo)
                    VALUES (@nome, @descricao, @precoVenda, @ativo)
                    RETURNING copao_id;";
            else
                cmd.CommandText = @"
                    INSERT INTO copoes (nome, descricao, preco_venda, ativo)
                    VALUES (@nome, @descricao, @precoVenda, @ativo);
                    SELECT last_insert_rowid();";

            cmd.Transaction = transaction;

            var paramNome = cmd.CreateParameter();
            paramNome.ParameterName = "@nome";
            paramNome.Value = copao.Nome;
            cmd.Parameters.Add(paramNome);

            var paramDesc = cmd.CreateParameter();
            paramDesc.ParameterName = "@descricao";
            paramDesc.Value = copao.Descricao ?? (object)DBNull.Value;
            cmd.Parameters.Add(paramDesc);

            var paramPreco = cmd.CreateParameter();
            paramPreco.ParameterName = "@precoVenda";
            paramPreco.Value = copao.PrecoVenda;
            cmd.Parameters.Add(paramPreco);

            var paramAtivo = cmd.CreateParameter();
            paramAtivo.ParameterName = "@ativo";
            paramAtivo.Value = copao.Ativo;
            cmd.Parameters.Add(paramAtivo);

            var copaoId = Convert.ToInt32(cmd.ExecuteScalar());

            // Inserir composição
            foreach (var item in composicao)
            {
                var cmdComp = conn.CreateCommand();
                cmdComp.CommandText = @"
                    INSERT INTO copao_composicao (copao_id, product_id, quantidade, unidade, debita_estoque)
                    VALUES (@copaoId, @productId, @quantidade, @unidade, @debitaEstoque)";

                cmdComp.Transaction = transaction;

                var pCopaoId = cmdComp.CreateParameter();
                pCopaoId.ParameterName = "@copaoId";
                pCopaoId.Value = copaoId;
                cmdComp.Parameters.Add(pCopaoId);

                var pProductId = cmdComp.CreateParameter();
                pProductId.ParameterName = "@productId";
                pProductId.Value = item.ProductId;
                cmdComp.Parameters.Add(pProductId);

                var pQtd = cmdComp.CreateParameter();
                pQtd.ParameterName = "@quantidade";
                pQtd.Value = item.Quantidade;
                cmdComp.Parameters.Add(pQtd);

                var pUnidade = cmdComp.CreateParameter();
                pUnidade.ParameterName = "@unidade";
                pUnidade.Value = item.Unidade;
                cmdComp.Parameters.Add(pUnidade);

                var pDebita = cmdComp.CreateParameter();
                pDebita.ParameterName = "@debitaEstoque";
                pDebita.Value = item.DebitaEstoque;
                cmdComp.Parameters.Add(pDebita);

                cmdComp.ExecuteNonQuery();
            }

            transaction.Commit();
            return copaoId;
        }
        catch
        {
            transaction.Rollback();
            throw;
        }
    }

    public void EditarCopao(Copao copao, List<CopaoComposicao> composicao)
    {
        if (string.IsNullOrWhiteSpace(copao.Nome))
            throw new ArgumentException("Nome do copão é obrigatório");

        if (copao.PrecoVenda <= 0)
            throw new ArgumentException("Preço deve ser maior que zero");

        if (composicao == null || composicao.Count == 0)
            throw new ArgumentException("Copão deve ter pelo menos um produto");

        using var conn = _dbService.GetConnection();
        if (conn.State != ConnectionState.Open)
            conn.Open();
        using var transaction = conn.BeginTransaction();

        try
        {
            // Atualizar copão
            using var cmd = conn.CreateCommand();
            cmd.CommandText = @"
                UPDATE copoes 
                SET nome = @nome, descricao = @descricao, preco_venda = @precoVenda, ativo = @ativo
                WHERE copao_id = @copaoId";

            cmd.Transaction = transaction;

            var paramId = cmd.CreateParameter();
            paramId.ParameterName = "@copaoId";
            paramId.Value = copao.CopaoId;
            cmd.Parameters.Add(paramId);

            var paramNome = cmd.CreateParameter();
            paramNome.ParameterName = "@nome";
            paramNome.Value = copao.Nome;
            cmd.Parameters.Add(paramNome);

            var paramDesc = cmd.CreateParameter();
            paramDesc.ParameterName = "@descricao";
            paramDesc.Value = copao.Descricao ?? (object)DBNull.Value;
            cmd.Parameters.Add(paramDesc);

            var paramPreco = cmd.CreateParameter();
            paramPreco.ParameterName = "@precoVenda";
            paramPreco.Value = copao.PrecoVenda;
            cmd.Parameters.Add(paramPreco);

            var paramAtivo = cmd.CreateParameter();
            paramAtivo.ParameterName = "@ativo";
            paramAtivo.Value = copao.Ativo;
            cmd.Parameters.Add(paramAtivo);

            cmd.ExecuteNonQuery();

            // Remover composição antiga
            var cmdDel = conn.CreateCommand();
            cmdDel.CommandText = "DELETE FROM copao_composicao WHERE copao_id = @copaoId";
            cmdDel.Transaction = transaction;

            var pDelId = cmdDel.CreateParameter();
            pDelId.ParameterName = "@copaoId";
            pDelId.Value = copao.CopaoId;
            cmdDel.Parameters.Add(pDelId);

            cmdDel.ExecuteNonQuery();

            // Inserir composição nova
            foreach (var item in composicao)
            {
                var cmdComp = conn.CreateCommand();
                cmdComp.CommandText = @"
                    INSERT INTO copao_composicao (copao_id, product_id, quantidade, unidade, debita_estoque)
                    VALUES (@copaoId, @productId, @quantidade, @unidade, @debitaEstoque)";

                cmdComp.Transaction = transaction;

                var pCopaoId = cmdComp.CreateParameter();
                pCopaoId.ParameterName = "@copaoId";
                pCopaoId.Value = copao.CopaoId;
                cmdComp.Parameters.Add(pCopaoId);

                var pProductId = cmdComp.CreateParameter();
                pProductId.ParameterName = "@productId";
                pProductId.Value = item.ProductId;
                cmdComp.Parameters.Add(pProductId);

                var pQtd = cmdComp.CreateParameter();
                pQtd.ParameterName = "@quantidade";
                pQtd.Value = item.Quantidade;
                cmdComp.Parameters.Add(pQtd);

                var pUnidade = cmdComp.CreateParameter();
                pUnidade.ParameterName = "@unidade";
                pUnidade.Value = item.Unidade;
                cmdComp.Parameters.Add(pUnidade);

                var pDebita = cmdComp.CreateParameter();
                pDebita.ParameterName = "@debitaEstoque";
                pDebita.Value = item.DebitaEstoque;
                cmdComp.Parameters.Add(pDebita);

                cmdComp.ExecuteNonQuery();
            }

            transaction.Commit();
        }
        catch
        {
            transaction.Rollback();
            throw;
        }
    }

    public void RemoverCopao(int copaoId)
    {
        // Validar se tem vendas
        var vendas = CarregarHistoricoVendasPorCopao(copaoId);
        if (vendas.Any())
            throw new InvalidOperationException("Não é possível remover um copão que já foi vendido");

        using var conn = _dbService.GetConnection();
        if (conn.State != ConnectionState.Open)
            conn.Open();

        using var cmd = conn.CreateCommand();
        cmd.CommandText = "DELETE FROM copoes WHERE copao_id = @copaoId";

        var param = cmd.CreateParameter();
        param.ParameterName = "@copaoId";
        param.Value = copaoId;
        cmd.Parameters.Add(param);

        cmd.ExecuteNonQuery();
    }

    // ==================== LISTAR ====================

    public List<Copao> CarregarCopoes(bool apenasAtivos = false)
    {
        var lista = new List<Copao>();
        using var conn = _dbService.GetConnection();
        if (conn.State != ConnectionState.Open)
            conn.Open();
        using var cmd = conn.CreateCommand();

        if (apenasAtivos)
            cmd.CommandText = "SELECT copao_id, nome, descricao, preco_venda, ativo, data_criacao FROM copoes WHERE ativo = true ORDER BY nome";
        else
            cmd.CommandText = "SELECT copao_id, nome, descricao, preco_venda, ativo, data_criacao FROM copoes ORDER BY nome";

        using var reader = cmd.ExecuteReader();
        while (reader.Read())
        {
            lista.Add(new Copao
            {
                CopaoId = reader.GetInt32(0),
                Nome = reader.GetString(1),
                Descricao = reader.IsDBNull(2) ? null : reader.GetString(2),
                PrecoVenda = reader.GetDecimal(3),
                Ativo = reader.GetBoolean(4),
                DataCriacao = reader.GetDateTime(5)
            });
        }
        return lista;
    }

