    public List<CopaoComposicao> CarregarComposicao(int copaoId)
    {
        var lista = new List<CopaoComposicao>();
        using var conn = _dbService.GetConnection();
        if (conn.State != ConnectionState.Open)
            conn.Open();
        using var cmd = conn.CreateCommand();
        
        // Usar CONCAT para PostgreSQL e || para SQLite
        string concatenacao = conn is Npgsql.NpgsqlConnection 
            ? "e.bebida || ' - ' || e.tamanho || ' - ' || e.material"
            : "CONCAT(e.bebida, ' - ', e.tamanho, ' - ', e.material)";
        
        cmd.CommandText = $@"
            SELECT 
                cc.composicao_id, cc.copao_id, cc.product_id, cc.quantidade, 
                cc.unidade, cc.debita_estoque,
                {concatenacao} as descricao
            FROM copao_composicao cc
            LEFT JOIN estoque e ON cc.product_id = e.productid
            WHERE cc.copao_id = @copaoId
            ORDER BY cc.composicao_id";

        var param = cmd.CreateParameter();
        param.ParameterName = "@copaoId";
        param.Value = copaoId;
        cmd.Parameters.Add(param);

        using var reader = cmd.ExecuteReader();
        while (reader.Read())
        {
            lista.Add(new CopaoComposicao
            {
                ComposicaoId = reader.GetInt32(0),
                CopaoId = reader.GetInt32(1),
                ProductId = reader.GetInt32(2),
                Quantidade = reader.GetDecimal(3),
                Unidade = reader.GetString(4),
                DebitaEstoque = reader.GetBoolean(5),
                ProdutoDescricao = reader.IsDBNull(6) ? "Produto deletado" : reader.GetString(6)
            });
        }
        return lista;
    }

    // ==================== VENDER COPÃO ====================

    public bool VenderCopao(int copaoId, int quantidade, string responsavel, string? observacoes)
    {
        if (quantidade <= 0)
            throw new ArgumentException("Quantidade deve ser maior que zero");

        var copao = CarregarCopao(copaoId);
        if (copao == null)
            throw new InvalidOperationException("Copão não encontrado");

        var composicao = CarregarComposicao(copaoId);

        // VALIDAÇÃO: Verificar quantidade de produtos em estoque (com debita_estoque = true)
        var erros = ValidarQuantidadeEstoque(composicao, quantidade);
        if (erros.Any())
            throw new InvalidOperationException(string.Join("; ", erros));

        using var conn = _dbService.GetConnection();
        using var transaction = conn.BeginTransaction();

        try
        {
            // Registrar venda do copão
            using var cmd = conn.CreateCommand();
            cmd.CommandText = @"
                INSERT INTO copao_vendas (copao_id, quantidade, preco_unitario, preco_total, responsavel, observacoes)
                VALUES (@copaoId, @quantidade, @precoUnitario, @precoTotal, @responsavel, @observacoes)";

            cmd.Transaction = transaction;

            var pCopaoId = cmd.CreateParameter();
            pCopaoId.ParameterName = "@copaoId";
            pCopaoId.Value = copaoId;
            cmd.Parameters.Add(pCopaoId);

            var pQtd = cmd.CreateParameter();
            pQtd.ParameterName = "@quantidade";
            pQtd.Value = quantidade;
            cmd.Parameters.Add(pQtd);

            var pPrecoUnit = cmd.CreateParameter();
            pPrecoUnit.ParameterName = "@precoUnitario";
            pPrecoUnit.Value = copao.PrecoVenda;
            cmd.Parameters.Add(pPrecoUnit);

            var pPrecoTotal = cmd.CreateParameter();
            pPrecoTotal.ParameterName = "@precoTotal";
            pPrecoTotal.Value = copao.PrecoVenda * quantidade;
            cmd.Parameters.Add(pPrecoTotal);

            var pResponsavel = cmd.CreateParameter();
            pResponsavel.ParameterName = "@responsavel";
            pResponsavel.Value = responsavel ?? (object)DBNull.Value;
            cmd.Parameters.Add(pResponsavel);

            var pObs = cmd.CreateParameter();
            pObs.ParameterName = "@observacoes";
            pObs.Value = observacoes ?? (object)DBNull.Value;
            cmd.Parameters.Add(pObs);

            cmd.ExecuteNonQuery();

            // Debitar produtos do estoque (apenas os com debita_estoque = true)
            foreach (var item in composicao.Where(x => x.DebitaEstoque))
            {
                var quantidadeTotal = (int)Math.Ceiling(item.Quantidade * quantidade);
                // Pass responsavel and copao name as 'saida'
                RegistrarSaidaEstoque(conn, transaction, item.ProductId, quantidadeTotal, "Venda Copão", responsavel ?? "", copao.Nome);
            }

            transaction.Commit();
            return true;
        }
        catch
        {
            transaction.Rollback();
            throw;
        }
    }

    // ==================== VALIDAÇÕES ====================

    public List<string> ValidarQuantidadeEstoque(List<CopaoComposicao> composicao, int quantidadeCopoesVenda)
    {
        var erros = new List<string>();
        var estoqueRepo = new EstoqueRepository(_dbService);
        var estoque = estoqueRepo.CarregarEstoqueCompleto();

        foreach (var item in composicao)
        {
            // Only validate items that actually debit stock
            if (!item.DebitaEstoque)
                continue;

            var produtoEstoque = estoque.FirstOrDefault(x => x.ProductId == item.ProductId);

            if (produtoEstoque == null)
            {
                erros.Add($"Produto {item.ProdutoDescricao} não encontrado no estoque");
                continue;
            }

            // For items that debit stock, we consume 1 unit per copão sold
            var quantidadeNecessaria = quantidadeCopoesVenda; // 1 unit per copão

            // Compare in product units
            if (produtoEstoque.Quantidade < quantidadeNecessaria)
            {
                erros.Add($"Insuficiente {item.ProdutoDescricao}: precisa de {quantidadeNecessaria}, tem {produtoEstoque.Quantidade}");
            }
        }

        return erros;
    }

    public bool ValidarNomeDuplicado(string nome)
    {
        using var conn = _dbService.GetConnection();
        using var cmd = conn.CreateCommand();
        cmd.CommandText = "SELECT COUNT(*) FROM copoes WHERE nome = @nome";

        var param = cmd.CreateParameter();
        param.ParameterName = "@nome";
        param.Value = nome;
        cmd.Parameters.Add(param);

        var resultado = Convert.ToInt32(cmd.ExecuteScalar());
        return resultado > 0;
    }

    // ==================== HISTÓRICO ====================

    public List<CopaoVenda> CarregarHistoricoVendas(int? mes = null, int? ano = null)
    {
        var lista = new List<CopaoVenda>();
        using var conn = _dbService.GetConnection();
        using var cmd = conn.CreateCommand();

        string queryWhere = "";
        if (mes.HasValue && ano.HasValue)
        {
            if (conn is Npgsql.NpgsqlConnection)
                queryWhere = " WHERE EXTRACT(MONTH FROM cv.data_venda)::int = @mes AND EXTRACT(YEAR FROM cv.data_venda)::int = @ano";
            else
                queryWhere = " WHERE strftime('%m', cv.data_venda) = @mes AND strftime('%Y', cv.data_venda) = @ano";
        }

        cmd.CommandText = @"
            SELECT 
                cv.venda_id, cv.copao_id, cv.quantidade, cv.preco_unitario, 
                cv.preco_total, cv.data_venda, cv.responsavel, cv.observacoes,
                c.nome
            FROM copao_vendas cv
            LEFT JOIN copoes c ON cv.copao_id = c.copao_id" + queryWhere + @"
            ORDER BY cv.data_venda DESC";

        if (mes.HasValue && ano.HasValue)
        {
            var pMes = cmd.CreateParameter();
            pMes.ParameterName = "@mes";
            pMes.Value = mes.Value;  // Enviar como INT, não como TEXT
            cmd.Parameters.Add(pMes);

            var pAno = cmd.CreateParameter();
            pAno.ParameterName = "@ano";
            pAno.Value = ano.Value;  // Enviar como INT
            cmd.Parameters.Add(pAno);
        }

        using var reader = cmd.ExecuteReader();
        while (reader.Read())
        {
            lista.Add(new CopaoVenda
            {
                VendaId = reader.GetInt32(0),
                CopaoId = reader.GetInt32(1),
                Quantidade = reader.GetInt32(2),
                PrecoUnitario = reader.GetDecimal(3),
                PrecoTotal = reader.GetDecimal(4),
                DataVenda = reader.GetDateTime(5),
                Responsavel = reader.IsDBNull(6) ? null : reader.GetString(6),
                Observacoes = reader.IsDBNull(7) ? null : reader.GetString(7),
                NomeCopao = reader.IsDBNull(8) ? "Copão removido" : reader.GetString(8)
            });
        }
        return lista;
    }

