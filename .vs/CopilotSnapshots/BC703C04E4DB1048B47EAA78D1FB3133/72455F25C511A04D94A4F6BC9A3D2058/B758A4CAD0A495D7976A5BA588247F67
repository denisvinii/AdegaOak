using System.Windows;
using System.Windows.Controls;
using System.Windows.Media;

namespace Adega_Oak.Views;

public class PasswordPromptWindow : Window
{
    private PasswordBox _passwordBox;
    public string? EnteredPassword { get; private set; }

    public PasswordPromptWindow()
    {
        Title = "Confirmação";
        Width = 360;
        Height = 170;
        WindowStartupLocation = WindowStartupLocation.CenterOwner;
        ResizeMode = ResizeMode.NoResize;
        WindowStyle = WindowStyle.SingleBorderWindow;

        var grid = new Grid { Background = new SolidColorBrush(Color.FromRgb(45, 45, 45)), Margin = new Thickness(12) };
        grid.RowDefinitions.Add(new RowDefinition { Height = GridLength.Auto });
        grid.RowDefinitions.Add(new RowDefinition { Height = GridLength.Auto });
        grid.RowDefinitions.Add(new RowDefinition { Height = new GridLength(1, GridUnitType.Star) });

        var txt = new TextBlock
        {
            Text = "Digite a senha para confirmar a exclusão:",
            Foreground = Brushes.White,
            Margin = new Thickness(0, 0, 0, 8)
        };
        Grid.SetRow(txt, 0);
        grid.Children.Add(txt);

        _passwordBox = new PasswordBox
        {
            MinHeight = 32,
            Padding = new Thickness(6),
            Background = new SolidColorBrush(Color.FromRgb(53, 53, 53)),
            Foreground = Brushes.White
        };
        Grid.SetRow(_passwordBox, 1);
        grid.Children.Add(_passwordBox);

        var stack = new StackPanel
        {
            Orientation = Orientation.Horizontal,
            HorizontalAlignment = HorizontalAlignment.Right,
            Margin = new Thickness(0, 12, 0, 0)
        };

        var cancelBtn = new Button
        {
            Content = "Cancelar",
            Width = 90,
            Margin = new Thickness(0, 0, 8, 0),
            Padding = new Thickness(6)
        };
        cancelBtn.Click += CancelBtn_Click;

        var okBtn = new Button
        {
            Content = "Confirmar",
            Width = 100,
            Padding = new Thickness(6)
        };
        okBtn.Click += OkBtn_Click;

        stack.Children.Add(cancelBtn);
        stack.Children.Add(okBtn);

        Grid.SetRow(stack, 2);
        grid.Children.Add(stack);

        Content = grid;
    }

    private void OkBtn_Click(object? sender, RoutedEventArgs e)
    {
        EnteredPassword = _passwordBox.Password;
        DialogResult = true;
        Close();
    }

    private void CancelBtn_Click(object? sender, RoutedEventArgs e)
    {
        DialogResult = false;
        Close();
    }
}
