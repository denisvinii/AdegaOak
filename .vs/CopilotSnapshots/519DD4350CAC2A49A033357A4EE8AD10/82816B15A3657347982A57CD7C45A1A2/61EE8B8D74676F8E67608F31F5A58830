using Adega_Oak.Repositories;
using CommunityToolkit.Mvvm.ComponentModel;
using CommunityToolkit.Mvvm.Input;
using System.Collections.ObjectModel;
using System.Linq;

namespace Adega_Oak.Features.Copoes;

public partial class CopaoViewModel : ObservableObject
{
    private readonly CopaoRepository _copaoRepository;
    private readonly EstoqueRepository _estoqueRepository;
    private readonly MainRepository _mainRepository;

    [ObservableProperty]
    private ObservableCollection<CopaoRepository.Copao> copoes = new();

    [ObservableProperty]
    private CopaoRepository.Copao? copaoSelecionado;

    [ObservableProperty]
    private ObservableCollection<CopaoRepository.CopaoComposicao> produtosComposicao = new();

    // Formulário - Novo/Editar Copão
    [ObservableProperty]
    private string nomeCopao = string.Empty;

    [ObservableProperty]
    private decimal precoCopao = 0;

    [ObservableProperty]
    private string descricaoCopao = string.Empty;

    [ObservableProperty]
    private bool emEdicao = false;

    // Composição - Adicionar Produto
    private ObservableCollection<MainRepository.Produto> _produtos = new();
    public ObservableCollection<MainRepository.Produto> Produtos
    {
        get => _produtos;
        set => SetProperty(ref _produtos, value);
    }

    private MainRepository.Produto? _produtoSelecionado;
    public MainRepository.Produto? ProdutoSelecionado
    {
        get => _produtoSelecionado;
        set => SetProperty(ref _produtoSelecionado, value);
    }

    private ObservableCollection<MainRepository.Produto> _produtosFiltrados = new();
    public ObservableCollection<MainRepository.Produto> ProdutosFiltrados
    {
        get => _produtosFiltrados;
        set => SetProperty(ref _produtosFiltrados, value);
    }

    private string? _produtoFiltroTexto;
    public string? ProdutoFiltroTexto
    {
        get => _produtoFiltroTexto;
        set
        {
            if (SetProperty(ref _produtoFiltroTexto, value))
            {
                FiltrarProdutos(value);
            }
        }
    }

    [ObservableProperty]
    private decimal quantidadeProduto = 0.05m;

    [ObservableProperty]
    private string unidadeSelecionada = "L";

    [ObservableProperty]
    private bool debitaEstoque = false;

    private static readonly List<string> UnidadesPossiveis = new() { "L", "ml", "un", "g" };
    public List<string> Unidades => UnidadesPossiveis;

    [ObservableProperty]
    private string? mensagemErro;

    [ObservableProperty]
    private bool temErro = false;

    public CopaoViewModel(CopaoRepository copaoRepository, EstoqueRepository estoqueRepository, MainRepository mainRepository)
    {
        _copaoRepository = copaoRepository;
        _estoqueRepository = estoqueRepository;
        _mainRepository = mainRepository;

        CarregarCopoes();
        CarregarProdutosEstoque();
    }

    [RelayCommand]
    public void CarregarCopoes()
    {
        var copoesCarregadas = _copaoRepository.CarregarCopoes(apenasAtivos: true);
        Copoes.Clear();
        foreach (var copao in copoesCarregadas)
        {
            Copoes.Add(copao);
        }
        LimparFormulario();
        MensagemErro = null;
        TemErro = false;
    }

    [RelayCommand]
    public void SelecionarCopao(CopaoRepository.Copao copao)
    {
        CopaoSelecionado = copao;
        NomeCopao = copao.Nome;
        PrecoCopao = copao.PrecoVenda;
        DescricaoCopao = copao.Descricao ?? "";

        // Carrega composição do copão
        var composicao = _copaoRepository.CarregarComposicao(copao.CopaoId);
        ProdutosComposicao.Clear();
        foreach (var item in composicao)
        {
            ProdutosComposicao.Add(item);
        }

        EmEdicao = true;
        MensagemErro = null;
        TemErro = false;
    }

    [RelayCommand]
    public void NovoComposicao()
    {
        LimparFormulario();
        EmEdicao = false;
        MensagemErro = null;
        TemErro = false;
    }

    [RelayCommand]
    public void CarregarProdutosEstoque()
    {
        var produtosCarregados = _mainRepository.CarregarProdutos();
        Produtos = new ObservableCollection<MainRepository.Produto>(produtosCarregados);
        ProdutosFiltrados = new ObservableCollection<MainRepository.Produto>(Produtos);
    }

    private void FiltrarProdutos(string? filtro)
    {
        ProdutosFiltrados.Clear();

        if (string.IsNullOrWhiteSpace(filtro))
        {
            foreach (var produto in Produtos)
            {
                ProdutosFiltrados.Add(produto);
            }
            return;
        }

        var filtroLower = filtro.ToLower();
        foreach (var produto in Produtos)
        {
            if ((produto.Bebida?.ToLower().Contains(filtroLower) ?? false) ||
                (produto.Tamanho?.ToLower().Contains(filtroLower) ?? false) ||
                (produto.Material?.ToLower().Contains(filtroLower) ?? false))
            {
                ProdutosFiltrados.Add(produto);
            }
        }
    }

    [RelayCommand]
    public void AdicionarProdutoComposicao()
    {
        if (ProdutoSelecionado == null)
        {
            TemErro = true;
            MensagemErro = "Selecione um produto";
            return;
        }

        if (QuantidadeProduto <= 0)
        {
            TemErro = true;
            MensagemErro = "Quantidade deve ser maior que zero";
            return;
        }

        // Verifica se produto já está na composição
        var jaExiste = ProdutosComposicao.Any(x => x.ProductId == ProdutoSelecionado.ProductId);
        if (jaExiste)
        {
            TemErro = true;
            MensagemErro = "Este produto já foi adicionado à composição";
            return;
        }

        var novoItem = new CopaoRepository.CopaoComposicao
        {
            ProductId = ProdutoSelecionado.ProductId,
            Quantidade = QuantidadeProduto,
            Unidade = UnidadeSelecionada,
            DebitaEstoque = DebitaEstoque,
            ProdutoDescricao = ProdutoSelecionado.Descricao
        };

        ProdutosComposicao.Add(novoItem);
        LimparCamposComposicao();
        TemErro = false;
        MensagemErro = null;
    }

    [RelayCommand]
    public void RemoverProdutoComposicao(CopaoRepository.CopaoComposicao item)
    {
        ProdutosComposicao.Remove(item);
    }

    [RelayCommand]
    public void SalvarCopao()
    {
        // Validações
        if (string.IsNullOrWhiteSpace(NomeCopao))
        {
            TemErro = true;
            MensagemErro = "Nome do copão é obrigatório";
            return;
        }

        if (PrecoCopao <= 0)
        {
            TemErro = true;
            MensagemErro = "Preço deve ser maior que zero";
            return;
        }

        if (ProdutosComposicao.Count == 0)
        {
            TemErro = true;
            MensagemErro = "Adicione pelo menos um produto à composição";
            return;
        }

        try
        {
            var copao = new CopaoRepository.Copao
            {
                CopaoId = CopaoSelecionado?.CopaoId ?? 0,
                Nome = NomeCopao,
                Descricao = descricaoCopao,
                PrecoVenda = PrecoCopao,
                Ativo = true
            };

            var composicao = ProdutosComposicao.ToList();

            if (EmEdicao && CopaoSelecionado != null)
            {
                _copaoRepository.EditarCopao(copao, composicao);
                System.Windows.MessageBox.Show("Copão editado com sucesso!", "Sucesso", System.Windows.MessageBoxButton.OK, System.Windows.MessageBoxImage.Information);
            }
            else
            {
                _copaoRepository.CriarCopao(copao, composicao);
                System.Windows.MessageBox.Show("Copão criado com sucesso!", "Sucesso", System.Windows.MessageBoxButton.OK, System.Windows.MessageBoxImage.Information);
            }

            CarregarCopoes();
            LimparFormulario();
        }
        catch (Exception ex)
        {
            TemErro = true;
            MensagemErro = $"Erro: {ex.Message}";
        }
    }

    [RelayCommand]
    public void RemoverCopao()
    {
        if (CopaoSelecionado == null)
        {
            TemErro = true;
            MensagemErro = "Selecione um copão para remover";
            return;
        }

        var resultado = System.Windows.MessageBox.Show(
            $"Tem certeza que deseja remover '{NomeCopao}'?",
            "Confirmar Remoção",
            System.Windows.MessageBoxButton.YesNo,
            System.Windows.MessageBoxImage.Question);

        if (resultado != System.Windows.MessageBoxResult.Yes)
            return;

        try
        {
            _copaoRepository.RemoverCopao(CopaoSelecionado.CopaoId);
            System.Windows.MessageBox.Show("Copão removido com sucesso!", "Sucesso", System.Windows.MessageBoxButton.OK, System.Windows.MessageBoxImage.Information);
            CarregarCopoes();
        }
        catch (Exception ex)
        {
            TemErro = true;
            MensagemErro = $"Erro: {ex.Message}";
        }
    }

    private void LimparFormulario()
    {
        NomeCopao = string.Empty;
        PrecoCopao = 0;
        DescricaoCopao = string.Empty;
        CopaoSelecionado = null;
        EmEdicao = false;
        ProdutosComposicao.Clear();
        LimparCamposComposicao();
    }

    private void LimparCamposComposicao()
    {
        ProdutoSelecionado = null;
        ProdutoFiltroTexto = null;
        QuantidadeProduto = 0.05m;
        UnidadeSelecionada = "L";
        DebitaEstoque = false;
    }
}
