<UserControl x:Class="Adega_Oak.Views.CopaoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1200">
    <Grid Background="#1A1A1A">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Painel Esquerdo - Formulário -->
        <Border Grid.Column="0" Background="#2D2D2D" BorderBrush="#AAAAAA" BorderThickness="0,0,2,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <!-- Título -->
                    <TextBlock Text="Copões" FontSize="20" FontWeight="Bold" Foreground="#E65100" Margin="0,0,0,20"/>

                    <!-- Nome -->
                    <TextBlock Text="Nome do Copão" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Border Background="#353535" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="6" Padding="1" Margin="0,0,0,16">
                        <TextBox Background="#353535" Foreground="#FFFFFF" BorderThickness="0"
                                 Text="{Binding NomeCopao, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="11" MinHeight="40"/>
                    </Border>

                    <!-- Preço -->
                    <TextBlock Text="Preço (R$)" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Border Background="#353535" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="6" Padding="1" Margin="0,0,0,16">
                        <TextBox Background="#353535" Foreground="#FFFFFF" BorderThickness="0"
                                 Text="{Binding PrecoCopao, Mode=TwoWay, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="11" MinHeight="40"/>
                    </Border>

                    <!-- Descrição -->
                    <TextBlock Text="Descrição (Opcional)" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Border Background="#353535" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="6" Padding="1" Margin="0,0,0,16">
                        <TextBox Background="#353535" Foreground="#FFFFFF" BorderThickness="0"
                                 Text="{Binding DescricaoCopao, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="11" MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                    </Border>

                    <!-- Produtos -->
                    <TextBlock Text="Produtos" Foreground="#E65100" FontWeight="Bold" Margin="0,10,0,8"/>
                    
                    <TextBlock Text="Selecionar Produto" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding ProdutosFiltrados}"
                             SelectedItem="{Binding ProdutoSelecionado, Mode=TwoWay}"
                             DisplayMemberPath="Descricao"
                             Background="#353535" Foreground="#FFFFFF" BorderBrush="#AAAAAA"
                             IsEditable="True"
                             Text="{Binding ProdutoFiltroTexto, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                             Padding="11" MinHeight="40" Margin="0,0,0,12"/>

                    <TextBlock Text="Quantidade" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Border Background="#353535" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="6" Padding="1" Margin="0,0,0,12">
                        <TextBox Background="#353535" Foreground="#FFFFFF" BorderThickness="0"
                                 Text="{Binding QuantidadeProduto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="11" MinHeight="40"/>
                    </Border>

                    <TextBlock Text="Unidade" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding Unidades}"
                             SelectedItem="{Binding UnidadeSelecionada}"
                             Background="#353535" Foreground="#FFFFFF" BorderBrush="#AAAAAA"
                             Padding="11" MinHeight="40" Margin="0,0,0,12"/>

                    <!-- Debita Estoque -->
                    <CheckBox Content="Debita Estoque"
                             IsChecked="{Binding DebitaEstoque, Mode=TwoWay}"
                             Foreground="#FFFFFF" Margin="0,0,0,16"/>

                    <Button Content="Adicionar Produto"
                           Command="{Binding AdicionarProdutoComposicaoCommand}"
                           Background="#E65100" Foreground="White" FontWeight="Bold"
                           Padding="12,12" Margin="0,0,0,16" Cursor="Hand" MinHeight="40">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D84A00"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Mensagem de erro -->
                    <TextBlock Text="{Binding MensagemErro}" Foreground="#FF4444" 
                              Visibility="{Binding TemErro, Converter={StaticResource BoolToVisibilityConverter}}"
                              TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <!-- Botões -->
                    <Button Content="Salvar Copão"
                           Command="{Binding SalvarCopaoCommand}"
                           Background="#E65100" Foreground="White" FontWeight="Bold" FontSize="14"
                           Padding="12,12" Margin="0,0,0,10" Cursor="Hand" MinHeight="42">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D84A00"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="Novo Copão"
                           Command="{Binding NovoComposicaoCommand}"
                           Background="#353535" Foreground="#E65100" FontWeight="Bold"
                           Padding="12,12" Cursor="Hand" MinHeight="40">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#454545"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Painel Direito - Histórico/Lista -->
        <Border Grid.Column="1" Background="#1A1A1A">
            <StackPanel Margin="20">
                <TextBlock Text="Copões Cadastrados" FontSize="18" FontWeight="Bold" Foreground="#E65100" Margin="0,0,0,15"/>

                <ListBox ItemsSource="{Binding Copoes}"
                        Background="#2D2D2D" Foreground="#FFFFFF"
                        BorderBrush="#555555" BorderThickness="1"
                        Height="400" Margin="0,0,0,15">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" Background="#353535" Margin="0,5">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="{Binding Nome}" FontWeight="Bold" Foreground="#E65100" Width="150"/>
                                        <TextBlock Text="{Binding PrecoVenda, StringFormat=R$ {0:F2}}" Foreground="#90EE90"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Descricao}" Foreground="#BBBBBB" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
