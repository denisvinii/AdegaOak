    public void RemoverCombo(int comboId)
    {
        var vendas = CarregarHistoricoVendasPorCombo(comboId);
        if (vendas.Any())
            throw new InvalidOperationException("Não é possível remover um combo que já foi vendido");

        using var conn = _dbService.GetConnection();
        if (conn.State != ConnectionState.Open)
            conn.Open();

        using var cmd = conn.CreateCommand();
        cmd.CommandText = "DELETE FROM combos WHERE combo_id = @comboId";

        var param = cmd.CreateParameter();
        param.ParameterName = "@comboId";
        param.Value = comboId;
        cmd.Parameters.Add(param);

        cmd.ExecuteNonQuery();
    }

