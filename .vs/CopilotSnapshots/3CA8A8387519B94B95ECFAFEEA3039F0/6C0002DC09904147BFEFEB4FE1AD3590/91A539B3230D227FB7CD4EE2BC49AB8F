    private List<Combo> CarregarTodosCombosECopoes(bool apenasAtivos = false)
    {
        var lista = new List<Combo>();
        using var conn = _dbService.GetConnection();
        if (conn.State != ConnectionState.Open)
            conn.Open();
        using var cmd = conn.CreateCommand();

        if (apenasAtivos)
            cmd.CommandText = "SELECT combo_id, nome, descricao, preco_venda, ativo, data_criacao FROM combos WHERE ativo = true ORDER BY nome";
        else
            cmd.CommandText = "SELECT combo_id, nome, descricao, preco_venda, ativo, data_criacao FROM combos ORDER BY nome";

        using var reader = cmd.ExecuteReader();
        while (reader.Read())
        {
            var combo = new Combo
            {
                ComboId = reader.GetInt32(0),
                Nome = reader.GetString(1),
                Descricao = reader.IsDBNull(2) ? null : reader.GetString(2),
                PrecoVenda = reader.GetDecimal(3),
                Ativo = reader.GetBoolean(4),
                DataCriacao = reader.GetDateTime(5)
            };

            combo.Composicao = CarregarComposicao(combo.ComboId);
            lista.Add(combo);
        }
        return lista;
    }

