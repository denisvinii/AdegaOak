    // ==================== CRIAR/EDITAR ====================

    public int CriarCombo(Combo combo, List<ComboComposicao> composicao)
    {
        if (string.IsNullOrWhiteSpace(combo.Nome))
            throw new ArgumentException("Nome do combo é obrigatório");

        if (combo.PrecoVenda <= 0)
            throw new ArgumentException("Preço deve ser maior que zero");

        if (composicao == null || composicao.Count == 0)
            throw new ArgumentException("Combo deve ter pelo menos um produto");

        if (ValidarNomeDuplicado(combo.Nome))
            throw new InvalidOperationException($"Já existe um combo com o nome '{combo.Nome}'");

        using var conn = _dbService.GetConnection();
        if (conn.State != ConnectionState.Open)
            conn.Open();

        using var transaction = conn.BeginTransaction();

        try
        {
            using var cmd = conn.CreateCommand();

            if (conn is Npgsql.NpgsqlConnection)
                cmd.CommandText = @"
                    INSERT INTO combos (nome, descricao, preco_venda, ativo)
                    VALUES (@nome, @descricao, @precoVenda, @ativo)
                    RETURNING combo_id;";
            else
                cmd.CommandText = @"
                    INSERT INTO combos (nome, descricao, preco_venda, ativo)
                    VALUES (@nome, @descricao, @precoVenda, @ativo);
                    SELECT last_insert_rowid();";

            cmd.Transaction = transaction;

            var paramNome = cmd.CreateParameter();
            paramNome.ParameterName = "@nome";
            paramNome.Value = combo.Nome;
            cmd.Parameters.Add(paramNome);

            var paramDesc = cmd.CreateParameter();
            paramDesc.ParameterName = "@descricao";
            paramDesc.Value = combo.Descricao ?? (object)DBNull.Value;
            cmd.Parameters.Add(paramDesc);

            var paramPreco = cmd.CreateParameter();
            paramPreco.ParameterName = "@precoVenda";
            paramPreco.Value = combo.PrecoVenda;
            cmd.Parameters.Add(paramPreco);

            var paramAtivo = cmd.CreateParameter();
            paramAtivo.ParameterName = "@ativo";
            paramAtivo.Value = combo.Ativo;
            cmd.Parameters.Add(paramAtivo);

            var comboId = Convert.ToInt32(cmd.ExecuteScalar());

            foreach (var item in composicao)
            {
                var cmdComp = conn.CreateCommand();
                cmdComp.CommandText = @"
                    INSERT INTO combo_composicao (combo_id, product_id, quantidade, unidade, debita_estoque)
                    VALUES (@comboId, @productId, @quantidade, @unidade, @debitaEstoque)";

                cmdComp.Transaction = transaction;

                var pComboId = cmdComp.CreateParameter();
                pComboId.ParameterName = "@comboId";
                pComboId.Value = comboId;
                cmdComp.Parameters.Add(pComboId);

                var pProductId = cmdComp.CreateParameter();
                pProductId.ParameterName = "@productId";
                pProductId.Value = item.ProductId;
                cmdComp.Parameters.Add(pProductId);

                var pQtd = cmdComp.CreateParameter();
                pQtd.ParameterName = "@quantidade";
                pQtd.Value = item.Quantidade;
                cmdComp.Parameters.Add(pQtd);

                var pUnidade = cmdComp.CreateParameter();
                pUnidade.ParameterName = "@unidade";
                pUnidade.Value = item.Unidade;
                cmdComp.Parameters.Add(pUnidade);

                var pDebita = cmdComp.CreateParameter();
                pDebita.ParameterName = "@debitaEstoque";
                pDebita.Value = item.DebitaEstoque;
                cmdComp.Parameters.Add(pDebita);

                cmdComp.ExecuteNonQuery();
            }

            transaction.Commit();
            return comboId;
        }
        catch
        {
            transaction.Rollback();
            throw;
        }
    }

