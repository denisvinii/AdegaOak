    public (int Normal, int ValorZero, decimal TotalNormal, decimal TotalValorZero) ObterEstatisticasMovimento()
    {
        using var conn = _dbService.GetConnection();
        using var cmd = conn.CreateCommand();

        cmd.CommandText = @"
            SELECT 
                SUM(CASE WHEN tipo_movimento = 'Normal' OR tipo_movimento IS NULL THEN 1 ELSE 0 END) as qtd_normal,
                SUM(CASE WHEN tipo_movimento = 'ValorZero' THEN 1 ELSE 0 END) as qtd_valorzero,
                SUM(CASE WHEN tipo_movimento = 'Normal' OR tipo_movimento IS NULL THEN preco_total ELSE 0 END) as total_normal,
                SUM(CASE WHEN tipo_movimento = 'ValorZero' THEN preco_total ELSE 0 END) as total_valorzero
            FROM combo_vendas";

        using var reader = cmd.ExecuteReader();
        if (reader.Read())
        {
            int qtdNormal = reader.IsDBNull(0) ? 0 : Convert.ToInt32(reader.GetValue(0));
            int qtdValorZero = reader.IsDBNull(1) ? 0 : Convert.ToInt32(reader.GetValue(1));
            decimal totalNormal = reader.IsDBNull(2) ? 0 : Convert.ToDecimal(reader.GetValue(2));
            decimal totalValorZero = reader.IsDBNull(3) ? 0 : Convert.ToDecimal(reader.GetValue(3));

            return (qtdNormal, qtdValorZero, totalNormal, totalValorZero);
        }

        return (0, 0, 0, 0);
    }

