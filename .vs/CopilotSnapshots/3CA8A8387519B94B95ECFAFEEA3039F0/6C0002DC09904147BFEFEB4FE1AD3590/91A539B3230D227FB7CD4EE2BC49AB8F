    public decimal ObterTotalVendidoPeriodo(int mes, int ano)
    {
        using var conn = _dbService.GetConnection();
        using var cmd = conn.CreateCommand();

        if (conn is Npgsql.NpgsqlConnection)
            cmd.CommandText = @"
                SELECT COALESCE(SUM(preco_total), 0) 
                FROM combo_vendas 
                WHERE EXTRACT(MONTH FROM data_venda)::int = @mes 
                AND EXTRACT(YEAR FROM data_venda)::int = @ano";
        else
            cmd.CommandText = @"
                SELECT COALESCE(SUM(preco_total), 0) 
                FROM combo_vendas 
                WHERE strftime('%m', data_venda) = @mes 
                AND strftime('%Y', data_venda) = @ano";

        var pMes = cmd.CreateParameter();
        pMes.ParameterName = "@mes";
        pMes.Value = mes;
        cmd.Parameters.Add(pMes);

        var pAno = cmd.CreateParameter();
        pAno.ParameterName = "@ano";
        pAno.Value = ano;
        cmd.Parameters.Add(pAno);

        var resultado = cmd.ExecuteScalar();
        return resultado != null ? Convert.ToDecimal(resultado) : 0;
    }

    // ==================== HELPERS ====================

    private void RegistrarSaidaEstoque(IDbConnection conn, IDbTransaction transaction, int productId, int quantidade, string tipo, string responsavel, string? saida)
    {
        string produtoDescricao = "";
        try
        {
            using var cmdSel = conn.CreateCommand();
            cmdSel.CommandText = "SELECT bebida, tamanho, material FROM estoque WHERE productid = @productId";
            var p = cmdSel.CreateParameter();
            p.ParameterName = "@productId";
            p.Value = productId;
            cmdSel.Parameters.Add(p);

            using var rdr = cmdSel.ExecuteReader();
            if (rdr.Read())
            {
                var bebida = rdr.IsDBNull(0) ? "" : rdr.GetString(0);
                var tamanho = rdr.IsDBNull(1) ? "" : rdr.GetString(1);
                var material = rdr.IsDBNull(2) ? "" : rdr.GetString(2);
                produtoDescricao = string.Join(" - ", new[] { bebida, tamanho, material }.Where(s => !string.IsNullOrWhiteSpace(s)));
            }
        }
        catch { }

        var cmd = conn.CreateCommand();
