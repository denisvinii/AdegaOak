    // ==================== COMUM ====================

    private void CarregarProdutosEstoque()
    {
        var produtos = _estoqueRepository.CarregarEstoqueCompleto();
        ProdutosFiltrados = new ObservableCollection<MainRepository.Produto>(
            _mainRepository.CarregarProdutos()
        );
    }

    private void FiltrarProdutos()
    {
        if (string.IsNullOrWhiteSpace(ProdutoFiltroTexto))
        {
            ProdutosFiltrados = new ObservableCollection<MainRepository.Produto>(_mainRepository.CarregarProdutos());
            return;
        }

        var filtrados = _mainRepository.CarregarProdutos()
            .Where(p => p.Descricao.Contains(ProdutoFiltroTexto, StringComparison.OrdinalIgnoreCase))
            .ToList();

        ProdutosFiltrados = new ObservableCollection<MainRepository.Produto>(filtrados);
    }

    private void AtualizarCombosFiltrados()
    {
        if (string.IsNullOrWhiteSpace(FiltroCombo))
        {
            CombosFiltrados = new ObservableCollection<ComboRepository.Combo>(Combos);
        }
        else
        {
            var filtrados = Combos
                .Where(c => c.Nome.Contains(FiltroCombo, StringComparison.OrdinalIgnoreCase))
                .ToList();

            CombosFiltrados = new ObservableCollection<ComboRepository.Combo>(filtrados);
        }
    }

    private void AtualizarCopoesFiltrados()
    {
        if (string.IsNullOrWhiteSpace(FiltroCopao))
        {
            CopoesFiltradas = new ObservableCollection<ComboRepository.Combo>(Copoes);
        }
        else
        {
            var filtrados = Copoes
                .Where(c => c.Nome.Contains(FiltroCopao, StringComparison.OrdinalIgnoreCase))
                .ToList();

            CopoesFiltradas = new ObservableCollection<ComboRepository.Combo>(filtrados);
        }
