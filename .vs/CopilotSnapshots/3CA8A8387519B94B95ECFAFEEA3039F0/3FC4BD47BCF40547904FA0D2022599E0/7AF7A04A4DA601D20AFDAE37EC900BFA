    public ComboViewModel(ComboRepository comboRepository, EstoqueRepository estoqueRepository, MainRepository mainRepository)
    {
        _comboRepository = comboRepository;
        _estoqueRepository = estoqueRepository;
        _mainRepository = mainRepository;

        CarregarCombos();
        CarregarCopoes();
        CarregarProdutosEstoque();
    }

    // ==================== COMBOS ====================

    [RelayCommand]
    public void CarregarCombos()
    {
        var combosCarregados = _comboRepository.CarregarCombos(apenasAtivos: true);
        Combos.Clear();
        foreach (var combo in combosCarregados)
        {
            Combos.Add(combo);
        }
        AtualizarCombosFiltrados();
        LimparFormularioCombo();
        MensagemErro = null;
        TemErro = false;
    }

    [RelayCommand]
    public void SelecionarCombo(ComboRepository.Combo combo)
    {
        ComboSelecionado = combo;
        NomeCombo = combo.Nome;
        PrecoCombo = combo.PrecoVenda;
        DescricaoCombo = combo.Descricao ?? "";
        ProdutosComposicaoCombo.Clear();
        foreach (var item in combo.Composicao)
        {
           ProdutosComposicaoCombo.Add(item);
        }
        EmEdicaoCombo = true;
    }

    [RelayCommand]
    public void AdicionarProdutoComposicaoCombo()
    {
        if (ProdutoSelecionado == null)
        {
            MensagemErro = "Selecione um produto";
            TemErro = true;
            return;
        }

        if (QuantidadeProduto <= 0)
        {
            MensagemErro = "Quantidade deve ser maior que zero";
            TemErro = true;
            return;
        }

        var item = new ComboRepository.ComboComposicao
        {
            ProductId = ProdutoSelecionado.ProductId,
            Quantidade = QuantidadeProduto,
            Unidade = "ml",
            DebitaEstoque = true, // COMBO SEMPRE DEBITA
            ProdutoDescricao = ProdutoSelecionado.Descricao
        };

        ProdutosComposicaoCombo.Add(item);
        QuantidadeProduto = 0;
        DebitaEstoque = false;
        
        // Limpar seleção de produto
        ProdutoTextoSelecionado = string.Empty;
        ProdutoSelecionado = null;
        
        MensagemErro = null;
        TemErro = false;
    }

    [RelayCommand]
    public void RemoverProdutoComposicaoCombo(ComboRepository.ComboComposicao item)
    {
        ProdutosComposicaoCombo.Remove(item);
    }

    [RelayCommand]
    public void SalvarCombo()
    {
        if (string.IsNullOrWhiteSpace(NomeCombo))
        {
            MensagemErro = "Nome é obrigatório";
            TemErro = true;
            return;
        }

        if (PrecoCombo <= 0)
        {
            MensagemErro = "Preço deve ser maior que zero";
            TemErro = true;
            return;
        }

        if (ProdutosComposicaoCombo.Count == 0)
        {
            MensagemErro = "Adicione pelo menos um produto à composição";
            TemErro = true;
            return;
        }

        try
        {
            var combo = new ComboRepository.Combo
            {
                ComboId = ComboSelecionado?.ComboId ?? 0,
                Nome = NomeCombo,
                Descricao = DescricaoCombo,
                PrecoVenda = PrecoCombo,
                Ativo = true
            };

            var composicao = ProdutosComposicaoCombo.ToList();

            if (EmEdicaoCombo && ComboSelecionado != null)
            {
                _comboRepository.EditarCombo(combo, composicao);
                System.Windows.MessageBox.Show("Combo editado com sucesso!", "Sucesso", System.Windows.MessageBoxButton.OK, System.Windows.MessageBoxImage.Information);
            }
            else
            {
                _comboRepository.CriarCombo(combo, composicao);
                System.Windows.MessageBox.Show("Combo criado com sucesso!", "Sucesso", System.Windows.MessageBoxButton.OK, System.Windows.MessageBoxImage.Information);
            }

            CarregarCombos();
        }
        catch (Exception ex)
        {
            MensagemErro = $"Erro: {ex.Message}";
            TemErro = true;
        }
    }

    [RelayCommand]
    public void RemoverCombo(ComboRepository.Combo target)
    {
        var confirm = System.Windows.MessageBox.Show(
            $"Tem certeza que deseja remover '{target.Nome}'?",
            "Confirmar Remoção",
            System.Windows.MessageBoxButton.YesNo,
            System.Windows.MessageBoxImage.Warning);

        if (confirm != System.Windows.MessageBoxResult.Yes)
            return;

        try
        {
            _comboRepository.RemoverCombo(target.ComboId);
            System.Windows.MessageBox.Show("Combo removido com sucesso!", "Sucesso", System.Windows.MessageBoxButton.OK, System.Windows.MessageBoxImage.Information);
            CarregarCombos();
        }
        catch (Exception ex)
        {
            TemErro = true;
            MensagemErro = $"Erro: {ex.Message}";
        }
    }

