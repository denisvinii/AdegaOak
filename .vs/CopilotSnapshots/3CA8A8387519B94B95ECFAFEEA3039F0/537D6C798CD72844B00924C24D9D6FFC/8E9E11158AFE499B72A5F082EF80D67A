<UserControl x:Class="Adega_Oak.Views.ComboView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1200">
    <Grid Background="#1A1A1A">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Painel de Cadastro com Abas -->
        <Border Grid.Column="0" Background="#2D2D2D" BorderBrush="#AAAAAA" BorderThickness="0,0,2,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <!-- Seletor de Tipo -->
                    <TextBlock Text="Tipo de Cadastro" FontSize="14" FontWeight="Bold" Foreground="#E65100" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <RadioButton Content="Combo" Foreground="#FFFFFF" IsChecked="{Binding AbaTipoAtual, Converter={StaticResource IntToBoolConverter}, ConverterParameter=0}" Margin="0,0,20,0"/>
                        <RadioButton Content="Copao" Foreground="#FFFFFF" IsChecked="{Binding AbaTipoAtual, Converter={StaticResource IntToBoolConverter}, ConverterParameter=1}"/>
                    </StackPanel>

                    <!-- ===================== ABA COMBO ===================== -->
                    <StackPanel Visibility="{Binding AbaTipoAtual, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=0}">
                        <TextBlock Text="CADASTRO DE COMBO" FontSize="16" FontWeight="Bold" Foreground="#4CAF50" Margin="0,0,0,16" Background="#353535" Padding="12"/>
                        
                        <TextBlock Text="Combo: Venda com preco. Debita quantidade literal do estoque para cada item." Foreground="#90EE90" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,16" Background="#1a3a1a" Padding="10"/>

                        <TextBlock Text="Nome" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Border Background="#353535" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="6" Padding="1" Margin="0,0,0,16">
                            <TextBox Background="#353535" Foreground="#FFFFFF" BorderThickness="0"
                                     Text="{Binding NomeCombo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="11" MinHeight="40"/>
                        </Border>

                        <TextBlock Text="Preco" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Border Background="#353535" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="6" Padding="1" Margin="0,0,0,16">
                            <TextBox Background="#353535" Foreground="#FFFFFF" BorderThickness="0"
                                     Text="{Binding PrecoCombo, Mode=TwoWay, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="11" MinHeight="40"/>
                        </Border>

                        <TextBlock Text="Descricao" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Border Background="#353535" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="6" Padding="1" Margin="0,0,0,16">
                            <TextBox Background="#353535" Foreground="#FFFFFF" BorderThickness="0"
                                     Text="{Binding DescricaoCombo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="11" MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                        </Border>

                        <TextBlock Text="Selecionar Produto" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ComboBox x:Name="ProdutoComboBoxCombo"
                                 ItemsSource="{Binding ProdutosFiltrados}"
                                 SelectedItem="{Binding ProdutoSelecionado, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 DisplayMemberPath="Descricao"
                                 Background="#353535" Foreground="#FFFFFF" BorderBrush="#AAAAAA"
                                 IsEditable="True"
                                 Text="{Binding ProdutoFiltroTexto, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                 Padding="11" MinHeight="40" Margin="0,0,0,12"
                                 StaysOpenOnEdit="True"
                                 IsTextSearchEnabled="False"/>

                        <TextBlock Text="Quantidade (ml)" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Border Background="#353535" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="6" Padding="1" Margin="0,0,0,12">
                            <TextBox Background="#353535" Foreground="#FFFFFF" BorderThickness="0"
                                     Text="{Binding QuantidadeProduto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F0}"
                                     Padding="11" MinHeight="40"/>
                        </Border>

                        <TextBlock Text="NOTA: Combo sempre debita estoque" Foreground="#FFD700" FontSize="10" Margin="0,0,0,12"/>

                        <Button Content="Adicionar Produto"
                               Command="{Binding AdicionarProdutoComposicaoComboCommand}"
                               Background="#4CAF50" Foreground="White" FontWeight="Bold"
                               Padding="12,12" Margin="0,0,0,16" Cursor="Hand" MinHeight="40"/>

                        <TextBlock Text="{Binding MensagemErro}" Foreground="#FF4444" 
                                  Visibility="{Binding TemErro, Converter={StaticResource BoolToVisibilityConverter}}"
                                  TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <TextBlock Text="Produtos na Composicao" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,16,0,8"/>
                        <ListBox ItemsSource="{Binding ProdutosComposicaoCombo}"
                                Background="#353535" Foreground="#FFFFFF"
                                BorderBrush="#555555" BorderThickness="1"
                                Height="180" Margin="0,0,0,16">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" Background="#404040" Margin="0,2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding ProdutoDescricao}" FontWeight="Bold" Foreground="#90EE90" Margin="0,0,0,3"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                    <TextBlock Text="Qtd: " Foreground="#BBBBBB"/>
                                                    <TextBlock Text="{Binding Quantidade}" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                                    <TextBlock Text=" ml (Debita)" Foreground="#90EE90" FontWeight="Bold"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                   Content="Remover"
                                                   Command="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=DataContext.RemoverProdutoComposicaoComboCommand}"
                                                   CommandParameter="{Binding}"
                                                   Background="#8B0000" Foreground="White" 
                                                   Padding="8,4" FontSize="12"
                                                   Cursor="Hand" Height="28"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Content="Salvar Combo"
                               Command="{Binding SalvarComboCommand}"
                               Background="#4CAF50" Foreground="White" FontWeight="Bold" FontSize="14"
                               Padding="12,12" Margin="0,0,0,10" Cursor="Hand" MinHeight="42"/>

                        <Button Content="Novo Combo"
                               Command="{Binding NovoComboCommand}"
                               Background="#353535" Foreground="#4CAF50" FontWeight="Bold"
                               Padding="12,12" Cursor="Hand" MinHeight="40" Margin="0,0,0,30"/>
                    </StackPanel>

                    <!-- ===================== ABA COPAO ===================== -->
                    <StackPanel Visibility="{Binding AbaTipoAtual, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=1}">
                        <TextBlock Text="CADASTRO DE COPAO" FontSize="16" FontWeight="Bold" Foreground="#FF9800" Margin="0,0,0,16" Background="#353535" Padding="12"/>
                        
                        <TextBlock Text="Copao: Venda sem preco. Debita apenas itens marcados com flag true." Foreground="#FFD700" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,16" Background="#3a2800" Padding="10"/>

                        <TextBlock Text="Nome" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Border Background="#353535" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="6" Padding="1" Margin="0,0,0,16">
                            <TextBox Background="#353535" Foreground="#FFFFFF" BorderThickness="0"
                                     Text="{Binding NomeCopao, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="11" MinHeight="40"/>
                        </Border>

                        <TextBlock Text="Preco" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Border Background="#353535" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="6" Padding="1" Margin="0,0,0,16">
                            <TextBox Background="#353535" Foreground="#FFFFFF" BorderThickness="0"
                                     Text="{Binding PrecoCopao, Mode=TwoWay, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="11" MinHeight="40"/>
                        </Border>

                        <TextBlock Text="Descricao" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Border Background="#353535" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="6" Padding="1" Margin="0,0,0,16">
                            <TextBox Background="#353535" Foreground="#FFFFFF" BorderThickness="0"
                                     Text="{Binding DescricaoCopao, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="11" MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                        </Border>

                        <TextBlock Text="Selecionar Produto" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ComboBox x:Name="ProdutoComboBoxCopao"
                                 ItemsSource="{Binding ProdutosFiltrados}"
                                 SelectedItem="{Binding ProdutoSelecionado, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 DisplayMemberPath="Descricao"
                                 Background="#353535" Foreground="#FFFFFF" BorderBrush="#AAAAAA"
                                 IsEditable="True"
                                 Text="{Binding ProdutoFiltroTexto, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                 Padding="11" MinHeight="40" Margin="0,0,0,12"
                                 StaysOpenOnEdit="True"
                                 IsTextSearchEnabled="False"/>

                        <TextBlock Text="Quantidade (ml)" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Border Background="#353535" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="6" Padding="1" Margin="0,0,0,12">
                            <TextBox Background="#353535" Foreground="#FFFFFF" BorderThickness="0"
                                     Text="{Binding QuantidadeProduto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F0}"
                                     Padding="11" MinHeight="40"/>
                        </Border>

                        <CheckBox Content="Debita Estoque (marca para debitar este item)"
                                 IsChecked="{Binding DebitaEstoque, Mode=TwoWay}"
                                 Foreground="#FFFFFF" Margin="0,0,0,16" FontSize="11" FontWeight="SemiBold"/>

                        <Button Content="Adicionar Produto"
                               Command="{Binding AdicionarProdutoComposicaoCopaoCommand}"
                               Background="#FF9800" Foreground="White" FontWeight="Bold"
                               Padding="12,12" Margin="0,0,0,16" Cursor="Hand" MinHeight="40"/>

                        <TextBlock Text="{Binding MensagemErro}" Foreground="#FF4444" 
                                  Visibility="{Binding TemErro, Converter={StaticResource BoolToVisibilityConverter}}"
                                  TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <TextBlock Text="Produtos na Composicao" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,16,0,8"/>
                        <ListBox ItemsSource="{Binding ProdutosComposicaoCopao}"
                                Background="#353535" Foreground="#FFFFFF"
                                BorderBrush="#555555" BorderThickness="1"
                                Height="180" Margin="0,0,0,16">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" Background="#404040" Margin="0,2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding ProdutoDescricao}" FontWeight="Bold" Foreground="#FFD700" Margin="0,0,0,3"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                    <TextBlock Text="Qtd: " Foreground="#BBBBBB"/>
                                                    <TextBlock Text="{Binding Quantidade}" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                                    <TextBlock Text=" ml | Debita: " Foreground="#BBBBBB"/>
                                                    <TextBlock Text="{Binding DebitaEstoque}" Foreground="#FFD700" FontWeight="Bold"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                   Content="Remover"
                                                   Command="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=DataContext.RemoverProdutoComposicaoCopaoCommand}"
                                                   CommandParameter="{Binding}"
                                                   Background="#8B0000" Foreground="White" 
                                                   Padding="8,4" FontSize="12"
                                                   Cursor="Hand" Height="28"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Content="Salvar Copao"
                               Command="{Binding SalvarCopaoCommand}"
                               Background="#FF9800" Foreground="White" FontWeight="Bold" FontSize="14"
                               Padding="12,12" Margin="0,0,0,10" Cursor="Hand" MinHeight="42"/>

                        <Button Content="Novo Copao"
                               Command="{Binding NovoCopaoCommand}"
                               Background="#353535" Foreground="#FF9800" FontWeight="Bold"
                               Padding="12,12" Cursor="Hand" MinHeight="40"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Painel de Listagem -->
        <Border Grid.Column="1" Background="#1A1A1A">
            <StackPanel Margin="20">
                <!-- Abas de Listagem -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <RadioButton Content="Combos Cadastrados" Foreground="#FFFFFF" FontWeight="Bold" IsChecked="{Binding AbaTipoAtual, Converter={StaticResource IntToBoolConverter}, ConverterParameter=0}" Margin="0,0,40,0"/>
                    <RadioButton Content="Copoes Cadastrados" Foreground="#FFFFFF" FontWeight="Bold" IsChecked="{Binding AbaTipoAtual, Converter={StaticResource IntToBoolConverter}, ConverterParameter=1}"/>
                </StackPanel>

                <!-- LISTAGEM COMBOS -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Height="860" Visibility="{Binding AbaTipoAtual, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=0}">
                    <StackPanel>
                        <TextBlock Text="Combos Cadastrados" FontSize="18" FontWeight="Bold" Foreground="#4CAF50" Margin="0,0,0,15"/>
                        
                        <Border Background="#353535" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="6" Padding="1" Margin="0,0,0,16">
                            <TextBox Background="#353535" Foreground="#FFFFFF" BorderThickness="0"
                                     Text="{Binding FiltroCombo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="11" MinHeight="40" 
                                     Foreground="#CCCCCC" FontSize="12"/>
                        </Border>

                        <ItemsControl ItemsSource="{Binding CombosFiltrados}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12" Background="#2D2D2D" Margin="0,0,0,12" CornerRadius="8" BorderBrush="#4CAF50" BorderThickness="2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="{Binding Nome}" FontWeight="Bold" FontSize="14" Foreground="#4CAF50" Width="200"/>
                                                    <TextBlock Text="{Binding PrecoVenda, StringFormat=R$ {0:F2}}" Foreground="#90EE90" FontWeight="Bold" FontSize="13"/>
                                                </StackPanel>

                                                <TextBlock Text="{Binding Descricao}" Foreground="#BBBBBB" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                                <TextBlock Text="Composicao:" Foreground="#E0E0E0" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                <ItemsControl ItemsSource="{Binding Composicao}" Margin="0,0,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Padding="8" Background="#353535" Margin="0,0,0,4" CornerRadius="4">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    
                                                                    <StackPanel Grid.Column="0">
                                                                        <TextBlock Text="{Binding ProdutoDescricao}" Foreground="#90EE90" FontSize="10" FontWeight="SemiBold"/>
                                                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                                            <TextBlock Text="Qtd: " Foreground="#999999" FontSize="9"/>
                                                                            <TextBlock Text="{Binding Quantidade}" Foreground="#FFFFFF" FontSize="9" FontWeight="SemiBold"/>
                                                                            <TextBlock Text=" ml (Debita Sempre)" Foreground="#90EE90" FontSize="9" FontWeight="SemiBold"/>
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <Button Grid.Column="1"
                                                   Content="Editar"
                                                   Command="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl}, Path=DataContext.SelecionarComboCommand}"
                                                   CommandParameter="{Binding}"
                                                   Background="#4CAF50" Foreground="White" 
                                                   Padding="10,8" FontSize="12" FontWeight="Bold"
                                                   Cursor="Hand" Height="32" VerticalAlignment="Top" Margin="12,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- LISTAGEM COPOES -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Height="860" Visibility="{Binding AbaTipoAtual, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=1}">
                    <StackPanel>
                        <TextBlock Text="Copoes Cadastrados" FontSize="18" FontWeight="Bold" Foreground="#FF9800" Margin="0,0,0,15"/>
                        <ItemsControl ItemsSource="{Binding Copoes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12" Background="#2D2D2D" Margin="0,0,0,12" CornerRadius="8" BorderBrush="#FF9800" BorderThickness="2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="{Binding Nome}" FontWeight="Bold" FontSize="14" Foreground="#FF9800" Width="200"/>
                                                    <TextBlock Text="{Binding PrecoVenda, StringFormat=R$ {0:F2}}" Foreground="#FFD700" FontWeight="Bold" FontSize="13"/>
                                                </StackPanel>

                                                <TextBlock Text="{Binding Descricao}" Foreground="#BBBBBB" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                                <TextBlock Text="Composicao:" Foreground="#E0E0E0" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                <ItemsControl ItemsSource="{Binding Composicao}" Margin="0,0,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Padding="8" Background="#353535" Margin="0,0,0,4" CornerRadius="4">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    
                                                                    <StackPanel Grid.Column="0">
                                                                        <TextBlock Text="{Binding ProdutoDescricao}" Foreground="#FFD700" FontSize="10" FontWeight="SemiBold"/>
                                                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                                            <TextBlock Text="Qtd: " Foreground="#999999" FontSize="9"/>
                                                                            <TextBlock Text="{Binding Quantidade}" Foreground="#FFFFFF" FontSize="9" FontWeight="SemiBold"/>
                                                                            <TextBlock Text=" ml | Debita: " Foreground="#999999" FontSize="9"/>
                                                                            <TextBlock Text="{Binding DebitaEstoque}" Foreground="#FFD700" FontSize="9" FontWeight="SemiBold"/>
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <Button Grid.Column="1"
                                                   Content="Excluir"
                                                   Command="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl}, Path=DataContext.RemoverCopaoCommand}"
                                                   CommandParameter="{Binding}"
                                                   Background="#D32F2F" Foreground="White" 
                                                   Padding="10,8" FontSize="12" FontWeight="Bold"
                                                   Cursor="Hand" Height="32" VerticalAlignment="Top" Margin="12,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
