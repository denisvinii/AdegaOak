<UserControl x:Class="Adega_Oak.Views.TabelaPrecosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:Adega_Oak.Converters"
             mc:Ignorable="d"
             Background="{DynamicResource MaterialDesignPaper}">

    <UserControl.Resources>
        <converters:LessThanZeroConverter x:Key="LessThanZeroConverter"/>
        <converters:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter"/>
        
        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource MaterialDesignDarkBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignDivider}"/>
        </Style>

        <Style x:Key="EditableFieldStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
        </Style>

        <Style x:Key="PriceTextStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#88D14F"/>
        </Style>

        <Style x:Key="TextBoxEditStyle" TargetType="TextBox">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#88D14F"/>
            <Setter Property="Background" Value="{DynamicResource MaterialDesignDarkBackground}"/>
            <Setter Property="Foreground" Value="#88D14F"/>
            <Setter Property="CaretBrush" Value="#88D14F"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Tabela de Precos"
                         Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                         Margin="0,0,0,8"/>
                
                <TextBlock Text="Clique para editar - Enter confirma - Esc cancela"
                         Style="{StaticResource MaterialDesignCaptionTextBlock}"
                         Opacity="0.7"
                         Margin="0,0,0,12"/>

                <TextBox Width="300"
                        Padding="8,6"
                        materialDesign:HintAssist.Hint="Filtrar produtos..."
                        HorizontalAlignment="Left"
                        Text="{Binding Filtro, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </Border>

        <!-- CONTEUDO PRINCIPAL -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="600"/>
                <ColumnDefinition Width="Auto" MinWidth="320"/>
            </Grid.ColumnDefinitions>

            <!-- TABELA COM ABAS -->
            <Border Grid.Column="0" 
                    Background="{DynamicResource MaterialDesignCardBackground}"
                    CornerRadius="4"
                    Margin="0,0,12,0">
                
                <TabControl Style="{StaticResource MaterialDesignTabControl}">
                    
                    <!-- ABA VAREJO -->
                    <TabItem Header="Varejo">
                        <Grid Background="{DynamicResource MaterialDesignPaper}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                     Text="Preco unitario de venda"
                                     Foreground="#88D14F"
                                     FontSize="12"
                                     Padding="12"
                                     FontWeight="Bold"/>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding ProdutosView}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      SelectedItem="{Binding ProdutoSelecionado}"
                                      PreviewMouseLeftButtonDown="DataGrid_PreviewMouseLeftButtonDown"
                                      PreviewKeyDown="DataGrid_PreviewKeyDown"
                                      CellEditEnding="DataGrid_CellEditEnding"
                                      Background="{DynamicResource MaterialDesignPaper}"
                                      RowHeight="45">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Produto"
                                                      Binding="{Binding Descricao}"
                                                      Width="*"
                                                      IsReadOnly="True"
                                                      HeaderStyle="{StaticResource DataGridHeaderStyle}"/>

                                    <DataGridTextColumn Header="Custo"
                                                      Binding="{Binding ValorCusto, StringFormat=C2}"
                                                      Width="90"
                                                      IsReadOnly="True"
                                                      HeaderStyle="{StaticResource DataGridHeaderStyle}"
                                                      ElementStyle="{StaticResource EditableFieldStyle}"/>

                                    <DataGridTextColumn Header="Venda"
                                                      Binding="{Binding ValorVenda, StringFormat=C2, UpdateSourceTrigger=PropertyChanged}"
                                                      Width="100"
                                                      HeaderStyle="{StaticResource DataGridHeaderStyle}"
                                                      ElementStyle="{StaticResource PriceTextStyle}"
                                                      EditingElementStyle="{StaticResource TextBoxEditStyle}"/>

                                    <DataGridTextColumn Header="Margem %"
                                                      Binding="{Binding PorcentagemLucro, StringFormat='{}{0:N1}%'}"
                                                      Width="90"
                                                      IsReadOnly="True"
                                                      HeaderStyle="{StaticResource DataGridHeaderStyle}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Margin" Value="4"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PorcentagemLucro}" Value="0">
                                                        <Setter Property="Foreground" Value="#FFA500"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PorcentagemLucro, Converter={StaticResource LessThanZeroConverter}}" Value="True">
                                                        <Setter Property="Foreground" Value="#FF6B6B"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PorcentagemLucro, Converter={StaticResource GreaterThanZeroConverter}}" Value="True">
                                                        <Setter Property="Foreground" Value="#88D14F"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <!-- ABA CAIXA -->
                    <TabItem Header="Caixa">
                        <Grid Background="{DynamicResource MaterialDesignPaper}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                     Text="Preco de venda por caixa"
                                     Foreground="#88D14F"
                                     FontSize="12"
                                     Padding="12"
                                     FontWeight="Bold"/>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding ProdutosView}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      SelectedItem="{Binding ProdutoSelecionado}"
                                      PreviewMouseLeftButtonDown="DataGrid_PreviewMouseLeftButtonDown"
                                      PreviewKeyDown="DataGrid_PreviewKeyDown"
                                      CellEditEnding="DataGrid_CellEditEnding"
                                      Background="{DynamicResource MaterialDesignPaper}"
                                      RowHeight="45">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Produto"
                                                      Binding="{Binding Descricao}"
                                                      Width="*"
                                                      IsReadOnly="True"
                                                      HeaderStyle="{StaticResource DataGridHeaderStyle}"/>

                                    <DataGridTextColumn Header="Qtd/Cx"
                                                      Binding="{Binding QuantidadeCaixa, UpdateSourceTrigger=PropertyChanged}"
                                                      Width="70"
                                                      HeaderStyle="{StaticResource DataGridHeaderStyle}"
                                                      ElementStyle="{StaticResource EditableFieldStyle}"
                                                      EditingElementStyle="{StaticResource TextBoxEditStyle}"/>

                                    <DataGridTextColumn Header="Valor"
                                                      Binding="{Binding ValorCaixa, StringFormat=C2, UpdateSourceTrigger=PropertyChanged}"
                                                      Width="100"
                                                      HeaderStyle="{StaticResource DataGridHeaderStyle}"
                                                      ElementStyle="{StaticResource PriceTextStyle}"
                                                      EditingElementStyle="{StaticResource TextBoxEditStyle}"/>

                                    <DataGridTextColumn Header="Margem %"
                                                      Binding="{Binding PorcentagemLucroCaixa, StringFormat='{}{0:N1}%'}"
                                                      Width="90"
                                                      IsReadOnly="True"
                                                      HeaderStyle="{StaticResource DataGridHeaderStyle}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Margin" Value="4"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PorcentagemLucroCaixa}" Value="0">
                                                        <Setter Property="Foreground" Value="#FFA500"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PorcentagemLucroCaixa, Converter={StaticResource LessThanZeroConverter}}" Value="True">
                                                        <Setter Property="Foreground" Value="#FF6B6B"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PorcentagemLucroCaixa, Converter={StaticResource GreaterThanZeroConverter}}" Value="True">
                                                        <Setter Property="Foreground" Value="#88D14F"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <!-- ABA ATACADO -->
                    <TabItem Header="Atacado">
                        <Grid Background="{DynamicResource MaterialDesignPaper}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                     Text="Preco especial para compras em quantidade"
                                     Foreground="#88D14F"
                                     FontSize="12"
                                     Padding="12"
                                     FontWeight="Bold"/>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding ProdutosView}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      SelectedItem="{Binding ProdutoSelecionado}"
                                      PreviewMouseLeftButtonDown="DataGrid_PreviewMouseLeftButtonDown"
                                      CellEditEnding="DataGrid_CellEditEnding"
                                      Background="{DynamicResource MaterialDesignPaper}"
                                      RowHeight="45">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Produto"
                                                      Binding="{Binding Descricao}"
                                                      Width="*"
                                                      IsReadOnly="True"
                                                      HeaderStyle="{StaticResource DataGridHeaderStyle}"/>

                                    <DataGridTextColumn Header="Qtd Min"
                                                      Binding="{Binding QuantidadeMinimaAtacado, UpdateSourceTrigger=PropertyChanged}"
                                                      Width="70"
                                                      HeaderStyle="{StaticResource DataGridHeaderStyle}"
                                                      ElementStyle="{StaticResource EditableFieldStyle}"
                                                      EditingElementStyle="{StaticResource TextBoxEditStyle}"/>

                                    <DataGridTextColumn Header="Valor"
                                                      Binding="{Binding ValorAtacadoCaixa, StringFormat=C2, UpdateSourceTrigger=PropertyChanged}"
                                                      Width="100"
                                                      HeaderStyle="{StaticResource DataGridHeaderStyle}"
                                                      ElementStyle="{StaticResource PriceTextStyle}"
                                                      EditingElementStyle="{StaticResource TextBoxEditStyle}"/>

                                    <DataGridTextColumn Header="Margem %"
                                                      Binding="{Binding PorcentagemLucroAtacado, StringFormat='{}{0:N1}%'}"
                                                      Width="90"
                                                      IsReadOnly="True"
                                                      HeaderStyle="{StaticResource DataGridHeaderStyle}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Margin" Value="4"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PorcentagemLucroAtacado}" Value="0">
                                                        <Setter Property="Foreground" Value="#FFA500"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PorcentagemLucroAtacado, Converter={StaticResource LessThanZeroConverter}}" Value="True">
                                                        <Setter Property="Foreground" Value="#FF6B6B"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PorcentagemLucroAtacado, Converter={StaticResource GreaterThanZeroConverter}}" Value="True">
                                                        <Setter Property="Foreground" Value="#88D14F"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>

            <!-- PAINEL LATERAL -->
            <Border Grid.Column="1"
                    Background="{DynamicResource MaterialDesignCardBackground}"
                    CornerRadius="4">
                
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Produto Selecionado"
                                 Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="{Binding ProdutoSelecionado.Descricao}"
                                 TextWrapping="Wrap"
                                 Margin="0,0,0,16"
                                 Foreground="#88D14F"
                                 FontWeight="Bold"/>

                        <Separator Margin="0,0,0,12"/>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Custo Unitario"
                                     Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                     Opacity="0.7"/>
                            <TextBlock Text="{Binding ProdutoSelecionado.ValorCusto, StringFormat=C2}"
                                     FontSize="18"
                                     FontWeight="Bold"
                                     Foreground="#FFA500"
                                     Margin="0,4,0,0"/>
                        </StackPanel>

                        <Separator Margin="0,0,0,12"/>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Preco Varejo"
                                     Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                     Opacity="0.7"/>
                            <TextBlock Text="{Binding ProdutoSelecionado.ValorVenda, StringFormat=C2}"
                                     FontSize="18"
                                     FontWeight="Bold"
                                     Foreground="#88D14F"
                                     Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding ProdutoSelecionado.PorcentagemLucro, StringFormat='Margem: {0:N1}%'}"
                                     FontSize="11"
                                     Margin="0,6,0,0"
                                     Opacity="0.8"/>
                        </StackPanel>

                        <Separator Margin="0,0,0,12"/>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Preco Caixa"
                                     Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                     Opacity="0.7"/>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding ProdutoSelecionado.QuantidadeCaixa, StringFormat='Quantidade: {0} un'}"
                                             FontSize="11"
                                             Opacity="0.8"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding ProdutoSelecionado.ValorCaixa, StringFormat=C2}"
                                             FontWeight="Bold"
                                             Foreground="#88D14F"/>
                                    <TextBlock Text="{Binding ProdutoSelecionado.PorcentagemLucroCaixa, StringFormat='{}{0:N1}%'}"
                                             FontSize="11"
                                             Margin="0,2,0,0"
                                             Opacity="0.8"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <Separator Margin="0,0,0,12"/>

                        <StackPanel>
                            <TextBlock Text="Preco Atacado"
                                     Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                     Opacity="0.7"/>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding ProdutoSelecionado.QuantidadeMinimaAtacado, StringFormat='Minimo: {0} cx'}"
                                             FontSize="11"
                                             Opacity="0.8"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding ProdutoSelecionado.ValorAtacadoCaixa, StringFormat=C2}"
                                             FontWeight="Bold"
                                             Foreground="#88D14F"/>
                                    <TextBlock Text="{Binding ProdutoSelecionado.PorcentagemLucroAtacado, StringFormat='{}{0:N1}%'}"
                                             FontSize="11"
                                             Margin="0,2,0,0"
                                             Opacity="0.8"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
