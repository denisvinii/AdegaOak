    // --- DESCONTO EM SAÍDA ---
    private DescontoModel _descontoModel = new();
    public DescontoModel DescontoModel
    {
        get => _descontoModel;
        private set => SetProperty(ref _descontoModel, value);
    }

    private bool descontoAtivo;
    public bool DescontoAtivo
    {
        get => descontoAtivo;
        set => SetProperty(ref descontoAtivo, value);
    }

    private string senhaDesconto = string.Empty;
    public string SenhaDesconto
    {
        get => senhaDesconto;
        set => SetProperty(ref senhaDesconto, value);
    }

    private bool senhaDescontoCorreta;
    public bool SenhaDescontoCorreta
    {
        get => senhaDescontoCorreta;
        set => SetProperty(ref senhaDescontoCorreta, value);
    }

    public int DescontoPercentual
    {
        get => _descontoModel.Percentual;
        set => _descontoModel.Percentual = value;
    }

    public decimal DescontoValor
    {
        get => _descontoModel.Valor;
        set => _descontoModel.Valor = value;
    }

    public decimal ValorFinalProduto
    {
        get => _descontoModel.PrecoFinal;
    }

    public decimal ValorCustoProduto
    {
        get => _descontoModel.Custo;
        set => _descontoModel.Custo = value;
    }

    public string DescontoPercentualTexto
    {
        get => _descontoModel.Percentual.ToString(CultureInfo.CurrentCulture);
        set
        {
            if (int.TryParse(value, NumberStyles.Integer, CultureInfo.CurrentCulture, out var parsed))
            {
                _descontoModel.Percentual = parsed;
            }
            else if (string.IsNullOrWhiteSpace(value))
            {
                _descontoModel.Percentual = 0;
            }
        }
    }

    public string DescontoValorTexto
    {
        get => _descontoModel.Valor.ToString("N2", CultureInfo.CurrentCulture);
        set
        {
            if (decimal.TryParse(value, NumberStyles.Number, CultureInfo.CurrentCulture, out var parsed))
            {
                _descontoModel.Valor = parsed;
            }
            else if (decimal.TryParse(value?.Replace(',', '.'), NumberStyles.Number, CultureInfo.InvariantCulture, out parsed))
            {
                _descontoModel.Valor = parsed;
            }
            else if (string.IsNullOrWhiteSpace(value))
            {
                _descontoModel.Valor = 0m;
            }
        }
    }

    [RelayCommand]
    public void AtivarDesconto()
    {
        if (!IsSaida) return;
        DescontoAtivo = true;
        SenhaDesconto = string.Empty;
        SenhaDescontoCorreta = false;
    }

    [RelayCommand]
    public void ValidarSenhaDesconto()
    {
        string senhaConfigrada = _configuration?["DescontoSettings:SenhaAutorizacao"] ?? "ADEGA2024";
        
        if (SenhaDesconto == senhaConfigrada)
        {
            SenhaDescontoCorreta = true;
            _descontoModel.Reset();
            ValorCustoProduto = ProdutoSelecionado != null ? ProdutoSelecionado.Valor : 0m;
            AtualizarPrecoVendaModel();
        }
        else
        {
            SenhaDescontoCorreta = false;
        }
    }

    private void LimparDesconto()
    {
        DescontoAtivo = false;
        SenhaDesconto = string.Empty;
        SenhaDescontoCorreta = false;
        _descontoModel.Reset();
        ValorCustoProduto = 0m;
    }

    private void AtualizarPrecoVendaModel()
    {
        var precoVenda = ObterPrecoVendaAtual();
        var custo = ProdutoSelecionado?.Valor ?? 0m;
        _descontoModel.ConfigurarProduto(precoVenda, custo);
    }

    private decimal ObterPrecoVendaAtual()
    {
        if (_tabelaPrecosViewModel?.Produtos == null || ProdutoSelecionado == null)
            return ProdutoSelecionado?.Valor ?? 0m;
        
        var produtoPreco = _tabelaPrecosViewModel.Produtos.FirstOrDefault(p => p.Descricao == ProdutoSelecionado.Descricao);
        return produtoPreco != null && produtoPreco.ValorVenda > 0 ? produtoPreco.ValorVenda : ProdutoSelecionado.Valor;
    }

    private void OnStatusChanged(bool online)
    {
        Application.Current.Dispatcher.Invoke(() =>
        {
            StatusText = online ? "Online" : "Offline (usando local)";
            OnPropertyChanged(nameof(StatusText));
        });
    }
