public class DescontoModel : ObservableObject
{
    private int _percentual = 0;
    private decimal _valor = 0m;
    private decimal _precoVenda = 0m;
    private decimal _custo = 0m;
    private bool _isUpdating = false;

    public int Percentual
    {
        get => _percentual;
        set
        {
            if (_percentual == value) return;
            if (_isUpdating) return;

            try
            {
                _isUpdating = true;
                int validado = Math.Max(0, Math.Min(100, value));
                if (SetProperty(ref _percentual, validado))
                {
                    AtualizarValorAPartirPercentual();
                }
            }
            finally { _isUpdating = false; }
        }
    }

    public decimal Valor
    {
        get => _valor;
        set
        {
            if (_valor == value) return;
            if (_isUpdating) return;

            try
            {
                _isUpdating = true;
                decimal maxDesc = CalcularMaxDescontoPermitido();
                decimal validado = Math.Max(0m, Math.Min(maxDesc, value));
                if (SetProperty(ref _valor, validado))
                {
                    AtualizarPercentualAPartirValor();
                }
            }
            finally { _isUpdating = false; }
        }
    }

    public decimal PrecoVenda
    {
        get => _precoVenda;
        set
        {
            if (SetProperty(ref _precoVenda, value))
            {
                RecalcularComNovoPreco();
            }
        }
    }

    public decimal Custo
    {
        get => _custo;
        set
        {
            if (SetProperty(ref _custo, value))
            {
                RecalcularComNovoCusto();
            }
        }
    }

    public decimal PrecoFinal => Math.Max(0m, decimal.Round(_precoVenda - _valor, 2));
    public decimal MaxDescontoPermitido => CalcularMaxDescontoPermitido();
    public bool EstValido => _precoVenda > 0m && _valor >= 0m && _valor <= MaxDescontoPermitido;

    private void AtualizarValorAPartirPercentual()
    {
        if (_precoVenda <= 0m)
        {
            _valor = 0m;
        }
        else
        {
            decimal calc = decimal.Round(_precoVenda * _percentual / 100m, 2);
            decimal max = CalcularMaxDescontoPermitido();
            _valor = Math.Min(calc, max);
        }
        OnPropertyChanged(nameof(Valor));
        OnPropertyChanged(nameof(PrecoFinal));
    }

    private void AtualizarPercentualAPartirValor()
    {
        if (_precoVenda <= 0m)
        {
            _percentual = 0;
        }
        else
        {
            _percentual = (int)Math.Round(100m * _valor / _precoVenda);
            _percentual = Math.Max(0, Math.Min(100, _percentual));
        }
        OnPropertyChanged(nameof(Percentual));
        OnPropertyChanged(nameof(PrecoFinal));
    }

    private decimal CalcularMaxDescontoPermitido()
    {
        return Math.Max(0m, _precoVenda - _custo);
    }

    private void RecalcularComNovoPreco()
    {
        if (_precoVenda <= 0m)
        {
            _valor = 0m;
            _percentual = 0;
        }
        else
        {
            decimal max = CalcularMaxDescontoPermitido();
            if (_valor > max)
            {
                _valor = max;
                AtualizarPercentualAPartirValor();
            }
        }
        OnPropertyChanged(nameof(PrecoFinal));
        OnPropertyChanged(nameof(MaxDescontoPermitido));
        OnPropertyChanged(nameof(Valor));
        OnPropertyChanged(nameof(Percentual));
    }

    private void RecalcularComNovoCusto()
    {
        decimal max = CalcularMaxDescontoPermitido();
        if (_valor > max)
        {
            _valor = max;
            AtualizarPercentualAPartirValor();
        }
        OnPropertyChanged(nameof(MaxDescontoPermitido));
        OnPropertyChanged(nameof(PrecoFinal));
        OnPropertyChanged(nameof(Valor));
        OnPropertyChanged(nameof(Percentual));
    }

    public void Reset()
    {
        _percentual = 0;
        _valor = 0m;
        OnPropertyChanged(nameof(Percentual));
        OnPropertyChanged(nameof(Valor));
        OnPropertyChanged(nameof(PrecoFinal));
    }

    public void ConfigurarProduto(decimal precoVenda, decimal custo)
    {
        PrecoVenda = precoVenda;
        Custo = custo;
        Reset();
    }
}

