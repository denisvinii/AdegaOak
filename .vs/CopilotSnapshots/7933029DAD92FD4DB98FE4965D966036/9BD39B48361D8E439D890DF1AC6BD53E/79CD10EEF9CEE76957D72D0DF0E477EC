public class ProdutoSelecionadoItem : ObservableObject
{
    public MainRepository.Produto Produto { get; set; } = null!;
    public string Descricao { get; set; } = "";

    private int quantidade;
    public int Quantidade
    {
        get => quantidade;
        set
        {
            if (SetProperty(ref quantidade, value))
                OnPropertyChanged(nameof(ValorTotal));
        }
    }

    public string TipoMovimentacao { get; set; } = "";
    public string? TipoSaida { get; set; }
    public string? UnidadeSelecionada { get; set; }

    private decimal valorUnitario;
    public decimal ValorUnitario
    {
        get => valorUnitario;
        set
        {
            if (SetProperty(ref valorUnitario, value))
                OnPropertyChanged(nameof(ValorTotal));
        }
    }

    private decimal _descontoAplicado = 0m;
    public decimal DescontoAplicado
    {
        get => _descontoAplicado;
        set
        {
            if (SetProperty(ref _descontoAplicado, value))
                OnPropertyChanged(nameof(ValorTotal));
        }
    }

    public int QuantidadeCaixas { get; set; } = 0;
    public decimal ValorCaixa { get; set; } = 0;
    public string? TipoVenda { get; set; } = "Varejo";
    public int QuantidadeMinimaAtacado { get; set; } = 20;

    public decimal ValorTotal
    {
        get
        {
            if (string.Equals(UnidadeSelecionada, "Caixa", StringComparison.OrdinalIgnoreCase))
            {
                return QuantidadeCaixas * ValorCaixa;
            }
            return Quantidade * ValorUnitario;
        }
    }
}

public partial class MainWindowViewModel
{
    #region Ajuste de Quantidade
    [RelayCommand]
    private void IncrementarQuantidade()
    {
        if (!int.TryParse(Quantidade, out int qtd))
            qtd = 0;
        qtd++;
        Quantidade = qtd.ToString();
    }

    [RelayCommand]
    private void DecrementarQuantidade()
    {
        if (!int.TryParse(Quantidade, out int qtd))
            qtd = 0;
        if (qtd > 1)
            qtd--;
        else
            qtd = 1;
        Quantidade = qtd.ToString();
    }
    #endregion

    partial void OnNovoProdutoMaterialChanged(string? value)
    {
        if (!string.IsNullOrWhiteSpace(value) && tamanhosPorMaterial.ContainsKey(value))
        {
            TamanhosDisponiveis.Clear();
            foreach (var tamanho in tamanhosPorMaterial[value])
                TamanhosDisponiveis.Add(tamanho);
            OnPropertyChanged(nameof(TamanhosDisponiveis));
        }
        else
        {
            TamanhosDisponiveis.Clear();
            OnPropertyChanged(nameof(TamanhosDisponiveis));
        }
        NovoProdutoTamanho = "";
    }

    partial void OnProdutoSelecionadoChanged(MainRepository.Produto? value)
    {
        if (value != null)
        {
            if (!string.Equals(ProdutoFiltroTexto, value.Descricao, System.StringComparison.OrdinalIgnoreCase))
                ProdutoFiltroTexto = value.Descricao;

            if (!string.IsNullOrWhiteSpace(value.Material) && tamanhosPorMaterial.ContainsKey(value.Material))
            {
                TamanhosDisponiveis.Clear();
                foreach (var tamanho in tamanhosPorMaterial[value.Material])
                    TamanhosDisponiveis.Add(tamanho);
                OnPropertyChanged(nameof(TamanhosDisponiveis));
            }
            else
            {
                TamanhosDisponiveis.Clear();
            }

            // Atualizar modelo de desconto com novo produto
            AtualizarPrecoVendaModel();
            
            // Notificar que a prévia do valor final pode ter mudado
            OnPropertyChanged(nameof(ValorFinalProduto));
        }
        else
        {
            TamanhosDisponiveis.Clear();
            _descontoModel.Reset();
            ValorCustoProduto = 0m;
            OnPropertyChanged(nameof(ValorFinalProduto));
        }
    }
