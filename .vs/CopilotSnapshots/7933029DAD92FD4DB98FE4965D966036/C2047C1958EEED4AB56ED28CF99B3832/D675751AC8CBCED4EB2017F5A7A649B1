using Adega_Oak.Features.MainWindow;
using System.Windows.Controls;
using System.Windows.Input;

namespace Adega_Oak.Views;

public partial class InicioView : UserControl
{
    #region Construtor
    // Inicializa a view de início
    public InicioView()
    {
        InitializeComponent();
    }
    #endregion

    private void QuantidadeMenos_Click(object sender, MouseButtonEventArgs e)
    {
        if (DataContext is MainWindowViewModel vm)
        {
            if (!int.TryParse(vm.Quantidade, out int qtd))
                qtd = 0;
            if (qtd > 1)
                qtd--;
            else
                qtd = 1;
            vm.Quantidade = qtd.ToString();
        }
    }

    private void QuantidadeMais_Click(object sender, MouseButtonEventArgs e)
    {
        if (DataContext is MainWindowViewModel vm)
        {
            if (!int.TryParse(vm.Quantidade, out int qtd))
                qtd = 0;
            qtd++;
            vm.Quantidade = qtd.ToString();
        }
    }

    private void QuantidadeTextBox_TextChanged(object sender, TextChangedEventArgs e)
    {

    }

    private void TextBox_TextChanged(object sender, TextChangedEventArgs e)
    {

    }

    private void SenhaBox_PasswordChanged(object sender, RoutedEventArgs e)
    {
        if (DataContext is MainWindowViewModel vm && sender is PasswordBox pb)
        {
            vm.SenhaDesconto = pb.Password;
        }
    }

    private void SenhaBox_KeyDown(object sender, KeyEventArgs e)
    {
        if (e.Key == Key.Enter && DataContext is MainWindowViewModel vm)
        {
            // Execute the validation command when Enter is pressed
            if (vm.ValidarSenhaDescontoCommand.CanExecute(null))
                vm.ValidarSenhaDescontoCommand.Execute(null);
            e.Handled = true;
        }
    }
}