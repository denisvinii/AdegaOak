<Window x:Class="Adega_Oak.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirmação de Senha" Height="200" Width="380"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{DynamicResource WindowBackground}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Digite a senha para excluir o produto:" Grid.Row="0" Margin="0,0,0,14"
                   FontSize="16" Foreground="{DynamicResource ErrorColor}" FontWeight="SemiBold"/>
        <Border Grid.Row="1" CornerRadius="6" BorderThickness="2" BorderBrush="{DynamicResource ErrorColor}" Background="{DynamicResource ControlBackground}" Padding="2">
            <PasswordBox x:Name="PasswordBox" Height="34" FontSize="16" VerticalContentAlignment="Center"/>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Excluir" Width="100" Margin="0,0,12,0" IsDefault="True" Click="Ok_Click"
                    Background="{DynamicResource ErrorColor}" Foreground="White" FontWeight="Bold" Style="{DynamicResource AccentButtonStyle}"/>
            <Button Content="Cancelar" Width="100" IsCancel="True" Click="Cancel_Click"
                    Background="{DynamicResource ControlBackground}" Foreground="{DynamicResource Foreground}" Style="{DynamicResource AccentButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
