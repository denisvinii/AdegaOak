<Window x:Class="Adega_Oak.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirmação de Senha" Height="220" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#FFF">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Digite a senha para excluir o produto:" Grid.Row="0" Margin="0,0,0,18"
                   FontSize="18" Foreground="#D32F2F" FontWeight="Bold"/>
        <Border Grid.Row="1" CornerRadius="8" BorderThickness="2" BorderBrush="#D32F2F" Background="#FFF" Padding="2" Margin="0,0,0,12">
            <Grid>
                <PasswordBox x:Name="PasswordBox" Height="38" FontSize="18" VerticalContentAlignment="Center" Background="#FFF" Foreground="#222"/>
                <!-- Placeholder para senha -->
                <TextBlock Text="Senha" Foreground="#888" FontSize="16" Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"
                           Visibility="{Binding ElementName=PasswordBox, Path=Password.Length, Converter={StaticResource NullToVisibilityConverter}}"/>
            </Grid>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Excluir" Width="110" Height="38" Margin="0,0,14,0" IsDefault="True" Click="Ok_Click"
                    Background="#D32F2F" Foreground="White" FontWeight="Bold" FontSize="16" BorderBrush="#B71C1C" BorderThickness="1"/>
            <Button Content="Cancelar" Width="110" Height="38" IsCancel="True" Click="Cancel_Click"
                    Background="#F5F5F5" Foreground="#222" FontWeight="SemiBold" FontSize="16" BorderBrush="#CCC" BorderThickness="1"/>
        </StackPanel>
    </Grid>
</Window>
