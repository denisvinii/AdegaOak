    private void IniciarVerificacaoConexao()
    {
        _connectionCheckTimer = new System.Timers.Timer(30000); // 30 segundos
        _connectionCheckTimer.Elapsed += (s, e) =>
        {
            var anterior = _isOnlineCache;
            IsOnline(forceCheck: true);

            if (anterior != _isOnlineCache && _isOnlineCache.HasValue)
            {
                System.Diagnostics.Debug.WriteLine($"Status da conexão alterado: {_isOnlineCache}");
                if (_isOnlineCache.Value)
                {
                    // Se voltou online, sincroniza
                    SincronizarEAtualizarBackupLocal();
                }
            }
        };
        _connectionCheckTimer.Start();
    }

    public bool IsOnline(bool forceCheck = false)
    {
        if (!forceCheck && _isOnlineCache.HasValue)
            return _isOnlineCache.Value;

        try
        {
            using var conn = new NpgsqlConnection(_supabaseConnectionString);
            conn.Open();
            _isOnlineCache = true;
            return true;
        }
        catch
        {
            _isOnlineCache = false;
            return false;
        }
    }

    /// <summary>
    /// Retorna uma conexão aberta para o banco de dados apropriado.
    /// </summary>
    public IDbConnection GetConnection()
    {
        try
        {
            if (IsOnline(forceCheck: true))
            {
                var conn = new NpgsqlConnection(_supabaseConnectionString);
                conn.Open();
                return conn;
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Erro ao conectar com a nuvem: {ex.Message}");
            _isOnlineCache = false; // Força o modo offline
        }

        // Se chegou aqui, usa SQLite
        var localConn = new SqliteConnection($"Data Source={_sqliteDbPath}");
        localConn.Open();
        return localConn;
    }

    /// <summary>
    /// Faz backup incremental das tabelas da nuvem para o banco local.
    /// </summary>
    public void BackupBancoNuvemParaLocal()
    {
        if (!IsOnline())
            return;

        using var pgConn = new NpgsqlConnection(_supabaseConnectionString);
        using var sqliteConn = new SqliteConnection($"Data Source={_sqliteDbPath}");
        pgConn.Open();
        sqliteConn.Open();

        CriarTabelasSQLiteSeNecessario();

        // Backup da tabela estoque (aqui pode limpar pois é dado de referência)
        using (var pgCmd = pgConn.CreateCommand())
        {
            // Alterado para incluir a coluna valor
            pgCmd.CommandText = "SELECT productid, bebida, tamanho, material, estoque_minimo, valor FROM estoque";
            using var reader = pgCmd.ExecuteReader();
            using var tx = sqliteConn.BeginTransaction();

            using (var delCmd = sqliteConn.CreateCommand())
            {
                delCmd.CommandText = "DELETE FROM estoque";
                delCmd.ExecuteNonQuery();
            }

            while (reader.Read())
            {
                using var insertCmd = sqliteConn.CreateCommand();
                // Atualizado para incluir a coluna valor
                insertCmd.CommandText = "INSERT INTO estoque (productid, bebida, tamanho, material, estoque_minimo, valor) VALUES (@id, @bebida, @tamanho, @material, @minimo, @valor)";
                insertCmd.Parameters.AddWithValue("@id", reader.GetInt32(0));
                insertCmd.Parameters.AddWithValue("@bebida", reader.GetString(1));
                insertCmd.Parameters.AddWithValue("@tamanho", reader.GetString(2));
                insertCmd.Parameters.AddWithValue("@material", reader.GetString(3));
                insertCmd.Parameters.AddWithValue("@minimo", reader.IsDBNull(4) ? 0 : reader.GetInt32(4));
                insertCmd.Parameters.AddWithValue("@valor", reader.IsDBNull(5) ? 0 : reader.GetDecimal(5));
                insertCmd.ExecuteNonQuery();
            }
            tx.Commit();
        }

        // Backup da tabela funcionarios (aqui pode limpar pois é dado de referência)
        using (var pgCmd = pgConn.CreateCommand())
        {
            pgCmd.CommandText = "SELECT id, username FROM funcionarios";
            using var reader = pgCmd.ExecuteReader();
            using var tx = sqliteConn.BeginTransaction();

            using (var delCmd = sqliteConn.CreateCommand())
            {
                delCmd.CommandText = "DELETE FROM funcionarios";
                delCmd.ExecuteNonQuery();
            }

            while (reader.Read())
            {
                using var insertCmd = sqliteConn.CreateCommand();
                insertCmd.CommandText = "INSERT INTO funcionarios (id, username) VALUES (@id, @username)";
                insertCmd.Parameters.AddWithValue("@id", reader.GetInt32(0));
                insertCmd.Parameters.AddWithValue("@username", reader.GetString(1));
                insertCmd.ExecuteNonQuery();
            }
            tx.Commit();
        }

        // Backup da tabela movimentacoes
        using (var countCmd = sqliteConn.CreateCommand())
        {
            countCmd.CommandText = "SELECT COUNT(*) FROM movimentacoes";
            var count = Convert.ToInt32(countCmd.ExecuteScalar());
            
            if (count == 0)
            {
                // Faz backup completo inicial
                using var pgCmd = pgConn.CreateCommand();
                pgCmd.CommandText = "SELECT data, tipo, productid, produto, quantidade, responsavel, saida FROM movimentacoes ORDER BY data DESC";
                using var reader = pgCmd.ExecuteReader();
                using var tx = sqliteConn.BeginTransaction();

                try
                {
                    while (reader.Read())
                    {
                        using var insertCmd = sqliteConn.CreateCommand();
                        insertCmd.CommandText = @"
                            INSERT OR IGNORE INTO movimentacoes 
                            (data, tipo, productid, produto, quantidade, responsavel, saida) 
                            VALUES (@data, @tipo, @productid, @produto, @quantidade, @responsavel, @saida)";
                        
