    private void CriarTabelasSQLiteSeNecessario(SqliteConnection? conn = null)
    {
        bool shouldDisposeConnection = conn == null;
        conn ??= new SqliteConnection($"Data Source={_sqliteDbPath}");
        if (conn.State != ConnectionState.Open)
            conn.Open();

        using var cmd = conn.CreateCommand();
        
        // Tabela de produtos
        cmd.CommandText = @"
            CREATE TABLE IF NOT EXISTS estoque (
                productid INTEGER PRIMARY KEY,
                bebida TEXT NOT NULL,
                tamanho TEXT NOT NULL,
                material TEXT NOT NULL,
                valor DECIMAL NOT NULL DEFAULT 0,
                estoque_minimo INTEGER DEFAULT 0
            )";
        cmd.ExecuteNonQuery();

        // Tabela de movimentações
        cmd.CommandText = @"
            CREATE TABLE IF NOT EXISTS movimentacoes (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                data TEXT NOT NULL,
                tipo TEXT NOT NULL,
                productid INTEGER NOT NULL,
                produto TEXT NOT NULL,
                quantidade INTEGER NOT NULL,
                responsavel TEXT NOT NULL,
                saida TEXT,
                valor_unitario DECIMAL NOT NULL DEFAULT 0,
                FOREIGN KEY (productid) REFERENCES estoque(productid)
            )";
        cmd.ExecuteNonQuery();

        // Tabela de histórico de valores
        cmd.CommandText = @"
            CREATE TABLE IF NOT EXISTS historico_valores (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                data TEXT NOT NULL,
                productid INTEGER NOT NULL,
                valor DECIMAL NOT NULL,
                FOREIGN KEY (productid) REFERENCES estoque(productid)
            )";
        cmd.ExecuteNonQuery();

        // Tabela de funcionários
        cmd.CommandText = @"
            CREATE TABLE IF NOT EXISTS funcionarios (
                userid INTEGER PRIMARY KEY AUTOINCREMENT,
                username TEXT NOT NULL UNIQUE
            )";
        cmd.ExecuteNonQuery();

        if (shouldDisposeConnection)
            conn.Dispose();
    }

    private void VerificarEAtualizarEstrutura(SqliteConnection conn)
    {
        using var cmd = conn.CreateCommand();
        
        // Verifica se a coluna valor existe na tabela estoque
        cmd.CommandText = "PRAGMA table_info(estoque);";
        using var reader = cmd.ExecuteReader();
        var colunas = new List<string>();
        while (reader.Read())
        {
            colunas.Add(reader.GetString(1).ToLower());
        }

        // Se não existir a coluna valor, adiciona
        if (!colunas.Contains("valor"))
        {
            System.Diagnostics.Debug.WriteLine("Adicionando coluna 'valor' na tabela estoque");
            using var alterCmd = conn.CreateCommand();
            alterCmd.CommandText = "ALTER TABLE estoque ADD COLUMN valor DECIMAL(10,2) DEFAULT 0;";
            alterCmd.ExecuteNonQuery();
        }
    }

    private void AtualizarSyncControl(string status)
    {
        using var conn = new SqliteConnection($"Data Source={_sqliteDbPath}");
        conn.Open();
        using var cmd = conn.CreateCommand();
        cmd.CommandText = @"
            INSERT OR REPLACE INTO sync_control (ultima_sync, status) 
            VALUES (@data, @status)";
        cmd.Parameters.AddWithValue("@data", DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss"));
        cmd.Parameters.AddWithValue("@status", status);
        cmd.ExecuteNonQuery();
    }

    private void CriarTabelasPostgresSeNecessario()
    {
        if (!IsOnline()) return;
        try
        {
            using var conn = new NpgsqlConnection(_supabaseConnectionString);
            conn.Open();
            using var cmd = conn.CreateCommand();
            // Tabela estoque
            cmd.CommandText = @"
                CREATE TABLE IF NOT EXISTS estoque (
                    productid INTEGER PRIMARY KEY,
                    bebida TEXT NOT NULL,
                    tamanho TEXT NOT NULL,
                    material TEXT NOT NULL,
                    valor DECIMAL NOT NULL DEFAULT 0,
                    estoque_minimo INTEGER DEFAULT 0
                );";
            cmd.ExecuteNonQuery();
            // Tabela funcionarios
            cmd.CommandText = @"
                CREATE TABLE IF NOT EXISTS funcionarios (
                    id SERIAL PRIMARY KEY,
                    username TEXT NOT NULL UNIQUE
                );";
            cmd.ExecuteNonQuery();
            // Tabela movimentacoes
            cmd.CommandText = @"
                CREATE TABLE IF NOT EXISTS movimentacoes (
                    id SERIAL PRIMARY KEY,
                    data TIMESTAMP NOT NULL,
                    tipo TEXT NOT NULL,
                    productid INTEGER NOT NULL,
                    produto TEXT NOT NULL,
                    quantidade INTEGER NOT NULL,
                    responsavel TEXT NOT NULL,
                    saida TEXT,
                    valor_unitario DECIMAL NOT NULL DEFAULT 0,
                    FOREIGN KEY (productid) REFERENCES estoque(productid)
                );";
            cmd.ExecuteNonQuery();
            // Tabela historico_valores
            cmd.CommandText = @"
                CREATE TABLE IF NOT EXISTS historico_valores (
                    id SERIAL PRIMARY KEY,
                    data TIMESTAMP NOT NULL,
                    productid INTEGER NOT NULL,
                    valor DECIMAL NOT NULL,
                    FOREIGN KEY (productid) REFERENCES estoque(productid)
                );";
            cmd.ExecuteNonQuery();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Erro ao criar tabelas no PostgreSQL: {ex.Message}");
        }
    }
