                    }
                    tx.Commit();
                }
                catch
                {
                    tx.Rollback();
                    throw;
                }
            }
        }
    }

    /// <summary>
    /// Sincroniza movimentações locais para a nuvem (envia apenas as que não existem na nuvem).
    /// </summary>
    public void SincronizarDadosParaNuvem()
    {
        if (!IsOnline())
            return;

        using var pgConn = new NpgsqlConnection(_supabaseConnectionString);
        using var sqliteConn = new SqliteConnection($"Data Source={_sqliteDbPath}");
        pgConn.Open();
        sqliteConn.Open();

        // 1. Buscar movimentações já existentes na nuvem (usando data+productid como chave)
        var movimentacoesNaNuvem = new Dictionary<string, (DateTime data, int productid)>();
        using (var pgCmd = pgConn.CreateCommand())
        {
            pgCmd.CommandText = "SELECT data, productid FROM movimentacoes";
            using var reader = pgCmd.ExecuteReader();
            while (reader.Read())
            {
                string dataStr = reader.GetDateTime(0).ToString("yyyy-MM-dd HH:mm:ss");
                int productid = reader.GetInt32(1);
                string chave = $"{dataStr}|{productid}";
                movimentacoesNaNuvem[chave] = (reader.GetDateTime(0), productid);
            }
        }

        // 2. Buscar movimentações locais (usando data+productid como chave)
        var movimentacoesLocais = new Dictionary<string, (string data, string tipo, int productid, string produto, int quantidade, string responsavel, object? saida)>();
        using (var sqliteCmd = sqliteConn.CreateCommand())
        {
            sqliteCmd.CommandText = "SELECT data, tipo, productid, produto, quantidade, responsavel, saida FROM movimentacoes";
            using var reader = sqliteCmd.ExecuteReader();
            while (reader.Read())
            {
                string data = reader.GetString(0);
                int productid = reader.GetInt32(2);
                string chave = $"{data}|{productid}";
                movimentacoesLocais[chave] = (
                    data,
                    reader.GetString(1),
                    productid,
                    reader.GetString(3),
                    reader.GetInt32(4),
                    reader.GetString(5),
                    reader.IsDBNull(6) ? null : reader.GetString(6)
                );
            }
        }

        // 3. Incluir na nuvem as movimentações que existem localmente e não estão na nuvem
        foreach (var kvp in movimentacoesLocais)
        {
            if (!movimentacoesNaNuvem.ContainsKey(kvp.Key))
            {
                var mov = kvp.Value;
                using var insertCmd = pgConn.CreateCommand();
                insertCmd.CommandText = "INSERT INTO movimentacoes (data, tipo, productid, produto, quantidade, responsavel, saida) VALUES (@data, @tipo, @productid, @produto, @quantidade, @responsavel, @saida)";
                insertCmd.Parameters.AddWithValue("@data", DateTime.Parse(mov.data));
                insertCmd.Parameters.AddWithValue("@tipo", mov.tipo);
                insertCmd.Parameters.AddWithValue("@productid", mov.productid);
                insertCmd.Parameters.AddWithValue("@produto", mov.produto);
                insertCmd.Parameters.AddWithValue("@quantidade", mov.quantidade);
                insertCmd.Parameters.AddWithValue("@responsavel", mov.responsavel);
                insertCmd.Parameters.AddWithValue("@saida", mov.saida ?? DBNull.Value);
                insertCmd.ExecuteNonQuery();
            }
        }

    }

    /// <summary>
    /// Fluxo recomendado: sincroniza dados locais para a nuvem, atualiza dados de referência e movimentações da nuvem.
    /// </summary>
    public void SincronizarEAtualizarBackupLocal()
    {
        if (!IsOnline())
            return;

        try
        {
            System.Diagnostics.Debug.WriteLine("Iniciando sincronização...");

            // 1. Garante que as tabelas existem
            CriarTabelasSQLiteSeNecessario();

            // 2. Primeiro atualiza dados de referência (estoque e funcionários)
            AtualizarDadosReferencia();
            System.Diagnostics.Debug.WriteLine("Dados de referência atualizados");

            // 3. Sincroniza todas as movimentações
            SincronizarMovimentacoesNuvem();
            System.Diagnostics.Debug.WriteLine("Movimentações sincronizadas");

            // 4. Atualiza controle
            AtualizarSyncControl("Sincronização concluída com sucesso");
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Erro na sincronização: {ex.Message}");
            AtualizarSyncControl($"Erro na sincronização: {ex.Message}");
            throw;
        }
    }

    private void AtualizarDadosReferencia()
    {
        using var pgConn = new NpgsqlConnection(_supabaseConnectionString);
        using var sqliteConn = new SqliteConnection($"Data Source={_sqliteDbPath}");
        pgConn.Open();
        sqliteConn.Open();

        // Atualiza estoque
        using (var tx = sqliteConn.BeginTransaction())
        {
            try
            {
                // 1. Criar tabela temporária para os dados atuais da nuvem
                using (var createTempCmd = sqliteConn.CreateCommand())
                {
                    createTempCmd.CommandText = @"
                        CREATE TEMP TABLE IF NOT EXISTS estoque_temp (
                            productid INTEGER PRIMARY KEY,
                            bebida TEXT,
                            tamanho TEXT,
                            material TEXT,
                            estoque_minimo INTEGER,
                            valor DECIMAL(10,2)
                        )";
                    createTempCmd.ExecuteNonQuery();
                }

                // 2. Limpar tabela temporária
                using (var clearTempCmd = sqliteConn.CreateCommand())
                {
                    clearTempCmd.CommandText = "DELETE FROM estoque_temp";
                    clearTempCmd.ExecuteNonQuery();
                }

                // 3. Carregar dados da nuvem na tabela temporária
                using (var pgCmd = pgConn.CreateCommand())
                {
                    pgCmd.CommandText = "SELECT productid, bebida, tamanho, material, estoque_minimo, valor FROM estoque";
                    using var reader = pgCmd.ExecuteReader();

                    while (reader.Read())
                    {
                        using var insertTempCmd = sqliteConn.CreateCommand();
                        insertTempCmd.CommandText = @"
                            INSERT INTO estoque_temp (productid, bebida, tamanho, material, estoque_minimo, valor) 
                            VALUES (@id, @bebida, @tamanho, @material, @minimo, @valor)";

                        insertTempCmd.Parameters.AddWithValue("@id", reader.GetInt32(0));
                        insertTempCmd.Parameters.AddWithValue("@bebida", reader.GetString(1));
                        insertTempCmd.Parameters.AddWithValue("@tamanho", reader.GetString(2));
                        insertTempCmd.Parameters.AddWithValue("@material", reader.GetString(3));
                        insertTempCmd.Parameters.AddWithValue("@minimo", reader.IsDBNull(4) ? 0 : reader.GetInt32(4));
                        insertTempCmd.Parameters.AddWithValue("@valor", reader.IsDBNull(5) ? 0 : reader.GetDecimal(5));
                        insertTempCmd.ExecuteNonQuery();
                    }
                }

                // 4. Atualizar tabela principal
                using (var mergeCmd = sqliteConn.CreateCommand())
                {
                    mergeCmd.CommandText = @"
                        INSERT OR REPLACE INTO estoque 
                        SELECT * FROM estoque_temp";
                    mergeCmd.ExecuteNonQuery();
                }

                // 5. Remover registros que não existem mais na nuvem
                using (var cleanupCmd = sqliteConn.CreateCommand())
                {
                    cleanupCmd.CommandText = @"
                        DELETE FROM estoque 
                        WHERE productid NOT IN (SELECT productid FROM estoque_temp)";
                    cleanupCmd.ExecuteNonQuery();
                }

                tx.Commit();
            }
            catch
            {
                tx.Rollback();
                throw;
            }
            finally
            {
                // 6. Limpar tabela temporária
                using var dropTempCmd = sqliteConn.CreateCommand();
                dropTempCmd.CommandText = "DROP TABLE IF EXISTS estoque_temp";
                dropTempCmd.ExecuteNonQuery();
            }
        }

        // Atualizar funcionários de forma similar...
        using (var tx = sqliteConn.BeginTransaction())
        {
            try
            {
                // Usar UPSERT para funcionários também
                using (var pgCmd = pgConn.CreateCommand())
                {
                    pgCmd.CommandText = "SELECT id, username FROM funcionarios";
                    using var reader = pgCmd.ExecuteReader();

                    while (reader.Read())
                    {
                        using var insertCmd = sqliteConn.CreateCommand();
                        insertCmd.CommandText = @"
                            INSERT INTO funcionarios (id, username) 
                            VALUES (@id, @username)
                            ON CONFLICT(id) DO UPDATE SET
                                username = @username";

                        insertCmd.Parameters.AddWithValue("@id", reader.GetInt32(0));
                        insertCmd.Parameters.AddWithValue("@username", reader.GetString(1));
                        insertCmd.ExecuteNonQuery();
                    }
                }

                tx.Commit();
            }
            catch
            {
                tx.Rollback();
                throw;
            }
        }
    }

    private void SincronizarMovimentacoesNuvem()
    {
        using var pgConn = new NpgsqlConnection(_supabaseConnectionString);
        using var sqliteConn = new SqliteConnection($"Data Source={_sqliteDbPath}");
        pgConn.Open();
        sqliteConn.Open();

        using var tx = sqliteConn.BeginTransaction();
        try
        {
            // Primeiro limpa todas as movimentações locais
            using (var delCmd = sqliteConn.CreateCommand())
            {
                delCmd.CommandText = "DELETE FROM movimentacoes";
                delCmd.ExecuteNonQuery();
            }

            // Busca todas as movimentações do PostgreSQL
            using var pgCmd = pgConn.CreateCommand();
            pgCmd.CommandText = @"
                SELECT data, tipo, productid, produto, quantidade, responsavel, saida 
                FROM movimentacoes 
                ORDER BY data DESC";

            using var reader = pgCmd.ExecuteReader();
            while (reader.Read())
            {
                using var insertCmd = sqliteConn.CreateCommand();
                insertCmd.CommandText = @"
                    INSERT OR IGNORE INTO movimentacoes 
                    (data, tipo, productid, produto, quantidade, responsavel, saida) 
                    VALUES (@data, @tipo, @productid, @produto, @quantidade, @responsavel, @saida)";

                // Converte o timestamp para o formato de texto usado no SQLite
                string dataFormatada = reader.GetDateTime(0).ToString("yyyy-MM-dd HH:mm:ss");
                insertCmd.Parameters.AddWithValue("@data", dataFormatada);
                insertCmd.Parameters.AddWithValue("@tipo", reader.GetString(1));
                insertCmd.Parameters.AddWithValue("@productid", reader.GetInt32(2));
                insertCmd.Parameters.AddWithValue("@produto", reader.GetString(3));
                insertCmd.Parameters.AddWithValue("@quantidade", reader.GetInt32(4));
                insertCmd.Parameters.AddWithValue("@responsavel", reader.GetString(5));
                insertCmd.Parameters.AddWithValue("@saida", reader.IsDBNull(6) ? DBNull.Value : reader.GetString(6));
                insertCmd.ExecuteNonQuery();
            }

            tx.Commit();
            System.Diagnostics.Debug.WriteLine("Sincronização de movimentações concluída com sucesso");
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Erro ao sincronizar movimentações: {ex.Message}");
            tx.Rollback();
            throw;
        }
    }

