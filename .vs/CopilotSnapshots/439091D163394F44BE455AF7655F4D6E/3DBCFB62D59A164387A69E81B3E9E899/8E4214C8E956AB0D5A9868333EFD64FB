using Adega_Oak.Repositories;
using CommunityToolkit.Mvvm.ComponentModel;
using CommunityToolkit.Mvvm.Input;
using System.Collections.ObjectModel;

namespace Adega_Oak.Features.Drinks;

public partial class DrinksViewModel : ObservableObject
{
    private readonly DrinksRepository _drinksRepository;
    private readonly EstoqueRepository _estoqueRepository;

    [ObservableProperty]
    private ObservableCollection<DrinksRepository.Drink> drinks = new();

    [ObservableProperty]
    private DrinksRepository.Drink? selectedDrink;

    [ObservableProperty]
    private string tamanhoSelecionado = "M";

    [ObservableProperty]
    private int quantidade = 1;

    [ObservableProperty]
    private decimal valor = 0;

    [ObservableProperty]
    private string? responsavel;

    [ObservableProperty]
    private ObservableCollection<DrinksRepository.DrinkRecipeItem> ingredientes = new();

    [ObservableProperty]
    private ObservableCollection<ImpactItem> impactPreview = new();

    [ObservableProperty]
    private bool hasShortages = false;

    public DrinksViewModel(DrinksRepository drinksRepository, EstoqueRepository estoqueRepository)
    {
        _drinksRepository = drinksRepository;
        _estoqueRepository = estoqueRepository;
        CarregarDrinks();
    }

    [RelayCommand]
    private void CarregarDrinks()
    {
        Drinks.Clear();
        foreach (var d in _drinksRepository.GetDrinks())
            Drinks.Add(d);
    }

    partial void OnSelectedDrinkChanged(DrinksRepository.Drink? value)
    {
        if (value == null) return;
        Ingredientes.Clear();
        foreach (var r in _drinksRepository.GetRecipeForDrink(value.DrinkId))
            Ingredientes.Add(r);
        Valor = value.PrecoPadrao;
        TamanhoSelecionado = value.TamanhoPadrao;
    }

    public class ImpactItem
    {
        public int ProductId { get; set; }
        public int Required { get; set; }
        public int Available { get; set; }
        public bool Shortage { get; set; }
    }

    [RelayCommand]
    private void PreviewImpact()
    {
        ImpactPreview.Clear();
        if (SelectedDrink == null)
            return;

        int tamanhoMultiplier = MapTamanhoToMultiplier(TamanhoSelecionado);
        var recipes = _drinksRepository.GetRecipeForDrink(SelectedDrink.DrinkId);
        // load estoque once
        var estoque = _estoqueRepository.CarregarEstoqueCompleto().ToDictionary(e => e.ProductId);

        foreach (var r in recipes)
        {
            int required = r.QuantidadePorDrink * Quantidade * tamanhoMultiplier;
            int available = estoque.TryGetValue(r.ProductId, out var e) ? e.Quantidade : 0;
            var item = new ImpactItem
            {
                ProductId = r.ProductId,
                Required = required,
                Available = available,
                Shortage = available < required
            };
            ImpactPreview.Add(item);
        }

        HasShortages = ImpactPreview.Any(i => i.Shortage);
    }

    private int MapTamanhoToMultiplier(string tamanho)
    {
        return tamanho switch
        {
            "Pequeno" => 1,
            "Medio" => 2,
            "Grande" => 3,
            "P" => 1,
            "M" => 2,
            "G" => 3,
            _ => 1
        };
    }

    [RelayCommand]
    private void RegistrarDrink()
    {
        if (SelectedDrink == null)
        {
            System.Windows.MessageBox.Show("Selecione um combo de drink ou crie um.", "Aviso", System.Windows.MessageBoxButton.OK, System.Windows.MessageBoxImage.Warning);
            return;
        }
        if (string.IsNullOrEmpty(Responsavel))
        {
            System.Windows.MessageBox.Show("Selecione um responsável.", "Aviso", System.Windows.MessageBoxButton.OK, System.Windows.MessageBoxImage.Warning);
            return;
        }

        // ensure preview up to date
        PreviewImpact();

        if (HasShortages)
        {
            var resultado = System.Windows.MessageBox.Show("Alguns ingredientes estão com estoque insuficiente. Deseja registrar mesmo assim?", "Estoque insuficiente", System.Windows.MessageBoxButton.YesNo, System.Windows.MessageBoxImage.Warning);
            if (resultado == System.Windows.MessageBoxResult.No)
                return;
        }

        int tamanhoMultiplier = MapTamanhoToMultiplier(TamanhoSelecionado);

        // Criar instância e registrar movimentações
        _drinksRepository.CreateDrinkInstance(SelectedDrink.DrinkId, TamanhoSelecionado, Valor, Responsavel ?? "", Quantidade, tamanhoMultiplier);
        System.Windows.MessageBox.Show("Drink registrado com sucesso.", "Sucesso", System.Windows.MessageBoxButton.OK, System.Windows.MessageBoxImage.Information);
        CarregarDrinks();
        ImpactPreview.Clear();
        HasShortages = false;
    }

    [RelayCommand]
    private void GerenciarCombos()
    {
        // Abrir tela de gerenciamento de combos - futura implementação
        System.Windows.MessageBox.Show("Abrir gerenciamento de combos (ainda não implementado).", "Info", System.Windows.MessageBoxButton.OK, System.Windows.MessageBoxImage.Information);
    }
}
