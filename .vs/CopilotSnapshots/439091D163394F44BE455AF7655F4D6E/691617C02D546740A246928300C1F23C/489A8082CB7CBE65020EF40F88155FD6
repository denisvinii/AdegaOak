-- Add drinks tables for PostgreSQL

CREATE TABLE IF NOT EXISTS drinks (
    drink_id SERIAL PRIMARY KEY,
    nome TEXT NOT NULL,
    tamanho_padrao TEXT DEFAULT 'M',
    preco_padrao DECIMAL DEFAULT 0,
    productid INTEGER -- product in estoque representing the sale item
);

CREATE TABLE IF NOT EXISTS drink_recipes (
    id SERIAL PRIMARY KEY,
    drink_id INTEGER NOT NULL,
    productid INTEGER NOT NULL,
    quantidade_por_drink INTEGER NOT NULL DEFAULT 1,
    FOREIGN KEY (drink_id) REFERENCES drinks(drink_id)
);

CREATE TABLE IF NOT EXISTS drink_instances (
    id SERIAL PRIMARY KEY,
    drink_id INTEGER NOT NULL,
    tamanho TEXT,
    valor DECIMAL DEFAULT 0,
    responsavel TEXT,
    observacao TEXT,
    data TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (drink_id) REFERENCES drinks(drink_id)
);
