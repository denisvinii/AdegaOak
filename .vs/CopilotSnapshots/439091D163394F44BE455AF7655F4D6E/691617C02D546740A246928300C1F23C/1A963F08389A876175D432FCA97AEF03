<UserControl x:Class="Adega_Oak.Views.DrinksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <Grid Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="12" Padding="16" Effect="{DynamicResource MaterialDesignElevationShadow2}">
                <StackPanel>
                    <TextBlock Text="Registrar Drink" FontWeight="Bold" FontSize="16" Margin="0,0,0,12"/>

                    <ComboBox ItemsSource="{Binding Drinks}" DisplayMemberPath="Nome" SelectedItem="{Binding SelectedDrink, Mode=TwoWay}" Style="{StaticResource MaterialDesignFilledComboBox}" Margin="0,0,0,12"/>

                    <TextBlock Text="Tamanho do copo"/>
                    <ComboBox SelectedItem="{Binding TamanhoSelecionado, Mode=TwoWay}" Style="{StaticResource MaterialDesignFilledComboBox}" Margin="0,4,0,12">
                        <ComboBoxItem>Pequeno</ComboBoxItem>
                        <ComboBoxItem>Medio</ComboBoxItem>
                        <ComboBoxItem>Grande</ComboBoxItem>
                    </ComboBox>

                    <TextBlock Text="Quantidade"/>
                    <TextBox Text="{Binding Quantidade, Mode=TwoWay}" Style="{StaticResource MaterialDesignFilledTextBox}" Margin="0,4,0,12"/>

                    <TextBlock Text="Valor (R$)"/>
                    <TextBox Text="{Binding Valor, Mode=TwoWay, StringFormat=N2}" Style="{StaticResource MaterialDesignFilledTextBox}" Margin="0,4,0,12"/>

                    <TextBlock Text="Responsavel"/>
                    <ComboBox ItemsSource="{Binding DataContext.Responsaveis, RelativeSource={RelativeSource AncestorType=UserControl}}" SelectedItem="{Binding Responsavel, Mode=TwoWay}" Style="{StaticResource MaterialDesignFilledComboBox}" Margin="0,4,0,12"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Spacing="8">
                        <Button Command="{Binding PreviewImpactCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,4,0,0">Visualizar Impacto</Button>
                        <Button Command="{Binding RegistrarDrinkCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,4,0,0">Registrar Drink</Button>
                    </StackPanel>

                    <Button Command="{Binding GerenciarCombosCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,8,0,0">Gerenciar Combos</Button>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="12" Padding="16" Effect="{DynamicResource MaterialDesignElevationShadow2}">
                <StackPanel>
                    <TextBlock Text="Ingredientes do Combo" FontWeight="Bold" FontSize="16" Margin="0,0,0,12"/>
                    <DataGrid ItemsSource="{Binding Ingredientes}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Height="200">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ProductId" Binding="{Binding ProductId}" Width="*"/>
                            <DataGridTextColumn Header="Qtd/Drink" Binding="{Binding QuantidadePorDrink}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Text="Impacto no Estoque" FontWeight="Bold" FontSize="16" Margin="0,12,0,8"/>
                    <TextBlock Text="Atenção: existem faltas" Foreground="Red" Visibility="{Binding HasShortages, Converter={StaticResource BooleanToVisibilityConverter}}" FontWeight="Bold"/>

                    <DataGrid ItemsSource="{Binding ImpactPreview}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Shortage}" Value="True">
                                        <Setter Property="Background" Value="#FFDAD0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ProductId" Binding="{Binding ProductId}" Width="100"/>
                            <DataGridTextColumn Header="Required" Binding="{Binding Required}" Width="100"/>
                            <DataGridTextColumn Header="Available" Binding="{Binding Available}" Width="100"/>
                            <DataGridCheckBoxColumn Header="Shortage" Binding="{Binding Shortage}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>