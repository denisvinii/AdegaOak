using Adega_Oak.Services;
using System.Data;
using System.Collections.Generic;

namespace Adega_Oak.Repositories;

public class DrinksRepository
{
    private readonly DatabaseService _db;
    public DrinksRepository(DatabaseService db)
    {
        _db = db;
    }

    public class Drink
    {
        public int DrinkId { get; set; }
        public string Nome { get; set; } = string.Empty;
        public string TamanhoPadrao { get; set; } = "M";
        public decimal PrecoPadrao { get; set; }
        public int ProductId { get; set; } // product in estoque representing the drink sale
    }

    public class DrinkRecipeItem
    {
        public int DrinkRecipeId { get; set; }
        public int DrinkId { get; set; }
        public int ProductId { get; set; }
        public int QuantidadePorDrink { get; set; }
    }

    public class DrinkInstance
    {
        public int Id { get; set; }
        public int DrinkId { get; set; }
        public string Tamanho { get; set; } = "M";
        public decimal Valor { get; set; }
        public string Responsavel { get; set; } = string.Empty;
        public string Observacao { get; set; } = string.Empty;
        public DateTime Data { get; set; }
    }

    public IEnumerable<Drink> GetDrinks()
    {
        var lista = new List<Drink>();
        using var conn = _db.GetConnection();
        using var cmd = conn.CreateCommand();
        cmd.CommandText = "SELECT drink_id, nome, tamanho_padrao, preco_padrao, productid FROM drinks";
        using var reader = cmd.ExecuteReader();
        while (reader.Read())
        {
            lista.Add(new Drink
            {
                DrinkId = reader.GetInt32(0),
                Nome = reader.GetString(1),
                TamanhoPadrao = reader.IsDBNull(2) ? "M" : reader.GetString(2),
                PrecoPadrao = reader.IsDBNull(3) ? 0 : reader.GetDecimal(3),
                ProductId = reader.IsDBNull(4) ? 0 : reader.GetInt32(4)
            });
        }
        return lista;
    }

    public IEnumerable<DrinkRecipeItem> GetRecipeForDrink(int drinkId)
    {
        var lista = new List<DrinkRecipeItem>();
        using var conn = _db.GetConnection();
        using var cmd = conn.CreateCommand();
        cmd.CommandText = "SELECT id, drink_id, productid, quantidade_por_drink FROM drink_recipes WHERE drink_id = @drinkId";
        var p = cmd.CreateParameter(); p.ParameterName = "@drinkId"; p.Value = drinkId; cmd.Parameters.Add(p);
        using var reader = cmd.ExecuteReader();
        while (reader.Read())
        {
            lista.Add(new DrinkRecipeItem
            {
                DrinkRecipeId = reader.GetInt32(0),
                DrinkId = reader.GetInt32(1),
                ProductId = reader.GetInt32(2),
                QuantidadePorDrink = reader.GetInt32(3)
            });
        }
        return lista;
    }

    public int CreateDrink(string nome, string tamanhoPadrao, decimal precoPadrao, List<(int productId, int quantidade)> recipe)
    {
        using var conn = _db.GetConnection();
        using var tx = conn.BeginTransaction();
        try
        {
            // Create a product in estoque to represent the drink sale
            using var cmdMax = conn.CreateCommand();
            cmdMax.CommandText = "SELECT COALESCE(MAX(productid),0) + 1 FROM estoque";
            var nextIdObj = cmdMax.ExecuteScalar();
            int nextId = Convert.ToInt32(nextIdObj);

            using var insertProduto = conn.CreateCommand();
            insertProduto.CommandText = @"INSERT INTO estoque (productid, bebida, tamanho, material, valor_venda) VALUES (@id, @bebida, @tamanho, @material, @valor)";
            insertProduto.Parameters.AddWithValue("@id", nextId);
            insertProduto.Parameters.AddWithValue("@bebida", "DRINK - " + nome);
            insertProduto.Parameters.AddWithValue("@tamanho", tamanhoPadrao ?? "M");
            insertProduto.Parameters.AddWithValue("@material", "Drink");
            insertProduto.Parameters.AddWithValue("@valor", precoPadrao);
            insertProduto.ExecuteNonQuery();

            // Insert into drinks table
            using var cmd = conn.CreateCommand();
            cmd.CommandText = "INSERT INTO drinks (nome, tamanho_padrao, preco_padrao, productid) VALUES (@nome, @tamanho, @preco, @productid) RETURNING drink_id";
            cmd.Parameters.AddWithValue("@nome", nome);
            cmd.Parameters.AddWithValue("@tamanho", tamanhoPadrao);
            cmd.Parameters.AddWithValue("@preco", precoPadrao);
            cmd.Parameters.AddWithValue("@productid", nextId);
            var drinkIdObj = cmd.ExecuteScalar();
            int drinkId = Convert.ToInt32(drinkIdObj);

            // Insert recipe
            foreach (var item in recipe)
            {
                using var rc = conn.CreateCommand();
                rc.CommandText = "INSERT INTO drink_recipes (drink_id, productid, quantidade_por_drink) VALUES (@did, @pid, @qtd)";
                rc.Parameters.AddWithValue("@did", drinkId);
                rc.Parameters.AddWithValue("@pid", item.productId);
                rc.Parameters.AddWithValue("@qtd", item.quantidade);
                rc.ExecuteNonQuery();
            }

            tx.Commit();
            return drinkId;
        }
        catch
        {
            tx.Rollback();
            throw;
        }
    }

    public int CreateDrinkInstance(int drinkId, string tamanho, decimal valor, string responsavel, string? observacao = null)
    {
        using var conn = _db.GetConnection();
        using var tx = conn.BeginTransaction();
        try
        {
            // Insert instance
            using var cmd = conn.CreateCommand();
            cmd.CommandText = "INSERT INTO drink_instances (drink_id, tamanho, valor, responsavel, observacao, data) VALUES (@did, @tamanho, @valor, @resp, @obs, @data) RETURNING id";
            cmd.Parameters.AddWithValue("@did", drinkId);
            cmd.Parameters.AddWithValue("@tamanho", tamanho);
            cmd.Parameters.AddWithValue("@valor", valor);
            cmd.Parameters.AddWithValue("@resp", responsavel);
            cmd.Parameters.AddWithValue("@obs", observacao ?? string.Empty);
            cmd.Parameters.AddWithValue("@data", DateTime.Now);
            var instObj = cmd.ExecuteScalar();
            int instanceId = Convert.ToInt32(instObj);

            // Get drink productid to record sale
            int drinkProductId = 0;
            using (var q = conn.CreateCommand())
            {
                q.CommandText = "SELECT productid FROM drinks WHERE drink_id = @did";
                q.Parameters.AddWithValue("@did", drinkId);
                var r = q.ExecuteScalar();
                drinkProductId = r == null ? 0 : Convert.ToInt32(r);
            }

            // Insert sale movimentacao (1 unidade do produto drink)
            using (var saleCmd = conn.CreateCommand())
            {
                saleCmd.CommandText = @"INSERT INTO movimentacoes (data, tipo, tipo_venda, productid, produto, quantidade, responsavel, saida, valor_unitario) VALUES (@data, @tipo, @tipo_venda, @productid, @produto, @quantidade, @responsavel, @saida, @valor_unitario)";
                saleCmd.Parameters.AddWithValue("@data", DateTime.Now);
                saleCmd.Parameters.AddWithValue("@tipo", "Saída");
                saleCmd.Parameters.AddWithValue("@tipo_venda", "Varejo");
                saleCmd.Parameters.AddWithValue("@productid", drinkProductId);
                saleCmd.Parameters.AddWithValue("@produto", "DRINK - " + drinkId);
                saleCmd.Parameters.AddWithValue("@quantidade", 1);
                saleCmd.Parameters.AddWithValue("@responsavel", responsavel);
                saleCmd.Parameters.AddWithValue("@saida", "Venda (Drink)");
                saleCmd.Parameters.AddWithValue("@valor_unitario", valor);
                saleCmd.ExecuteNonQuery();
            }

            // Insert ingredient consumptions as movimentacoes with valor_unitario = 0
            var recipes = GetRecipeForDrink(drinkId);
            foreach (var r in recipes)
            {
                using var ingCmd = conn.CreateCommand();
                ingCmd.CommandText = @"INSERT INTO movimentacoes (data, tipo, tipo_venda, productid, produto, quantidade, responsavel, saida, valor_unitario) VALUES (@data, @tipo, @tipo_venda, @productid, @produto, @quantidade, @responsavel, @saida, @valor_unitario)";
                ingCmd.Parameters.AddWithValue("@data", DateTime.Now);
                ingCmd.Parameters.AddWithValue("@tipo", "Saída");
                ingCmd.Parameters.AddWithValue("@tipo_venda", "Varejo");
                ingCmd.Parameters.AddWithValue("@productid", r.ProductId);
                ingCmd.Parameters.AddWithValue("@produto", r.ProductId);
                ingCmd.Parameters.AddWithValue("@quantidade", r.QuantidadePorDrink);
                ingCmd.Parameters.AddWithValue("@responsavel", responsavel);
                ingCmd.Parameters.AddWithValue("@saida", "Consumo (Drink)");
                ingCmd.Parameters.AddWithValue("@valor_unitario", 0);
                ingCmd.ExecuteNonQuery();
            }

            tx.Commit();
            return instanceId;
        }
        catch
        {
            tx.Rollback();
            throw;
        }
    }
}
