<UserControl x:Class="Adega_Oak.Views.DespesasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1200">
    <Grid Background="#1A1A1A">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Painel Esquerdo - Formulario -->
        <Border Grid.Column="0" Background="#2D2D2D" BorderBrush="#E65100" BorderThickness="0,0,2,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <!-- Titulo -->
                    <TextBlock Text="Nova Despesa" FontSize="20" FontWeight="Bold" Foreground="#E65100" Margin="0,0,0,20"/>

                    <!-- Campo: Descricao -->
                    <TextBlock Text="Descricao" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Border Background="#353535" BorderBrush="#E65100" BorderThickness="1" CornerRadius="6" Padding="1" Margin="0,0,0,16">
                        <TextBox Background="#353535" Foreground="#FFFFFF" BorderThickness="0"
                                 Text="{Binding Descricao, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="11" MinHeight="40" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Campo: Valor -->
                    <TextBlock Text="Valor (R$)" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Border Background="#353535" BorderBrush="#E65100" BorderThickness="1" CornerRadius="6" Padding="1" Margin="0,0,0,16">
                        <TextBox Background="#353535" Foreground="#FFFFFF" BorderThickness="0"
                                 Text="{Binding Valor, Mode=TwoWay, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="11" MinHeight="40"/>
                    </Border>

                    <!-- Campo: Data -->
                    <TextBlock Text="Data" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <DatePicker SelectedDate="{Binding DataDespesa, Mode=TwoWay}" 
                               Background="#353535" Foreground="#FFFFFF" BorderBrush="#E65100"
                               Padding="12" Margin="0,0,0,16" MinHeight="40"/>

                    <!-- Campo: Tipo de Despesa -->
                    <TextBlock Text="Tipo de Despesa" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding TiposDespesa}" 
                             Background="#353535" Foreground="#FFFFFF" BorderBrush="#E65100"
                             SelectedIndex="{Binding TipoDespesaSelecionado, Converter={StaticResource EnumToIntConverter}}"
                             Padding="12" Margin="0,0,0,16" MinHeight="40"/>

                    <!-- Campo: Notas -->
                    <TextBlock Text="Notas (Opcional)" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Border Background="#353535" BorderBrush="#E65100" BorderThickness="1" CornerRadius="6" Padding="1" Margin="0,0,0,20">
                        <TextBox Background="#353535" Foreground="#FFFFFF" BorderThickness="0"
                                 Text="{Binding Notas, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="11" MinHeight="80" TextWrapping="Wrap" AcceptsReturn="True"/>
                    </Border>

                    <!-- Botoes de Acao -->
                    <StackPanel Orientation="Vertical" Margin="0,10,0,0">
                        <!-- Botao: Adicionar -->
                        <Button Content="Adicionar Despesa"
                               Command="{Binding AdicionarDespesaCommand}"
                               Background="#E65100" Foreground="White" FontWeight="Bold" FontSize="14"
                               Padding="12,12" Margin="0,0,0,10" Cursor="Hand" MinHeight="42">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#D84A00"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Botao: Salvar Edicao -->
                        <Button Content="Salvar Alteracoes"
                               Command="{Binding SalvarEdicaoCommand}"
                               Background="#2196F3" Foreground="White" FontWeight="Bold" FontSize="14"
                               Padding="12,12" Margin="0,0,0,10" Cursor="Hand" MinHeight="42"
                               Visibility="{Binding EmEdicao, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1976D2"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Botao: Cancelar -->
                        <Button Content="Cancelar Edicao" 
                               Command="{Binding CancelarEdicaoCommand}"
                               Background="#666666" Foreground="White" FontWeight="Bold" FontSize="14"
                               Padding="12,12" Margin="0,0,0,10" Cursor="Hand" MinHeight="42"
                               Visibility="{Binding EmEdicao, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#555555"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Botao: Limpar -->
                        <Button Content="Limpar Formulario" 
                               Command="{Binding CancelarEdicaoCommand}"
                               Background="#555555" Foreground="White" FontWeight="SemiBold" FontSize="12"
                               Padding="8,10" Cursor="Hand" MinHeight="38"
                               Visibility="{Binding EmEdicao, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#444444"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Painel Direito - Lista de Despesas -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header com Resumo -->
            <Border Grid.Row="0" Background="#2D2D2D" BorderBrush="#555555" BorderThickness="0,0,0,1" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Titulo -->
                    <StackPanel Grid.Column="0" Orientation="Vertical">
                        <TextBlock Text="Controle de Despesas" FontSize="24" FontWeight="Bold" Foreground="#E65100"/>
                        <TextBlock Text="Gerencie gastos avulsos e mensais" Foreground="#AAAAAA" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Cards de Resumo -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- Card: Total Nao Pago -->
                        <Border Background="#C0392B" CornerRadius="8" Padding="16" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="Nao Pago" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding TotalDespesasNaoPagas, StringFormat=R$ {0:N2}}" 
                                          Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Card: Total Pago -->
                        <Border Background="#27AE60" CornerRadius="8" Padding="16" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="Pago" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding TotalDespesasPagas, StringFormat=R$ {0:N2}}" 
                                          Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Card: Saldo Livre -->
                        <Border Background="#1E8449" CornerRadius="8" Padding="16">
                            <StackPanel>
                                <TextBlock Text="Saldo Livre" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SaldoAtualizado, StringFormat=R$ {0:N2}}" 
                                          Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Filtros -->
            <Border Grid.Row="1" Background="#353535" BorderBrush="#555555" BorderThickness="0,0,0,1" Padding="20">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ComboBox ItemsSource="{Binding Meses}" 
                             SelectedItem="{Binding MesSelecionado}"
                             Width="100" Background="#2D2D2D" Foreground="#FFFFFF" 
                             BorderBrush="#E65100" Padding="10" Margin="0,0,10,0" MinHeight="35"/>
                    
                    <ComboBox ItemsSource="{Binding Anos}" 
                             SelectedItem="{Binding AnoSelecionado}"
                             Width="100" Background="#2D2D2D" Foreground="#FFFFFF" 
                             BorderBrush="#E65100" Padding="10" Margin="0,0,10,0" MinHeight="35"/>
                    
                    <Button Content="Filtrar" 
                           Command="{Binding FiltrarPorPeriodoCommand}"
                           Background="#E65100" Foreground="White" FontWeight="Bold"
                           Padding="16,8" Cursor="Hand" Margin="0,0,10,0" MinHeight="35"/>

                    <Button Content="Recarregar" 
                           Command="{Binding CarregarDespesasCommand}"
                           Background="#2196F3" Foreground="White" FontWeight="Bold"
                           Padding="16,8" Cursor="Hand" MinHeight="35"/>
                </StackPanel>
            </Border>

            <!-- DataGrid com Despesas -->
            <Border Grid.Row="2" Background="#2D2D2D" Margin="0" Padding="0">
                <DataGrid ItemsSource="{Binding Despesas}" 
                         SelectedItem="{Binding DespesaSelecionada, Mode=TwoWay}"
                         AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                         Background="#2D2D2D" HeadersVisibility="Column" RowHeight="50" FontSize="13"
                         BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#404040">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="#2D2D2D"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3D3D3D"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#E65100"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#353535"/>
                            <Setter Property="Foreground" Value="#E65100"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="BorderBrush" Value="#404040"/>
                            <Setter Property="BorderThickness" Value="0,0,1,0"/>
                        </Style>
                    </DataGrid.Resources>
                    
                    <DataGrid.Columns>
                        <!-- Data -->
                        <DataGridTextColumn Header="Data" Binding="{Binding Data, StringFormat={}{0:dd/MM/yyyy}}" Width="100"/>
                        
                        <!-- Tipo -->
                        <DataGridTemplateColumn Header="Tipo" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Canvas Width="24" Height="24" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,0,8,0">
                                            <Path Data="{Binding Tipo, Converter={StaticResource TipoDespesaToIconPathConverter}}"
                                                  Fill="{Binding Tipo, Converter={StaticResource TipoDespesaToColorConverter}}"
                                                  Stretch="Uniform" Width="20" Height="20"/>
                                        </Canvas>
                                        
                                        <TextBlock Text="{Binding Tipo, Converter={StaticResource TipoDespesaToStringConverter}}" 
                                                   Foreground="White" FontWeight="SemiBold" TextAlignment="Left" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Descricao -->
                        <DataGridTextColumn Header="Descricao" Binding="{Binding Descricao}" Width="*"/>
                        
                        <!-- Valor -->
                        <DataGridTextColumn Header="Valor" Binding="{Binding Valor, StringFormat=R$ {0:N2}}" Width="120">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Foreground" Value="#FF9800"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>

                        <!-- Status Pagamento -->
                        <DataGridTemplateColumn Header="Status" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding Pago, Converter={StaticResource PagoToColorConverter}}" 
                                           CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="{Binding Pago, Converter={StaticResource PagoToStringConverter}}" 
                                                  Foreground="White" FontWeight="SemiBold" TextAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Acoes -->
                        <DataGridTemplateColumn Header="Acoes" Width="280">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4">
                                        <!-- Editar -->
                                        <Button Content="Editar" 
                                               Command="{Binding DataContext.EditarDespesaCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                               Background="#2196F3" Foreground="White" FontWeight="Bold" FontSize="11"
                                               Padding="8,6" Margin="2,0" Cursor="Hand" MinWidth="70"/>

                                        <!-- Pago/Nao Pago -->
                                        <Button Content="{Binding Pago, Converter={StaticResource PagoToActionConverter}}"
                                               Background="{Binding Pago, Converter={StaticResource PagoToButtonColorConverter}}" 
                                               Foreground="White" FontWeight="Bold" FontSize="11"
                                               Padding="8,6" Margin="2,0" Cursor="Hand" MinWidth="70"
                                               Command="{Binding DataContext.MarcarComoPagoCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>

                                        <!-- Deletar -->
                                        <Button Content="Deletar" 
                                               Command="{Binding DataContext.DeletarDespesaCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                               Background="#D32F2F" Foreground="White" FontWeight="Bold" FontSize="11"
                                               Padding="8,6" Margin="2,0" Cursor="Hand" MinWidth="70"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Rodape com Total -->
            <Border Grid.Row="3" Background="#353535" BorderBrush="#555555" BorderThickness="0,1,0,0" Padding="20">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Total do Periodo: " Foreground="#AAAAAA" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding TotalDespesasNaoPagas, StringFormat=R$ {0:N2}}" 
                              Foreground="#FF9800" FontSize="16" FontWeight="Bold" Margin="0,0,30,0"/>
                    <TextBlock Text="Pago: " Foreground="#AAAAAA" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding TotalDespesasPagas, StringFormat=R$ {0:N2}}" 
                              Foreground="#27AE60" FontSize="16" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
