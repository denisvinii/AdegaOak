    public decimal ObterTotalDespesasNaoPagas()
    {
        try
        {
            using var conn = _dbService.GetConnection();
            using var cmd = conn.CreateCommand();
            cmd.CommandText = "SELECT COALESCE(SUM(valor), 0) FROM despesas WHERE pago = 0";
            
            var result = cmd.ExecuteScalar();
            return result != null ? Convert.ToDecimal(result) : 0m;
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Erro ao obter total de despesas não pagas: {ex.Message}");
            return 0m;
        }
    }

    public decimal ObterTotalDespesasDoMes(int mes, int ano)
    {
        try
        {
            using var conn = _dbService.GetConnection();
            using var cmd = conn.CreateCommand();
            cmd.CommandText = @"
                SELECT COALESCE(SUM(valor), 0) FROM despesas 
                WHERE strftime('%m', data) = @mes AND strftime('%Y', data) = @ano";
            
            var param1 = cmd.CreateParameter();
            param1.ParameterName = "@mes";
            param1.Value = mes.ToString("D2");
            cmd.Parameters.Add(param1);

            var param2 = cmd.CreateParameter();
            param2.ParameterName = "@ano";
            param2.Value = ano.ToString();
            cmd.Parameters.Add(param2);
            
            var result = cmd.ExecuteScalar();
            return result != null ? Convert.ToDecimal(result) : 0m;
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Erro ao obter total do mês: {ex.Message}");
            return 0m;
        }
    }

