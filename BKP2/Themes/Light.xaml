<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Cores Base (Seguindo o padrão WPF) -->
    <Color x:Key="Primary">#1976D2</Color>
    <Color x:Key="PrimaryDark">#1565C0</Color>
    <Color x:Key="PrimaryLight">#42A5F5</Color>
    <Color x:Key="Accent">#FF4081</Color>
    
    <!-- Cores de Texto (Padrão WPF) -->
    <Color x:Key="TextPrimary">#000000</Color>
    <Color x:Key="TextSecondary">#666666</Color>
    <Color x:Key="TextDisabled">#9E9E9E</Color>
    
    <!-- Cores de Fundo -->
    <Color x:Key="Background">#FFFFFF</Color>
    <Color x:Key="Surface">#F5F5F5</Color>
    <Color x:Key="WindowBackground">#FFFFFF</Color>
    <Color x:Key="ControlBackground">#FFFFFF</Color>
    
    <!-- Status -->
    <Color x:Key="Error">#D32F2F</Color>
    <Color x:Key="Success">#388E3C</Color>
    <Color x:Key="Warning">#F57C00</Color>
    <Color x:Key="Info">#1976D2</Color>
    
    <!-- Elementos de Interface -->
    <Color x:Key="Border">#BDBDBD</Color>
    <Color x:Key="Divider">#E0E0E0</Color>
    <Color x:Key="Selection">#E3F2FD</Color>
    <Color x:Key="Focus">#2196F3</Color>
    
    <!-- Controles -->
    <Color x:Key="ButtonBackground">#F5F5F5</Color>
    <Color x:Key="ButtonBackgroundHover">#E0E0E0</Color>
    <Color x:Key="ButtonBackgroundPressed">#BDBDBD</Color>
    <Color x:Key="ButtonBorder">#BDBDBD</Color>
    <Color x:Key="ButtonText">#000000</Color>
    
    <!-- DataGrid -->
    <Color x:Key="DataGridBackground">#FFFFFF</Color>
    <Color x:Key="DataGridHeaderBackground">#F5F5F5</Color>
    <Color x:Key="DataGridBorder">#E0E0E0</Color>
    <Color x:Key="DataGridSelectedBackground">#E3F2FD</Color>
    <Color x:Key="DataGridAlternatingBackground">#F5F5F5</Color>
    
    <!-- ComboBox -->
    <Color x:Key="ComboBoxBackground">#FFFFFF</Color>
    <Color x:Key="ComboBoxBorder">#BDBDBD</Color>
    <Color x:Key="ComboBoxSelectionBackground">#E3F2FD</Color>
    
    <!-- TextBox -->
    <Color x:Key="TextBoxBackground">#FFFFFF</Color>
    <Color x:Key="TextBoxBorder">#BDBDBD</Color>
    <Color x:Key="TextBoxFocusedBorder">#2196F3</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDark}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLight}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabled}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource Background}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}"/>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackground}"/>
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="{StaticResource ControlBackground}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource Error}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource Info}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}"/>
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource Divider}"/>
    <SolidColorBrush x:Key="SelectionBrush" Color="{StaticResource Selection}"/>
    <SolidColorBrush x:Key="FocusBrush" Color="{StaticResource Focus}"/>
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="{StaticResource ButtonBackground}"/>
    <SolidColorBrush x:Key="ButtonBackgroundHoverBrush" Color="{StaticResource ButtonBackgroundHover}"/>
    <SolidColorBrush x:Key="ButtonBackgroundPressedBrush" Color="{StaticResource ButtonBackgroundPressed}"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="{StaticResource ButtonBorder}"/>
    <SolidColorBrush x:Key="ButtonTextBrush" Color="{StaticResource ButtonText}"/>
    <SolidColorBrush x:Key="DataGridBackgroundBrush" Color="{StaticResource DataGridBackground}"/>
    <SolidColorBrush x:Key="DataGridHeaderBackgroundBrush" Color="{StaticResource DataGridHeaderBackground}"/>
    <SolidColorBrush x:Key="DataGridBorderBrush" Color="{StaticResource DataGridBorder}"/>
    <SolidColorBrush x:Key="DataGridSelectedBackgroundBrush" Color="{StaticResource DataGridSelectedBackground}"/>
    <SolidColorBrush x:Key="DataGridAlternatingBackgroundBrush" Color="{StaticResource DataGridAlternatingBackground}"/>
    <SolidColorBrush x:Key="ComboBoxBackgroundBrush" Color="{StaticResource ComboBoxBackground}"/>
    <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="{StaticResource ComboBoxBorder}"/>
    <SolidColorBrush x:Key="ComboBoxSelectionBackgroundBrush" Color="{StaticResource ComboBoxSelectionBackground}"/>
    <SolidColorBrush x:Key="TextBoxBackgroundBrush" Color="{StaticResource TextBoxBackground}"/>
    <SolidColorBrush x:Key="TextBoxBorderBrush" Color="{StaticResource TextBoxBorder}"/>
    <SolidColorBrush x:Key="TextBoxFocusedBorderBrush" Color="{StaticResource TextBoxFocusedBorder}"/>
</ResourceDictionary>